# Copy to .cursor/agent-schedule.env and edit (gitignored).
# Used by agent-schedule-run.sh and agent-schedule-install.sh.

# systemd OnCalendar expression (see `man systemd.time`).
# Examples:
#   "Mon *-*-* 09:00:00"     — Mondays at 09:00 local time
#   "*-*-* 08:30:00"         — every day at 08:30
#   "hourly"                 — top of each hour
AGENT_SCHEDULE_ONCALENDAR="Mon *-*-* 09:00:00"

# Optional: pass through to `agent --model` (empty = CLI default).
AGENT_SCHEDULE_MODEL=""

# Non-interactive agent flags (see `agent --help`).
AGENT_SCHEDULE_EXTRA_FLAGS="--force"

# Prompt sent to `agent -p` on each scheduled run.
AGENT_SCHEDULE_PROMPT="Run page-consistency-team skill in audit mode. Goal: weekly design consistency sweep across all 6 nav views. Report findings only; do not edit files unless P0."

# Optional API key (otherwise agent uses stored Cursor auth).
# CURSOR_API_KEY=""
