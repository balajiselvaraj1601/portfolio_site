---
import Divider from '@components/ui/Divider.astro';
import Hero from '@components/sections/Hero.astro';
import Impact from '@components/sections/Impact.astro';
import Vision from '@components/sections/Vision.astro';
import VisionBoard from '@components/sections/VisionBoard.astro';
import ThirukuralQuote from '@components/sections/ThirukuralQuote.astro';
import AboutLanding from '@components/sections/AboutLanding.astro';
import LeadershipPhilosophy from '@components/sections/LeadershipPhilosophy.astro';
import Experience from '@components/sections/Experience.astro';
import ExperienceIntro from '@components/sections/ExperienceIntro.astro';
import ProjectsIntro from '@components/sections/ProjectsIntro.astro';
import FeaturedCaseStudies from '@components/sections/FeaturedCaseStudies.astro';
import GenerativeAI from '@components/sections/GenerativeAI.astro';
import Education from '@components/sections/Education.astro';
import Awards from '@components/sections/Awards.astro';
import Publications from '@components/sections/Publications.astro';
import Conferences from '@components/sections/Conferences.astro';
import Speakers from '@components/sections/Speakers.astro';
import Kaggle from '@components/sections/Kaggle.astro';
import Contact from '@components/sections/Contact.astro';
import { sectionViewMap, navViews, navHref } from '@lib/content';

/**
 * Every imported `.astro` file's default export shares the same component
 * factory type, so derive it from a real component instead of importing
 * Astro's internal `astro/runtime/server` path (not a stable public export).
 */
type SectionComponent = typeof Hero;

const SECTIONS: Record<string, SectionComponent> = {
  hero: Hero,
  thirukural: ThirukuralQuote,
  impact: Impact,
  'technical-vision': Vision,
  'vision-board': VisionBoard,
  leadership: LeadershipPhilosophy,
  experience: Experience,
  'experience-intro': ExperienceIntro,
  'projects-intro': ProjectsIntro,
  'featured-case-studies': FeaturedCaseStudies,
  'generative-ai': GenerativeAI,
  education: Education,
  awards: Awards,
  publications: Publications,
  conferences: Conferences,
  speakers: Speakers,
  kaggle: Kaggle,
  contact: Contact,
};

interface Props {
  sections: string[];
  /** When true, wrap sections with data-nav-views for client-side view filtering. */
  navViews?: boolean;
}

const { sections, navViews: navViewsMode = false } = Astro.props;

const projectsView = navViews.find((v) => v.id === 'projects');
const researchView = navViews.find((v) => v.id === 'research');

function sectionProps(id: string): Record<string, string> {
  if (id === 'featured-case-studies' && projectsView) {
    return { showMoreHref: navHref(projectsView) };
  }
  if (id === 'publications' && researchView) {
    return { showMoreHref: navHref(researchView) };
  }
  return {};
}
---

{
  sections.map((id, index) => {
    const Section = SECTIONS[id];
    if (!Section) return null;

    if (id === 'thirukural' && sections[index - 1] === 'hero') return null;

    if (id === 'hero' && sections[index + 1] === 'thirukural') {
      const heroViews = navViewsMode ? sectionViewMap.hero?.join(' ') : undefined;
      const kuralViews = navViewsMode
        ? sectionViewMap.thirukural?.join(' ')
        : undefined;

      return (
        <AboutLanding>
          {navViewsMode && heroViews ? (
            <div
              class="section-view-root"
              data-nav-views={heroViews}
              data-section-id="hero"
            >
              <Hero />
            </div>
          ) : (
            <Hero />
          )}
          {navViewsMode && kuralViews ? (
            <div
              class="section-view-root"
              data-nav-views={kuralViews}
              data-section-id="thirukural"
            >
              <ThirukuralQuote />
            </div>
          ) : (
            <ThirukuralQuote />
          )}
        </AboutLanding>
      );
    }

    const showDivider = index > 0 && id !== 'hero' && id !== 'thirukural';
    const views = navViewsMode ? sectionViewMap[id]?.join(' ') : undefined;
    const extra = sectionProps(id);

    return (
      <>
        {showDivider && <Divider data-nav-divider={navViewsMode || undefined} />}
        {navViewsMode && views ? (
          <div
            class="section-view-root"
            data-nav-views={views}
            data-section-id={id}
          >
            <Section {...extra} />
          </div>
        ) : (
          <Section {...extra} />
        )}
      </>
    );
  })
}
