---
// Decorative monogram mark. Initials are derived from site.name (SSOT — no
// hardcoded letters). aria-hidden: the full name is already an accessible H1.
import { site } from '@lib/content';

interface Props {
  /** Edge length in px. */
  size?: number;
  class?: string;
}
const { size = 64, class: cls } = Astro.props;

const initials = site.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w.charAt(0).toUpperCase())
  .join('');
---

<span
  class:list={['monogram', cls]}
  style={`--monogram-size:${size}px`}
  aria-hidden="true"
>
  {initials}
</span>

<style>
  .monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--monogram-size);
    height: var(--monogram-size);
    border-radius: calc(var(--monogram-size) * 0.28);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    color: var(--accent);
    font-weight: 700;
    font-size: calc(var(--monogram-size) * 0.4);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    user-select: none;
  }
</style>
