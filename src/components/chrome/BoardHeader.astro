---
import Icon from '@components/ui/Icon.astro';

interface Props {
  title: string;
  /** Chevron direction flanking the title: 'in' points toward it, 'out' away. */
  flank?: 'in' | 'out';
  /** Optional id on the rendered heading so a parent can aria-labelledby it. */
  id?: string;
  /** Heading level of the title. */
  as?: 'h2' | 'h3';
  /** 'sm' renders a compact sub-board header. */
  size?: 'md' | 'sm';
}

const {
  title,
  flank = 'in',
  id,
  as: Heading = 'h2',
  size = 'md',
} = Astro.props as Props;
const chevSize = size === 'sm' ? 14 : 16;
---

<div class:list={['bhead', `bhead--${flank}`, { 'bhead--sm': size === 'sm' }]}>
  <span class="bhead__rule" aria-hidden="true"></span>
  <span class="bhead__chev bhead__chev--left" aria-hidden="true">
    <Icon name="chevron-right" size={chevSize} />
    <Icon name="chevron-right" size={chevSize} />
  </span>
  <Heading class="bhead__title" id={id}>{title}</Heading>
  <span class="bhead__chev bhead__chev--right" aria-hidden="true">
    <Icon name="chevron-right" size={chevSize} />
    <Icon name="chevron-right" size={chevSize} />
  </span>
  <span class="bhead__rule" aria-hidden="true"></span>
</div>

<style>
  .bhead {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: 100%;
  }
  .bhead__rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--border-strong),
      transparent
    );
  }
  .bhead__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 2vw, 2.1rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--heading);
    margin: 0;
    text-align: center;
    white-space: nowrap;
  }
  .bhead__chev {
    display: inline-flex;
    color: var(--accent-light);
    opacity: 0.55;
  }
  .bhead__chev :global(svg) {
    margin-inline: -5px;
  }
  /* 'in' → chevrons point toward the title (left group flipped). */
  .bhead--in .bhead__chev--left {
    transform: scaleX(-1);
  }
  /* 'out' → chevrons point away from the title (right group flipped). */
  .bhead--out .bhead__chev--right {
    transform: scaleX(-1);
  }
  .bhead--sm .bhead__title {
    font-size: clamp(1.15rem, 0.85rem + 1.4vw, 1.6rem);
  }
  @media (max-width: 600px) {
    .bhead__title {
      white-space: normal;
      font-size: var(--fs-xl);
    }
  }
</style>
