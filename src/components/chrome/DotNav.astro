---
import { dotNavLabels } from '@lib/content';

interface Props {
  sections: string[];
}
const { sections } = Astro.props;
---

<nav
  class="dot-nav"
  id="dot-nav"
  aria-label="Section navigation"
  hidden={sections.length < 2}
>
  {
    sections.map((id) => {
      const label = dotNavLabels[id] ?? id;
      return (
        <button
          type="button"
          class="dot-nav__dot"
          data-target={id}
          title={label}
          aria-label={label}
          hidden
        />
      );
    })
  }
</nav>

<style>
  .dot-nav {
    position: fixed;
    right: 2.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .dot-nav[hidden] {
    display: none;
  }
  .dot-nav__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: var(--text-muted);
    cursor: pointer;
    transition:
      background var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .dot-nav__dot[hidden] {
    display: none;
  }
  .dot-nav__dot:hover {
    background: var(--accent-ll);
  }
  .dot-nav__dot.is-active {
    background: var(--accent-light);
    transform: scale(1.5);
  }
  .dot-nav__dot:focus-visible {
    outline: 2px solid var(--accent-light);
    outline-offset: 3px;
  }
  @media (max-width: 900px) {
    .dot-nav {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('dot-nav');
  if (nav) {
    const dots = Array.from(nav.querySelectorAll<HTMLElement>('.dot-nav__dot'));

    const setActive = (id: string) => {
      dots.forEach((d) => {
        const active = d.dataset.target === id;
        d.classList.toggle('is-active', active);
        if (active) d.setAttribute('aria-current', 'true');
        else d.removeAttribute('aria-current');
      });
    };

    // All sections are visible on a single-page scroll — show every dot and
    // let a scroll-spy track which section is centered.
    dots.forEach((dot) => {
      dot.hidden = false;
      dot.addEventListener('click', () => {
        const target = document.getElementById(dot.dataset.target ?? '');
        if (target) {
          const reduce = window.matchMedia(
            '(prefers-reduced-motion: reduce)'
          ).matches;
          target.scrollIntoView({
            behavior: reduce ? 'auto' : 'smooth',
            block: 'start',
          });
        }
      });
    });

    const observed = dots
      .map((d) => document.getElementById(d.dataset.target ?? ''))
      .filter((el): el is HTMLElement => el !== null);

    nav.hidden = observed.length < 2;
    if (observed.length >= 2 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]?.target.id) setActive(visible[0].target.id);
        },
        { rootMargin: '-40% 0px -40% 0px', threshold: [0, 0.25, 0.5] }
      );
      observed.forEach((el) => observer.observe(el));
      if (observed[0]?.id) setActive(observed[0].id);
    } else if (observed[0]?.id) {
      setActive(observed[0].id);
    }
  }
</script>
