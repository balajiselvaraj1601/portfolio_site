---
import { site, profile, experience } from '@lib/content';
import { THEME_BG } from '@lib/theme-colors';

interface Props {
  /** Page title; defaults to the site SEO title. */
  title?: string;
  description?: string;
  /** Path of the current page relative to the site root, e.g. "/" or "/404". */
  path?: string;
  /** Preload LCP portrait image (home hero). */
  preloadPortrait?: { webp?: string; avif?: string };
}

const { title, description, path = '/', preloadPortrait } = Astro.props;

const pageTitle = title ?? site.seo.title;
const pageDesc = description ?? site.seo.description;

// Absolute URLs derive from `Astro.site` (set once in astro.config.mjs → SSOT).
// If `site` is unset (e.g. local dev without config), fall back to the request origin.
const origin = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(path, origin).href;
const ogImage = new URL(site.seo.ogImage, origin).href;

// JSON-LD Person — derived from content/person/profile.json.
const linkedin = profile.contact.find((c) => c.type === 'linkedin')?.href;
const github = profile.contact.find((c) => c.type === 'github')?.href;
const kaggle = profile.contact.find((c) => c.type === 'kaggle')?.href;
const email = profile.contact.find((c) => c.type === 'email')?.value;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.title,
  ...(email ? { email } : {}),
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.location.split(',')[0]?.trim() ?? site.location,
    addressCountry: site.location.includes('Sweden') ? 'SE' : undefined,
  },
  url: new URL('/', origin).href,
  sameAs: [linkedin, github, kaggle].filter(Boolean),
  knowsAbout: site.seo.keywords,
  worksFor: {
    '@type': 'Organization',
    name: experience.roles[0]?.organization.split(',')[0]?.trim() ?? site.name,
  },
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<meta name="keywords" content={site.seo.keywords.join(', ')} />
<!-- Page stays indexable; its images are excluded from image search (deters scraping). -->
<meta name="robots" content="index, follow, noimageindex" />
<link rel="canonical" href={canonical} />
<link
  rel="preload"
  href="/fonts/inter-latin.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/dm-serif-display-latin-400.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
{
  preloadPortrait?.avif && (
    <link
      rel="preload"
      as="image"
      href={preloadPortrait.avif}
      type="image/avif"
    />
  )
}
{
  preloadPortrait?.webp && (
    <link
      rel="preload"
      as="image"
      href={preloadPortrait.webp}
      type="image/webp"
    />
  )
}
<meta name="generator" content={Astro.generator} />

<!-- Theme color per scheme -->
<meta
  name="theme-color"
  content={THEME_BG.light}
  media="(prefers-color-scheme: light)"
/>
<meta
  name="theme-color"
  content={THEME_BG.dark}
  media="(prefers-color-scheme: dark)"
/>

<!-- Icons & manifest -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- OpenGraph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={`${profile.name} — ${profile.title}`} />
<meta property="og:locale" content="en" />

<!-- Twitter -->
<meta name="twitter:card" content={site.seo.twitterCard} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${profile.name} — ${profile.title}`} />

<!-- JSON-LD Person — pure data blob; is:inline keeps it verbatim and silences astro(4000). -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
