---
import { site, navItems, navHref } from '@lib/content';
import Monogram from '@components/chrome/Monogram.astro';
import Icon from '@components/ui/Icon.astro';

interface Props {
  singlePageViews?: boolean;
}

const { singlePageViews = false } = Astro.props;

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = current === '/';

type ContentNavItem = Extract<(typeof navItems)[number], { external?: false }>;

function isContentPage(
  item: (typeof navItems)[number]
): item is ContentNavItem {
  return !('external' in item && item.external);
}

const internalNavItems = navItems.filter(isContentPage).map((item) => ({
  label: item.label,
  href: singlePageViews ? navHref(item) : item.path,
  viewAnchor: item.viewAnchor ?? item.id,
}));

const [firstName, ...rest] = site.name.split(' ');
const lastName = rest.join(' ');
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={site.name}>
      <span class="brand__wordmark" aria-hidden="true">
        {firstName}{' '}
        <span class="brand__accent">{lastName}</span>
      </span>
      <span class="brand__mark" aria-hidden="true">
        <Monogram size={36} />
      </span>
    </a>

    <nav class="nav" id="primary-nav" aria-label="Primary">
      <ul class="nav__list">
        {
          internalNavItems.map((item) => (
            <li>
              <a
                class="nav__link"
                href={item.href}
                data-view-anchor={singlePageViews ? item.viewAnchor : undefined}
                aria-current={
                  singlePageViews
                    ? item.viewAnchor === 'about' && isHome
                      ? 'page'
                      : undefined
                    : (item.href.replace(/\/$/, '') || '/') === current
                      ? 'page'
                      : undefined
                }
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <button
        type="button"
        class="save-btn"
        id="save-btn"
        aria-label="Save page as HTML"
        title="Save page as HTML"
      >
        <Icon name="save" size="sm" />
        <span class="save-btn__spinner" aria-hidden="true"></span>
      </button>
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
      >
        <Icon name="sun" size="sm" class="theme-toggle__sun" />
        <Icon name="moon" size="sm" class="theme-toggle__moon" />
      </button>

      <button
        type="button"
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <Icon name="menu" size="sm" class="nav-toggle__open" />
        <Icon name="close" size="sm" class="nav-toggle__close" />
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  @media (prefers-reduced-motion: no-preference) {
    .site-header {
      transition:
        background-color var(--dur) var(--ease),
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .site-header__inner {
      transition: min-height var(--dur) var(--ease);
    }
  }
  .site-header.is-scrolled {
    background: color-mix(in srgb, var(--bg) 95%, transparent);
    border-bottom-color: var(--border-strong);
    box-shadow: var(--shadow-raised);
  }
  .site-header.is-scrolled .site-header__inner {
    min-height: 52px;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--header-h);
    gap: var(--space-3);
  }
  .brand {
    font-family: var(--font-display);
    font-size: var(--fs-ml);
    color: var(--heading);
    letter-spacing: var(--tracking-flat);
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .brand__wordmark {
    display: inline;
  }
  .brand__mark {
    display: none;
  }
  .brand__accent {
    color: var(--accent-light);
  }
  @media (max-width: 480px) {
    .brand__wordmark {
      display: none;
    }
    .brand__mark {
      display: inline-flex;
    }
  }
  .nav__list {
    display: flex;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    position: relative;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--pill-padding-y) var(--pill-padding-x);
    border-radius: var(--radius-xs);
    transition:
      color var(--dur) var(--ease),
      background-color var(--dur) var(--ease);
  }
  .nav__link:hover,
  .nav__link[aria-current='page'] {
    color: var(--heading);
    background: var(--accent-soft);
  }
  .nav__link[aria-current='page']::after {
    content: none;
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .save-btn,
  .theme-toggle,
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--text);
    font-size: var(--fs-ml);
  }
  @media (min-width: 1025px) {
    .save-btn,
    .theme-toggle {
      display: inline-flex;
    }
  }
  .save-btn {
    position: relative;
  }
  .save-btn:hover,
  .theme-toggle:hover,
  .nav-toggle:hover {
    border-color: var(--accent);
  }
  .save-btn[aria-busy='true'] svg {
    opacity: 0;
  }
  .save-btn__spinner {
    display: none;
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent-light);
    border-radius: 50%;
    animation: spin var(--dur-spin) linear infinite;
  }
  .save-btn[aria-busy='true'] .save-btn__spinner {
    display: block;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  :global(html[data-theme='dark']) .theme-toggle__moon,
  :global(html:not([data-theme='dark'])) .theme-toggle__sun {
    display: none;
  }
  @media (max-width: 1024px) {
    .nav {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .nav.is-open {
      display: block;
      position: fixed;
      inset: var(--header-h) 0 0 0;
      background: var(--bg);
      padding: var(--space-6);
      overflow-y: auto;
      border-top: 1px solid var(--border);
    }
    .nav.is-open .nav__list {
      flex-direction: column;
      gap: var(--space-1);
    }
    .nav.is-open .nav__link {
      display: block;
      padding: var(--space-3) var(--space-4);
      font-size: var(--fs-ml);
    }
    .nav.is-open .nav__link[aria-current='page']::after {
      content: none;
    }
  }
  .nav-toggle__close {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__open {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__close {
    display: inline-block;
  }
</style>

<script>
  import { savePage } from '../../scripts/save-page';
  document.getElementById('save-btn')?.addEventListener('click', savePage);
</script>
