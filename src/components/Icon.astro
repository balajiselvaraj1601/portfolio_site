---
// Single source of truth for inline SVG icons. Decorative by default
// (aria-hidden); pass a `label` to expose an accessible name.
interface Props {
  name:
    | 'email'
    | 'linkedin'
    | 'kaggle'
    | 'location'
    | 'external'
    | 'download'
    | 'sun'
    | 'moon'
    | 'menu'
    | 'close'
    | 'arrow-up'
    | 'chevron';
  label?: string;
  size?: number;
  class?: string;
}
const { name, label, size = 18, class: cls } = Astro.props;

const paths: Record<Props['name'], string> = {
  email:
    '<path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/><path d="m3 7 9 6 9-6"/>',
  linkedin:
    '<rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 17v-7" fill="none"/>',
  kaggle:
    '<path d="M7 3v18M7 13l7-7M9.5 10.5 17 21M7 13h.01" fill="none"/>',
  location:
    '<path d="M12 21s-7-5.5-7-11a7 7 0 1 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5" fill="none"/>',
  external:
    '<path d="M14 4h6v6M20 4l-9 9M18 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5" fill="none"/>',
  download:
    '<path d="M12 3v12M7 11l5 4 5-4M5 21h14" fill="none"/>',
  sun: '<circle cx="12" cy="12" r="4" fill="none"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" fill="none"/>',
  moon: '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" fill="none"/>',
  menu: '<path d="M3 6h18M3 12h18M3 18h18" fill="none"/>',
  close: '<path d="M6 6l12 12M18 6 6 18" fill="none"/>',
  'arrow-up': '<path d="M12 19V5M5 12l7-7 7 7" fill="none"/>',
  chevron: '<path d="m6 9 6 6 6-6" fill="none"/>',
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={paths[name]}
/>
