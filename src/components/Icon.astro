---
import type { IconName } from '@lib/icons';

// Icons are PNGs (rasterized from src/lib/icon-paths.json via the logo pipeline).
// Decorative by default (aria-hidden); pass a `label` to expose an accessible name.
// Baked black for the light base theme; dark mode inverts via CSS below.
interface Props {
  name: IconName;
  label?: string;
  size?: number;
  class?: string;
}
const { name, label, size = 18, class: cls } = Astro.props;
---

<img
  src={`/assets/icons/ui/${name}.png`}
  width={size}
  height={size}
  class:list={['icon-img', cls]}
  loading="lazy"
  decoding="async"
  alt={label ?? ''}
  role={label ? 'img' : undefined}
  aria-hidden={label ? undefined : 'true'}
/>

<style is:global>
  .icon-img {
    display: inline-block;
    object-fit: contain;
    vertical-align: middle;
  }
  /* Icons are baked black for the light base theme; flip for dark. */
  :root[data-theme='dark'] .icon-img {
    filter: invert(1);
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .icon-img {
      filter: invert(1);
    }
  }
</style>
