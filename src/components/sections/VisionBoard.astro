---
import Section from '@components/ui/Section.astro';
import BoardHeader from '@components/chrome/BoardHeader.astro';
import HubCircle from '@components/cards/HubCircle.astro';
import ProgramBadgeCard from '@components/cards/ProgramBadgeCard.astro';
import OrgImpactCard from '@components/cards/OrgImpactCard.astro';
import Icon from '@components/ui/Icon.astro';
import { visionBoard } from '@lib/content';

const { header, hubs, programs, orgHeader, orgCards } = visionBoard;
---

<Section
  id="vision-board"
  title={header}
  hideTitle
  variant="default"
  class="vboard"
>
  <BoardHeader title={header} flank="in" />

  {/* Top flow: IDEA » VISION » 2×2 program cards, all in one row. */}
  <div class="vboard__flow reveal">
    {
      hubs.map((hub) => (
        <Fragment>
          <HubCircle
            center={hub.center}
            satellites={hub.satellites}
            label={hub.label}
            variant={hub.variant}
          />
          <span class="vboard__arrow" aria-hidden="true">
            <Icon name="chevron-right" size={24} />
            <Icon name="chevron-right" size={24} />
          </span>
        </Fragment>
      ))
    }

    {
      programs && programs.length > 0 && (
        <div class="vboard__programs">
          {programs.map((p) => (
            <ProgramBadgeCard
              title={p.title}
              label={p.label}
              variant={p.variant}
              badge={p.badge}
              lines={p.lines}
              entity={p.entity}
            />
          ))}
        </div>
      )
    }
  </div>

  {
    orgCards && orgCards.length > 0 && (
      <div class="vboard__org reveal">
        {orgHeader && (
          <BoardHeader title={orgHeader} flank="in" as="h3" size="sm" />
        )}
        <div class="vboard__org-grid">
          {orgCards.map((c) => (
            <OrgImpactCard mark={c.mark} title={c.title} lines={c.lines} />
          ))}
        </div>
      </div>
    )
  }
</Section>

<style>
  /* ── top flow row (hubs » programs) ──────────────────────────────────── */
  .vboard__flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5) var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-10);
  }
  .vboard__arrow {
    display: inline-flex;
    align-items: center;
    color: var(--accent-light);
    opacity: 0.7;
  }
  .vboard__arrow :global(svg) {
    margin-inline: -6px;
  }
  .vboard__programs {
    flex: 1 1 640px;
    min-width: min(640px, 100%);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  /* ── org section ─────────────────────────────────────────────────────── */
  .vboard__org {
    margin-top: var(--space-16);
  }
  .vboard__org-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-10);
  }

  /* ── responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .vboard__org-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    /* Hide the inline arrows once the flow stacks vertically. */
    .vboard__arrow {
      display: none;
    }
    .vboard__programs {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .vboard__org-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
