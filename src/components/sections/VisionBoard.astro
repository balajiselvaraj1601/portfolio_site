---
import Section from '@components/ui/Section.astro';
import BoardHeader from '@components/chrome/BoardHeader.astro';
import HubCircle from '@components/cards/HubCircle.astro';
import ProgramBadgeCard from '@components/cards/ProgramBadgeCard.astro';
import OrgImpactCard from '@components/cards/OrgImpactCard.astro';
import Icon from '@components/ui/Icon.astro';
import { visionBoard } from '@lib/content';

const { header, intro, hubs, programs, orgHeader, orgCards } = visionBoard;
---

<Section
  id="vision-board"
  title={header}
  hideTitle
  variant="full"
  class="vboard section--alt"
>
  <BoardHeader title={header} flank="in" />
  {intro && <p class="vboard__intro reveal">{intro}</p>}

  {/* Top flow: IDEA » VISION » 2×2 program cards, all in one row. */}
  <div class="vboard__flow reveal">
    {
      hubs.map((hub) => (
        <Fragment>
          <HubCircle
            center={hub.center}
            satellites={hub.satellites}
            label={hub.label}
            variant={hub.variant}
          />
          <span class="vboard__arrow" aria-hidden="true">
            <Icon name="chevron-right" size={24} />
            <Icon name="chevron-right" size={24} />
          </span>
        </Fragment>
      ))
    }

    {
      programs && programs.length > 0 && (
        <div class="vboard__programs">
          {programs.map((p) => (
            <ProgramBadgeCard
              title={p.title}
              label={p.label}
              variant={p.variant}
              badge={p.badge}
              lines={p.lines}
              entity={p.entity}
            />
          ))}
        </div>
      )
    }
  </div>

  {
    orgCards && orgCards.length > 0 && (
      <div class="vboard__org reveal">
        {orgHeader && (
          <BoardHeader title={orgHeader} flank="out" as="h3" size="sm" />
        )}
        <div class="vboard__org-grid">
          {orgCards.map((c) => (
            <OrgImpactCard mark={c.mark} title={c.title} lines={c.lines} />
          ))}
        </div>
      </div>
    )
  }
</Section>

<style>
  .vboard__intro {
    max-width: 580px;
    margin: var(--space-4) auto var(--space-2);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  /* ── top flow row (hubs » programs) ──────────────────────────────────── */
  .vboard__flow {
    display: grid;
    grid-template-columns: auto auto auto auto minmax(460px, 1fr);
    align-items: center;
    gap: var(--space-4) var(--space-5);
    margin-top: var(--space-10);
  }
  .vboard__arrow {
    display: inline-flex;
    align-items: center;
    color: var(--accent-light);
    opacity: 0.7;
  }
  .vboard__arrow :global(svg) {
    margin-inline: -6px;
  }
  .vboard__programs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(2, auto);
    gap: var(--space-5);
    min-width: 0;
  }

  /* ── org section ─────────────────────────────────────────────────────── */
  .vboard__org {
    margin-top: var(--space-16);
  }
  .vboard__org-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    grid-template-rows: repeat(4, auto);
    gap: var(--space-4);
    margin-top: var(--space-10);
  }

  /* ── responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 1279px) {
    .vboard__flow {
      grid-template-columns: auto auto auto auto;
      justify-content: center;
    }
    .vboard__programs {
      grid-column: 1 / -1;
      min-width: min(640px, 100%);
      margin-inline: auto;
    }
    .vboard__org-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (max-width: 899px) {
    .vboard__org-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 767px) {
    .vboard__flow {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .vboard__arrow {
      display: none;
    }
    .vboard__programs {
      grid-template-columns: 1fr;
      min-width: 100%;
    }
  }
  @media (max-width: 599px) {
    .vboard__org-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
