---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Icon from '@components/ui/Icon.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { profile, site } from '@lib/content';
import type { z } from 'zod';
import { contactTypeSchema } from '@schemas';

type ContactType = z.infer<typeof contactTypeSchema>;

const { contactPage } = profile;

const contactChannels = profile.contact;

const isExternal = (href: string) => href.startsWith('http');

// Type-safe map of contact types to action labels.
const actionLabelMap: Record<ContactType, string> = {
  email: site.ui.contact.actions.email,
  linkedin: site.ui.contact.actions.linkedin,
  calendly: site.ui.contact.actions.calendly,
  github: site.ui.contact.actions.github,
  kaggle: site.ui.contact.actions.kaggle,
  location: site.ui.contact.actions.location,
};

const actionLabel = (type: ContactType): string => actionLabelMap[type];
---

<Section
  id="contact"
  title=""
  hideTitle
  labelledBy="contact-heading"
  variant="alt"
>
  <div class="contact-grid reveal">
    <!-- Left: pitch + actions -->
    <div class="contact-left">
      <div class="section-header section-header--inline contact-header">
        <Eyebrow text={contactPage.eyebrow} />
        <SectionHeading
          title={contactPage.title}
          highlight={contactPage.titleHighlight}
          class="section__title"
          id="contact-heading"
        />
      </div>
      <p class="section__subtitle contact-subtitle">{profile.contactIntro}</p>

      {
        contactPage.bookingHref && (
          <div class="contact-actions">
            <a
              class="btn btn-secondary"
              href={contactPage.bookingHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="calendar" size={18} />
              {contactPage.bookCallLabel}
            </a>
          </div>
        )
      }

      <p class="response-time">
        <Icon name="clock" size="sm" />
        {contactPage.responseTime}
      </p>
    </div>

    <!-- Right: connect cards -->
    <div class="contact-right">
      <div class="connect-header">
        <span>{contactPage.connectHeading}</span>
        <span class="connect-rule" aria-hidden="true"></span>
      </div>

      <div class="connect-grid">
        {
          contactChannels.map((c) => {
            const external = c.href ? isExternal(c.href) : false;
            return c.href ? (
              <a
                class:list={['connect-card', 'card', 'card-accent']}
                href={c.href}
                {...(external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <CardMark
                  icon={c.icon}
                  iconFallback="link"
                  variant="accented"
                />
                <h3 class="card-title connect-name">{c.label}</h3>
                <p class="connect-val">{c.value}</p>
                <span class="connect-action">
                  {actionLabel(c.type)}
                  <Icon name="arrow-right" size="sm" />
                  {external && (
                    <span class="visually-hidden">
                      {site.ui.common.opensInNewWindow}
                    </span>
                  )}
                </span>
              </a>
            ) : (
              <div
                class:list={[
                  'connect-card',
                  'card',
                  'card-accent',
                  'connect-card--static',
                ]}
              >
                <CardMark
                  icon={c.icon}
                  iconFallback="link"
                  variant="accented"
                />
                <h3 class="card-title connect-name">{c.label}</h3>
                <p class="connect-val">{c.value}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</Section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--stack-xl);
    align-items: start;
  }

  /* ── Left column ──────────────────────────────────────────── */
  .contact-subtitle {
    max-width: 38ch;
    margin-top: calc(2 * var(--lh-body) * 1em);
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--section-cta-gap);
    margin-top: var(--text-gap-section);
    margin-bottom: var(--stack-md);
  }
  /* Booking CTA — purple outline; icon inherits button color. */
  .contact-actions .btn-secondary {
    border-color: var(--accent);
    color: var(--accent-ll);
  }
  .contact-actions .btn-secondary:hover {
    border-color: var(--accent-light);
    color: var(--heading);
  }
  .response-time {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-md);
    color: var(--text-muted);
    margin-top: calc(2 * var(--lh-body) * 1em);
    margin-bottom: var(--stack-md);
  }
  .response-time :global(svg) {
    color: var(--accent-light);
    flex-shrink: 0;
  }

  /* ── Right column ─────────────────────────────────────────── */
  .contact-right {
    overflow: visible;
  }
  .connect-header {
    display: flex;
    align-items: center;
    gap: var(--text-gap-block);
    margin-bottom: var(--text-gap-block);
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .connect-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border-strong), transparent);
  }
  .connect-grid {
    --connect-gap: var(--stack-sm);
    /* Same footprint as the old 2-col / 4-box cards */
    --connect-size: calc((100% - var(--connect-gap)) / 2);
    --connect-grid-width: calc(
      3 * var(--connect-size) + 2 * var(--connect-gap)
    );
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--connect-gap);
    /* 3 cards + 2 gaps → wider than .contact-right; protrude left.
       Right edge must match other sections' card right edge (= .container
       content right). .contact-right ends there, so pin to 100%. */
    width: var(--connect-grid-width);
    max-width: none;
    margin-left: calc(100% - var(--connect-grid-width));
    margin-bottom: var(--stack-sm);
  }
  /* Connect cards inherit global .card.card-accent shell (purple border + icon tile).
     Square at the 2-col size (matches the old 4-box footprint). */
  .connect-card {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
    padding: var(--card-padding);
    text-decoration: none;
    grid-column: span 2;
    aspect-ratio: 1 / 1;
    min-height: 0;
  }
  /* Top row right-aligned over bottom 3 so right borders share a column:
        [1] [2]
   [3] [4] [5]  */
  .connect-card:nth-child(1) {
    grid-column: 3 / span 2;
  }
  .connect-card:nth-child(2) {
    grid-column: 5 / span 2;
  }
  .connect-card--static:hover {
    transform: none;
    box-shadow: none;
    border-color: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 40%,
      var(--border)
    );
  }
  .connect-card :global(.icon-tile) {
    margin-bottom: var(--space-3);
  }
  /* Adopt the site-standard accent-blended glyph: brand marks inherit the card
     accent (blue) instead of neutral --brand-mark ink. */
  .connect-card :global(.icon--brand) {
    color: var(--accent-card, var(--accent));
  }
  .connect-val {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    margin: 0;
    max-width: none;
    min-width: 0;
    overflow-wrap: anywhere;
    flex: 1;
  }
  .connect-action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--accent-card, var(--accent-light));
  }
  .connect-action :global(svg) {
    transition: transform var(--dur) var(--ease);
  }
  .connect-card:hover .connect-action :global(svg) {
    transform: translateX(3px);
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--stack-xl);
    }
    .contact-subtitle {
      max-width: none;
    }
  }
  @media (max-width: 560px) {
    .connect-grid {
      grid-template-columns: 1fr;
      width: 100%;
      margin-left: 0;
    }
    .connect-card,
    .connect-card:nth-child(1),
    .connect-card:nth-child(2) {
      grid-column: auto;
    }
  }
</style>
