---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Icon from '@components/ui/Icon.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { profile } from '@lib/content';
import type { z } from 'zod';
import { contactTypeSchema } from '@schemas';

type ContactType = z.infer<typeof contactTypeSchema>;

const { contactPage } = profile;

// Every contact entry with a link (location has none → stays hidden).
const linked = profile.contact.filter((c) => c.href);

const isExternal = (href: string) => href.startsWith('http');

// Type-safe map of contact types to action labels.
const actionLabelMap: Record<ContactType, string> = {
  email: 'Send email',
  linkedin: 'View profile',
  github: 'View profile',
  kaggle: 'View profile',
  location: 'View location',
};

const actionLabel = (type: ContactType): string => actionLabelMap[type];
---

<Section
  id="contact"
  title=""
  hideTitle
  labelledBy="contact-heading"
  variant="alt"
>
  <div class="contact-grid reveal">
    <!-- Left: pitch + actions -->
    <div class="contact-left">
      <div class="section-header section-header--inline">
        <Eyebrow text={contactPage.eyebrow} />
        <SectionHeading
          title={contactPage.title}
          highlight={contactPage.titleHighlight}
          class="section__title"
          id="contact-heading"
        />
        <p class="section__subtitle contact-subtitle">{profile.contactIntro}</p>
      </div>

      {
        contactPage.bookingHref && (
          <div class="contact-actions">
            <a
              class="btn btn-secondary"
              href={contactPage.bookingHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="calendar" size={18} />
              {contactPage.bookCallLabel}
            </a>
          </div>
        )
      }

      <p class="response-time">
        <Icon name="clock" size={16} />
        {contactPage.responseTime}
      </p>
    </div>

    <!-- Right: connect cards -->
    <div class="contact-right">
      <div class="connect-header">
        <span>{contactPage.connectHeading}</span>
        <span class="connect-rule" aria-hidden="true"></span>
      </div>

      <div class="connect-grid">
        {
          linked.map((c) => {
            const external = c.href ? isExternal(c.href) : false;
            return (
              <a
                class:list={[
                  'connect-card',
                  'card',
                  'card-accent',
                  `connect-card--${c.type}`,
                ]}
                href={c.href!}
                {...(external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <CardMark
                  icon={c.icon}
                  iconFallback="link"
                  variant="accented"
                />
                <h3 class="connect-name">{c.label}</h3>
                <p class="connect-val">{c.value}</p>
                <span class="connect-action">
                  {actionLabel(c.type)}
                  <Icon name="arrow-right" size={16} />
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</Section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--stack-xl);
    align-items: start;
  }

  /* ── Left column ──────────────────────────────────────────── */
  .contact-subtitle {
    max-width: 38ch;
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--section-cta-gap);
    margin-top: var(--text-gap-section);
    margin-bottom: var(--stack-md);
  }
  /* Booking CTA — solid purple box, white label + icon (matches connect cards). */
  .contact-actions .btn-secondary {
    background: var(--accent);
    color: var(--text-inverse);
    border-color: var(--accent);
  }
  .contact-actions .btn-secondary:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }
  .response-time {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-md);
    color: var(--text-muted);
    margin-bottom: var(--stack-md);
  }
  .response-time :global(svg) {
    color: var(--accent-light);
    flex-shrink: 0;
  }

  /* ── Right column ─────────────────────────────────────────── */
  .connect-header {
    display: flex;
    align-items: center;
    gap: var(--text-gap-block);
    margin-bottom: var(--text-gap-block);
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .connect-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border-strong), transparent);
  }
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 1fr;
    gap: var(--stack-sm);
    margin-bottom: var(--stack-sm);
  }
  /* Single accent per view: every connect card is a solid brand-purple box with
     white foreground (text + icons). Scoped rules here outrank the global .card /
     .icon-tile--accented defaults via Astro's component cid. #fff inside color-mix
     matches the codebase idiom; var(--text-inverse) is #ffffff in both themes. */
  .connect-card {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
    padding: var(--card-padding);
    text-decoration: none;
    height: 100%;
    background: var(--accent);
    border: 1px solid color-mix(in srgb, #fff 22%, transparent);
    color: var(--text-inverse);
  }
  .connect-card:hover {
    border-color: color-mix(in srgb, #fff 40%, transparent);
  }
  .connect-card :global(.icon-tile) {
    margin-bottom: var(--space-3);
    color: var(--text-inverse);
    /* Brand-mono glyphs (gmail/linkedin/github/kaggle) read --brand-mark, not the
       tile color — whiten it so they stay legible on purple in both themes. */
    --brand-mark: var(--text-inverse);
    background: color-mix(in srgb, #fff 16%, transparent);
    border-color: color-mix(in srgb, #fff 30%, transparent);
  }
  .connect-name {
    font-size: var(--fs-card-title);
    font-weight: var(--fw-semibold);
    color: var(--text-inverse);
  }
  .connect-val {
    font-size: var(--fs-sm);
    color: color-mix(in srgb, var(--text-inverse) 82%, transparent);
    margin: 0;
    max-width: none;
    flex: 1;
  }
  .connect-action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid color-mix(in srgb, #fff 25%, transparent);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-inverse);
  }
  .connect-action :global(svg) {
    transition: transform var(--dur) var(--ease);
  }
  .connect-card:hover .connect-action :global(svg) {
    transform: translateX(3px);
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--stack-xl);
    }
    .contact-subtitle {
      max-width: none;
    }
  }
  @media (max-width: 560px) {
    .connect-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
