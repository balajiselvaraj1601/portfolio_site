---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import { resolveIcon, type IconName } from '@lib/icons';
import { profile } from '@lib/content';

const { contactPage, contactQuote } = profile;

// Social/connect cards: every contact entry with a link (location has none).
const connectCards = profile.contact.filter((c) => c.href);
const emailHref =
  profile.contact.find((c) => c.type === 'email')?.href ?? undefined;

const isExternal = (href: string) => href.startsWith('http');
const actionLabel = (type: string) =>
  type === 'email' ? 'Send email' : 'View profile';

const titleParts = contactPage.titleHighlight
  ? {
      before: contactPage.title.slice(
        0,
        contactPage.title.indexOf(contactPage.titleHighlight)
      ),
      highlight: contactPage.titleHighlight,
      after: contactPage.title.slice(
        contactPage.title.indexOf(contactPage.titleHighlight) +
          contactPage.titleHighlight.length
      ),
    }
  : null;
---

<Section id="contact" title="" hideTitle eyebrow={contactPage.eyebrow} variant="alt">
  <div class="contact-grid reveal">
    <!-- Left: pitch + actions -->
    <div class="contact-left">
      <h2 class="contact__title">
        {
          titleParts ? (
            <>
              {titleParts.before}
              <span class="accent">{titleParts.highlight}</span>
              {titleParts.after}
            </>
          ) : (
            contactPage.title
          )
        }
      </h2>
      <p class="contact-subtitle">{profile.contactIntro}</p>

      <div class="contact-actions">
        {
          emailHref && (
            <a class="btn btn-primary" href={emailHref}>
              <Icon name="email" size={18} />
              {contactPage.emailButtonLabel}
            </a>
          )
        }
        {
          contactPage.bookingHref && (
            <a
              class="btn btn-secondary"
              href={contactPage.bookingHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="calendar" size={18} />
              {contactPage.bookCallLabel}
            </a>
          )
        }
      </div>

      <p class="response-time">
        <Icon name="clock" size={16} />
        {contactPage.responseTime}
      </p>

      {
        contactQuote && (
          <blockquote class="contact-quote">
            <p>{contactQuote.text}</p>
            <cite>— {contactQuote.author}</cite>
          </blockquote>
        )
      }
    </div>

    <!-- Right: connect cards + CTA banner -->
    <div class="contact-right">
      <div class="connect-header">
        <span>{contactPage.connectHeading}</span>
        <span class="connect-rule" aria-hidden="true"></span>
      </div>

      <div class="connect-grid">
        {
          connectCards.map((c) => {
            const external = c.href ? isExternal(c.href) : false;
            return (
              <a
                class="connect-card card"
                href={c.href!}
                {...(external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <span class="connect-badge" aria-hidden="true">
                  <Icon name={resolveIcon(c.icon, 'link') as IconName} size={22} />
                </span>
                <h3 class="connect-name">{c.label}</h3>
                <p class="connect-val">{c.value}</p>
                <span class="connect-action">
                  {actionLabel(c.type)}
                  <Icon name="arrow-right" size={16} />
                </span>
              </a>
            );
          })
        }
      </div>

      {
        emailHref && (
          <a class="connect-banner card" href={emailHref}>
            <span class="connect-banner__icon" aria-hidden="true">
              <Icon name="handshake" size={26} />
            </span>
            <span class="connect-banner__text">
              {contactPage.ctaText}{' '}
              <strong>{contactPage.ctaLinkText}</strong>
            </span>
            <span class="connect-banner__arrow" aria-hidden="true">
              <Icon name="arrow-right" size={20} />
            </span>
          </a>
        )
      }
    </div>
  </div>
</Section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--stack-xl);
    align-items: start;
  }

  /* ── Left column ──────────────────────────────────────────── */
  .contact__title {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 400;
    line-height: 1.1;
    color: var(--heading);
    margin-bottom: var(--stack-sm);
  }
  .contact-subtitle {
    color: var(--text-muted);
    margin-bottom: var(--stack-lg);
    font-size: 0.95rem;
    max-width: 38ch;
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: var(--stack-md);
  }
  .response-time {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--stack-lg);
  }
  .response-time :global(svg) {
    color: var(--accent-light);
    flex-shrink: 0;
  }
  .contact-quote {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    padding: var(--card-padding) var(--card-padding-lg);
    margin: 0;
    position: relative;
  }
  .contact-quote::before {
    content: '\201C';
    position: absolute;
    top: 0.4rem;
    left: 0.9rem;
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--accent-light);
    opacity: 0.5;
  }
  .contact-quote p {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0 0 0.75rem;
    padding-left: 1.5rem;
    max-width: none;
  }
  .contact-quote cite {
    display: block;
    padding-left: 1.5rem;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--accent-ll);
  }

  /* ── Right column ─────────────────────────────────────────── */
  .connect-header {
    display: flex;
    align-items: center;
    gap: var(--stack-sm);
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .connect-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border-strong), transparent);
  }
  .connect-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--stack-sm);
    margin-bottom: var(--stack-sm);
  }
  .connect-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--card-padding);
    text-decoration: none;
  }
  .connect-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .connect-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--heading);
  }
  .connect-val {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    max-width: none;
    flex: 1;
  }
  .connect-action {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-light);
  }
  .connect-action :global(svg) {
    transition: transform var(--dur) var(--ease);
  }
  .connect-card:hover .connect-action :global(svg) {
    transform: translateX(3px);
  }

  .connect-banner {
    display: flex;
    align-items: center;
    gap: var(--stack-sm);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
  }
  .connect-banner__icon {
    flex-shrink: 0;
    color: var(--accent-light);
  }
  .connect-banner__text {
    flex: 1;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .connect-banner__text strong {
    display: block;
    font-weight: 600;
    color: var(--accent-light);
  }
  .connect-banner__arrow {
    flex-shrink: 0;
    color: var(--accent-light);
    transition: transform var(--dur) var(--ease);
  }
  .connect-banner:hover .connect-banner__arrow {
    transform: translateX(4px);
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .contact-subtitle {
      max-width: none;
    }
  }
  @media (max-width: 560px) {
    .connect-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
