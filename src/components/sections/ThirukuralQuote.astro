---
import { profile } from '@lib/content';

const quote = profile.heroQuote;
---

{
  quote && (
    <section id="thirukural" class="kural reveal" aria-label="Thirukural">
      <div class="container">
        <figure class="kural__band">
          <div class="kural__copy">
            <blockquote class="kural__text">
              {quote.tamil && <p class="kural__tamil">{quote.tamil}</p>}
              <div class="kural__divider" aria-hidden="true" />
              <p class="kural__translation">{quote.translation}</p>
            </blockquote>
            <figcaption class="kural__author">— {quote.author}</figcaption>
          </div>

          {quote.image && (
            <div class="kural__img-wrap">
              {quote.imageWebp || quote.imageAvif ? (
                <picture>
                  {quote.imageAvif && (
                    <source srcset={quote.imageAvif} type="image/avif" />
                  )}
                  {quote.imageWebp && (
                    <source srcset={quote.imageWebp} type="image/webp" />
                  )}
                  <img
                    class="kural__img"
                    src={quote.image}
                    alt={quote.imageAlt}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              ) : (
                <img
                  class="kural__img"
                  src={quote.image}
                  alt={quote.imageAlt}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          )}
        </figure>
      </div>
    </section>
  )
}

<style>
  .kural {
    --kural-img-w: clamp(72px, 12vw, 120px);
    --kural-img-h: calc(var(--kural-img-w) * 480 / 448);
    --kural-text-gap: var(--text-gap-inline);

    padding-block: 0;
  }

  /* Open layout — no card/box; sits on page background like dummy.png */
  .kural__band {
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--hero-band-gap);
    width: fit-content;
    max-width: min(42rem, 100%);
  }
  @media (min-width: 768px) {
    .kural__band {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(1rem, 2.5vw, 1.75rem);
    }

    /* Distribute Tamil, divider, translation, and author across image height. */
    .kural__copy {
      min-height: var(--kural-img-h);
      justify-content: space-between;
      align-items: center;
      gap: 0;
    }

    .kural__text {
      display: contents;
    }

    .kural__img-wrap {
      width: var(--kural-img-w);
      height: var(--kural-img-h);
    }

    .kural__img {
      width: 100%;
      height: 100%;
    }
  }

  .kural__copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--kural-text-gap);
    flex: none;
    text-align: center;
  }

  .kural__text {
    margin: 0;
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--kural-text-gap);
    text-align: center;
  }

  .kural__divider {
    position: relative;
    width: min(8rem, 55%);
    height: var(--space-1);
    margin: 0 auto;
    background:
      linear-gradient(to right, var(--accent-light), var(--accent-light)) left
        center / calc(50% - 0.5rem) 1px no-repeat,
      linear-gradient(to right, var(--accent-light), var(--accent-light)) right
        center / calc(50% - 0.5rem) 1px no-repeat;
    opacity: 0.45;
  }
  .kural__divider::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 4px;
    height: 4px;
    border: 1px solid var(--accent-light);
    transform: translate(-50%, -50%) rotate(45deg);
    box-sizing: border-box;
    opacity: 0.45;
  }

  /* DM Serif Display is Latin-only and cannot render Tamil glyphs — Tamil uses sans. */
  .kural__tamil {
    font-family: var(--font-sans);
    font-size: var(--fs-kural);
    font-weight: var(--fw-medium);
    line-height: var(--lh-normal);
    color: var(--heading);
    margin: 0;
  }
  .kural__translation {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-kural-trans);
    line-height: var(--lh-normal);
    color: var(--text);
    margin: 0;
    max-width: none;
  }
  .kural__author {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-snug);
    color: var(--accent-light);
    margin: 0;
  }

  .kural__img-wrap {
    position: relative;
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .kural__img-wrap::before {
    content: '';
    position: absolute;
    inset: -12% -8%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent-light) 14%, transparent) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }
  .kural__img {
    position: relative;
    z-index: 1;
    width: var(--kural-img-w);
    height: auto;
    object-fit: contain;
    opacity: 0.92;
    filter: drop-shadow(0 4px 16px var(--shadow-drop-color));
  }
  @media (max-width: 767px) {
    .kural__img-wrap {
      order: -1;
    }
    .kural__img {
      width: clamp(64px, 22vw, 96px);
      height: auto;
    }
  }
</style>
