---
import CardMark from '@components/ui/CardMark.astro';
import { logoSrc } from '@lib/content';
import type { EducationRecord } from '@schemas';

type Props = {
  record: EducationRecord;
};

const { record } = Astro.props;
const logo = logoSrc(record.entity);
const degreeShort = record.degree.split(' ')[0];
const fieldLabel = record.field ?? record.degree.replace(/^[^\s]+\s*/, '');
---

<div class="edu-hero">
  <div class="edu-hero__top">
    <div class="edu-hero__mark">
      <CardMark
        logoUrl={logo}
        slug={record.entity}
        altText={record.institution + ' logo'}
        logoSize="lg"
        icon="graduation"
        iconFallback="graduation"
        variant="recog"
        class={logo ? 'edu-hero__logo' : 'edu-hero__icon icon-tile--accented'}
      />
    </div>
    <p class="edu-degree-short">{degreeShort}</p>
  </div>
  <div class="edu-hero__tail">
    <h3 class="card-title edu-field">{fieldLabel}</h3>
    <div class="edu-rule" aria-hidden="true"></div>
  </div>
</div>

<style>
  .edu-hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    gap: 0;
  }
  .edu-hero__top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--stack-md);
    width: 100%;
  }
  .edu-hero__tail {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
    width: 100%;
  }

  .edu-degree-short {
    font-family: var(--font-mono);
    font-size: var(--fs-edu-lg);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-none);
    color: var(--accent-card, var(--accent-gold));
    margin: 0;
  }

  .edu-rule {
    width: min(100%, 12rem);
    height: 2px;
    margin-top: var(--space-2);
    background: linear-gradient(
      to right,
      transparent,
      var(--accent-card, var(--accent-gold)),
      transparent
    );
    opacity: 0.85;
  }

  @media (min-width: 768px) /* --bp-md */ {
    .edu-hero {
      justify-content: space-between;
      padding-top: var(--space-2);
    }
  }

  @media (max-width: 767px) /* --bp-md - 1px */ {
    .edu-hero {
      height: auto;
      padding-top: 0;
      gap: var(--text-gap-inline);
    }
  }
</style>
