---
import SpeakingCard from '@components/cards/SpeakingCard.astro';
import Section from '@components/ui/Section.astro';
import { speakers, site } from '@lib/content';
---

<Section
  id="speakers"
  title={site.sections.speakers.title}
  variant="default"
>
  <div class="speaking-grid reveal">
    {speakers.items.map((item) => <SpeakingCard item={item} />)}
  </div>
</Section>

<style>
  .speaking-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 420px), 1fr));
    gap: 1.5rem;
  }
</style>
