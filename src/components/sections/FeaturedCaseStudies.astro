---
import Section from '@components/ui/Section.astro';
import ProjectCaseStudyCard from '@components/cards/ProjectCaseStudyCard.astro';
import { projects, site } from '@lib/content';

interface Props {
  showMoreHref?: string;
  showMoreLabel?: string;
}

const {
  showMoreHref,
  showMoreLabel = 'View all projects →',
} = Astro.props;

const featured = projects.projects.filter((p) => p.featured);
const title = site.sections['featured-case-studies'].title;
---

<Section
  id="featured-case-studies"
  title={title}
  eyebrow="Flagship Work"
  variant="alt"
>
  <div class="case-study-stack reveal">
    {
      featured.map((p) => (
        <ProjectCaseStudyCard
          name={p.name}
          role={p.role}
          org={p.org}
          entity={p.entity}
          period={p.period}
          domain={p.domain}
          summary={p.summary}
          tags={p.tags}
          problem={p.problem}
          solution={p.solution}
          architecture={p.architecture}
          businessImpact={p.businessImpact}
          outcome={p.outcome}
          lessons={p.lessons}
        />
      ))
    }
  </div>
  {
    showMoreHref && (
      <p class="case-study-more reveal">
        <a class="btn btn-secondary" href={showMoreHref}>
          {showMoreLabel}
        </a>
      </p>
    )
  }
</Section>

<style>
  .case-study-stack {
    display: flex;
    flex-direction: column;
    gap: var(--stack-lg);
  }
  .case-study-more {
    margin-top: var(--section-cta-gap);
    max-width: none;
  }
</style>
