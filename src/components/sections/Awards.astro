---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import RecogCardShell from '@components/ui/RecogCardShell.astro';
import RecogControls from '@components/ui/RecogControls.astro';
import RecogTile from '@components/ui/RecogTile.astro';
import { awards, site } from '@lib/content';

import { awardLevelSchema } from '@schemas';

/**
 * Nominator levels in seniority order — drives summary tiles + filters.
 * Derived from the awardLevelSchema enum (the SSOT) so the list never drifts
 * from the validated content; National Level follows Senior Director, then
 * Director and Associate Director.
 */
const LEVELS = awardLevelSchema.options;

const slug = (level: string) => level.toLowerCase().replace(/[^a-z]+/g, '-');

// Counts are DERIVED from the items — single source of truth, never hardcoded.
const counts = awards.items.reduce<Record<string, number>>((acc, a) => {
  acc[a.level] = (acc[a.level] ?? 0) + 1;
  return acc;
}, {});

// Presentation order = impact: level seniority first (EVP → … → Associate
// Director), then within-level impact rank (1 = highest). Reuses LEVELS as the
// single source of seniority order. Fixed server-side — no client re-sorting.
const levelOrder = Object.fromEntries(LEVELS.map((level, i) => [level, i]));
const items = [...awards.items].sort(
  (a, b) => levelOrder[a.level] - levelOrder[b.level] || a.rank - b.rank
);
const total = items.length;
---

<Section
  id="awards"
  eyebrow={site.sections.awards.eyebrow}
  title={site.sections.awards.title}
  variant="default"
  class="section--compact-bottom"
>
  <!-- Summary stat tiles — counts by nominator level -->
  <div class="recog-summary reveal">
    {
      LEVELS.map((level) => (
        <RecogTile
          class={`level-${slug(level)}`}
          icon="trophy"
          markSlug="logo_trophy_badge"
          count={counts[level] ?? 0}
          label={level}
        />
      ))
    }
  </div>

  <RecogControls
    countLabel="All Awards"
    total={total}
    countDataAttr="data-awards-count"
    searchDataAttr="data-awards-search"
    searchPlaceholder="Search awards…"
    searchAriaLabel="Search awards by title, nominator, or reason"
    filterGroupLabel="Filter by nominator level"
  >
    <button
      type="button"
      class="recog-chip is-active"
      data-filter="all"
      aria-pressed="true"
    >
      All
    </button>
    {
      LEVELS.map((level) => (
        <button
          type="button"
          class:list={['recog-chip', `level-${slug(level)}`]}
          data-filter={level}
          aria-pressed="false"
        >
          {level}
        </button>
      ))
    }
  </RecogControls>

  <!-- Award card grid -->
  <ul class="theme-grid awards-grid reveal" data-awards-grid role="list">
    {
      items.map((a) => (
        <li
          data-level={a.level}
          data-title={a.title}
          data-nominator={a.nominator}
          data-reason={a.reason}
        >
          <RecogCardShell class:list={[`level-${slug(a.level)}`]}>
            <Fragment slot="headTop">
              <CardMark
                mark={{ kind: 'logo', asset: 'logo_trophy_badge' }}
                icon="trophy"
                context="theme-card"
                emblemInCircle
              />
              <p class="awards-card__kicker">{a.level}</p>
            </Fragment>
            <h3 slot="title" class="recog-title theme-card__title">
              {a.title}
            </h3>

            <dl class="awards-card__meta">
              <div class="awards-card__meta-pair">
                <dt class="recog-label">Nominator</dt>
                <dd class="recog-value">
                  {a.nominator} · {a.designation}
                </dd>
              </div>
              <div class="awards-card__meta-pair">
                <dt class="recog-label">Reason</dt>
                <dd class="recog-value">{a.reason}</dd>
              </div>
              {a.date && (
                <div class="awards-card__meta-pair">
                  <dt class="recog-label">Date</dt>
                  <dd class="recog-value">{a.date}</dd>
                </div>
              )}
            </dl>
            <div class="recog-card-divider" aria-hidden="true" />
            <p
              class="theme-card__desc recog-clamp awards-card__message"
              style="--clamp: 6"
            >
              {a.message}
            </p>
          </RecogCardShell>
        </li>
      ))
    }
  </ul>

  <p class="recog-empty" data-awards-empty hidden>
    No awards match your search.
  </p>
</Section>

<style>
  /* Per-level accents — six distinct hues. Theme tuning lives once in
     global.css (--lvl-* tokens, AA ≥3:1 on --bg-elev in both themes); these
     classes just map an award level onto its token so accents never desync. */
  .level-evp {
    --lvl: var(--lvl-evp);
  }
  .level-cio {
    --lvl: var(--lvl-cio);
  }
  .level-senior-director {
    --lvl: var(--lvl-senior-director);
  }
  .level-director {
    --lvl: var(--lvl-director);
  }
  .level-associate-director {
    --lvl: var(--lvl-associate-director);
  }
  .level-national-level {
    --lvl: var(--lvl-national);
  }

  /* Multi-color per view: cards, stat tiles (RecogTile → .theme-card.card), and
     active filter chips read --accent-card; feed each item's per-level --lvl so
     every award level shows its own hue, falling back to the Recognition accent
     (gold) when an element has no level class. Scoped to #awards so the rule
     doesn't bleed into About/Vision theme-cards. */
  :global(
    #awards
      :is(.recog-card, .recog-summary .theme-card.card, .recog-chip.is-active)
  ) {
    --accent-card: var(--lvl, var(--view-accent-recognition));
    --mark-fg: var(--accent-card);
  }

  .awards-grid {
    --theme-cols: 3;
    grid-auto-rows: auto;
  }

  .awards-grid > li {
    display: grid;
    grid-row: span 6;
    grid-template-rows: subgrid;
  }

  :global(#awards .awards-grid > li > .recog-card) {
    display: grid;
    grid-row: span 6;
    grid-template-rows: subgrid;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .awards-card__top {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-pair);
  }

  :global(.awards-card__top .theme-card__icon) {
    margin-bottom: 0;
  }

  .awards-card__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }

  .awards-card__meta-pair {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-pair);
  }

  .awards-card__meta dd {
    margin: 0;
  }

  @media (max-width: 980px) {
    .awards-grid {
      --theme-cols: 2;
    }
  }

  @media (max-width: 560px) {
    .awards-grid {
      --theme-cols: 1;
      grid-auto-rows: auto;
    }
  }

  .awards-grid :global(li) {
    min-width: 0;
  }

  .awards-grid :global(.recog-card-divider) {
    margin-block: var(--text-gap-inline);
  }

  :global(#awards .recog-card .recog-card-divider) {
    background: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 40%,
      var(--border)
    );
  }

  .awards-card__kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
    margin: 0;
    max-width: none;
  }

  :global(#awards .awards-grid > li.hidden) {
    display: none;
  }
</style>
