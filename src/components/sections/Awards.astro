---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import RecogCardShell from '@components/ui/RecogCardShell.astro';
import { awards, site } from '@lib/content';
import { awardLevelSchema } from '@schemas';

/**
 * Nominator levels in seniority order — drives summary tiles + filters.
 * Derived from the awardLevelSchema enum (the SSOT) so the list never drifts
 * from the validated content; the enum is declared EVP → National Level.
 */
const LEVELS = awardLevelSchema.options;

const slug = (level: string) => level.toLowerCase().replace(/[^a-z]+/g, '-');

// Counts are DERIVED from the items — single source of truth, never hardcoded.
const counts = awards.items.reduce<Record<string, number>>((acc, a) => {
  acc[a.level] = (acc[a.level] ?? 0) + 1;
  return acc;
}, {});

// Presentation order = impact: level seniority first (EVP → … → Associate
// Director), then within-level impact rank (1 = highest). Reuses LEVELS as the
// single source of seniority order. Fixed server-side — no client re-sorting.
const levelOrder = Object.fromEntries(LEVELS.map((level, i) => [level, i]));
const items = [...awards.items].sort(
  (a, b) => levelOrder[a.level] - levelOrder[b.level] || a.rank - b.rank
);
const total = items.length;
---

<Section id="awards" title={site.sections.awards.title} variant="default">
  <!-- Summary stat tiles — counts by nominator level -->
  <div class="recog-summary reveal">
    {
      LEVELS.map((level) => (
        <div class:list={['recog-tile', `level-${slug(level)}`]}>
          <div class="recog-tile__icon" aria-hidden="true">
            <Icon name="trophy" size={22} />
          </div>
          <div class="recog-tile__count">{counts[level] ?? 0}</div>
          <div class="recog-tile__label">{level}</div>
        </div>
      ))
    }
  </div>

  <!-- Controls: live count + search + sort + level filters -->
  <div class="recog-controls reveal">
    <h3 class="recog-controls__count">
      All Awards (<span data-awards-count>{total}</span>)
    </h3>
    <div class="recog-tools">
      <input
        type="search"
        class="recog-search"
        data-awards-search
        placeholder="Search awards…"
        aria-label="Search awards by title, nominator, or reason"
      />
    </div>
    <div
      class="recog-filters"
      role="group"
      aria-label="Filter by nominator level"
    >
      <button
        type="button"
        class="recog-chip is-active"
        data-filter="all"
        aria-pressed="true"
      >
        All
      </button>
      {
        LEVELS.map((level) => (
          <button
            type="button"
            class:list={['recog-chip', `level-${slug(level)}`]}
            data-filter={level}
            aria-pressed="false"
          >
            {level}
          </button>
        ))
      }
    </div>
  </div>

  <!-- Award card grid -->
  <div class="recog-grid reveal" data-awards-grid>
    {
      items.map((a) => (
        <RecogCardShell
          class:list={[`level-${slug(a.level)}`]}
          data-level={a.level}
          data-title={a.title}
          data-nominator={a.nominator}
          data-reason={a.reason}
        >
          <Fragment slot="headTop">
            <div class="recog-icon" aria-hidden="true">
              <Icon name="trophy" size={22} />
            </div>
            <span class="recog-badge">{a.level}</span>
          </Fragment>
          <h4 slot="title" class="recog-title">
            {a.title}
          </h4>

          <dl class="recog-card-fields">
            <div class="recog-card-field">
              <dt class="recog-label">Nominator</dt>
              <dd class="recog-value">
                {a.nominator} · {a.designation}
              </dd>
            </div>
            <div class="recog-card-field">
              <dt class="recog-label">Award Reason</dt>
              <dd class="recog-value">{a.reason}</dd>
            </div>
            {a.date && (
              <div class="recog-card-field">
                <dt class="recog-label">Date</dt>
                <dd class="recog-value">{a.date}</dd>
              </div>
            )}
          </dl>

          <Fragment slot="footer">
            <div class="recog-card-divider" />
            <div class="recog-card-message">
              <span class="field-label recog-label">Award Message</span>
              <p class="recog-body recog-clamp" style="--clamp: 6">
                {a.message}
              </p>
            </div>
          </Fragment>
        </RecogCardShell>
      ))
    }
  </div>

  <p class="recog-empty" data-awards-empty hidden>
    No awards match your search.
  </p>
</Section>

<style>
  /* Per-level accents — six distinct hues. Theme tuning lives once in
     global.css (--lvl-* tokens, AA ≥3:1 on --bg-elev in both themes); these
     classes just map an award level onto its token so accents never desync. */
  .level-evp {
    --lvl: var(--lvl-evp);
  }
  .level-cio {
    --lvl: var(--lvl-cio);
  }
  .level-senior-director {
    --lvl: var(--lvl-senior-director);
  }
  .level-director {
    --lvl: var(--lvl-director);
  }
  .level-associate-director {
    --lvl: var(--lvl-associate-director);
  }
  .level-national-level {
    --lvl: var(--lvl-national);
  }

  /* Shared accent hook — the shared .recog-* layer reads --accent-card; feed it
     this component's per-level --lvl so cards/tiles auto-color by award level. */
  .recog-tile,
  .recog-card {
    --accent-card: var(--lvl);
  }
</style>

<script>
  const root = document.getElementById('awards');
  const grid = root?.querySelector('[data-awards-grid]');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll('.recog-card'));
    const searchEl = root?.querySelector<HTMLInputElement>(
      '[data-awards-search]'
    );
    const countEl = root?.querySelector('[data-awards-count]');
    const emptyEl = root?.querySelector('[data-awards-empty]');
    const chips = Array.from(root?.querySelectorAll('.recog-chip') ?? []);

    let activeFilter = 'all';
    let query = '';

    function apply() {
      let visible = 0;
      for (const card of cards) {
        const level = card.getAttribute('data-level') || '';
        const haystack = [
          card.getAttribute('data-title'),
          card.getAttribute('data-nominator'),
          card.getAttribute('data-reason'),
        ]
          .join(' ')
          .toLowerCase();
        const show =
          (activeFilter === 'all' || level === activeFilter) &&
          (query === '' || haystack.includes(query));
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      }
      if (countEl) countEl.textContent = String(visible);
      if (emptyEl) emptyEl.toggleAttribute('hidden', visible !== 0);
    }

    searchEl?.addEventListener('input', () => {
      query = (searchEl.value || '').trim().toLowerCase();
      apply();
    });
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => {
          c.classList.remove('is-active');
          c.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('is-active');
        chip.setAttribute('aria-pressed', 'true');
        activeFilter = chip.getAttribute('data-filter') || 'all';
        apply();
      });
    });

    apply();
  }
</script>
