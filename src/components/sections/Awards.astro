---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import RecogControls from '@components/ui/RecogControls.astro';
import RecogTile from '@components/ui/RecogTile.astro';
import { awards, site } from '@lib/content';

import { awardLevelSchema } from '@schemas';

/**
 * Nominator levels in seniority order — drives summary tiles + filters.
 * Derived from the awardLevelSchema enum (the SSOT) so the list never drifts
 * from the validated content; the enum is declared EVP → National Level.
 */
const LEVELS = awardLevelSchema.options;

const slug = (level: string) => level.toLowerCase().replace(/[^a-z]+/g, '-');

// Counts are DERIVED from the items — single source of truth, never hardcoded.
const counts = awards.items.reduce<Record<string, number>>((acc, a) => {
  acc[a.level] = (acc[a.level] ?? 0) + 1;
  return acc;
}, {});

// Presentation order = impact: level seniority first (EVP → … → Associate
// Director), then within-level impact rank (1 = highest). Reuses LEVELS as the
// single source of seniority order. Fixed server-side — no client re-sorting.
const levelOrder = Object.fromEntries(LEVELS.map((level, i) => [level, i]));
const items = [...awards.items].sort(
  (a, b) => levelOrder[a.level] - levelOrder[b.level] || a.rank - b.rank
);
const total = items.length;
---

<Section
  id="awards"
  title={site.sections.awards.title}
  variant="default"
  class="section--compact-bottom"
>
  <!-- Summary stat tiles — counts by nominator level -->
  <ul class="theme-grid awards-summary reveal" role="list">
    {
      LEVELS.map((level) => (
        <li>
          <RecogTile
            class={`level-${slug(level)}`}
            icon="trophy"
            markSlug="logo_trophy_badge"
            count={counts[level] ?? 0}
            label={level}
          />
        </li>
      ))
    }
  </ul>

  <RecogControls
    countLabel="All Awards"
    total={total}
    countDataAttr="data-awards-count"
    searchDataAttr="data-awards-search"
    searchPlaceholder="Search awards…"
    searchAriaLabel="Search awards by title, nominator, or reason"
    filterGroupLabel="Filter by nominator level"
  >
    <button
      type="button"
      class="recog-chip is-active"
      data-filter="all"
      aria-pressed="true"
    >
      All
    </button>
    {
      LEVELS.map((level) => (
        <button
          type="button"
          class:list={['recog-chip', `level-${slug(level)}`]}
          data-filter={level}
          aria-pressed="false"
        >
          {level}
        </button>
      ))
    }
  </RecogControls>

  <!-- Award card grid -->
  <ul class="theme-grid awards-grid reveal" data-awards-grid role="list">
    {
      items.map((a) => (
        <li>
          <article
            class:list={['theme-card', 'card', `level-${slug(a.level)}`]}
            data-level={a.level}
            data-title={a.title}
            data-nominator={a.nominator}
            data-reason={a.reason}
          >
            <CardMark
              mark={{ kind: 'logo', asset: 'logo_trophy_badge' }}
              icon="trophy"
              context="theme-card"
              emblemInCircle
            />
            <p class="awards-card__kicker">{a.level}</p>
            <h3 class="theme-card__title">{a.title}</h3>
            <div class="recog-card-divider" aria-hidden="true" />
            <p class="theme-card__desc">
              {a.nominator} · {a.designation}
            </p>
            <p class="theme-card__desc">{a.reason}</p>
            {a.date && <p class="theme-card__desc">{a.date}</p>}
            <div class="recog-card-divider" aria-hidden="true" />
            <p
              class="theme-card__desc recog-clamp awards-card__message"
              style="--clamp: 6"
            >
              {a.message}
            </p>
          </article>
        </li>
      ))
    }
  </ul>

  <p class="recog-empty" data-awards-empty hidden>
    No awards match your search.
  </p>
</Section>

<style>
  /* Per-level accents — six distinct hues. Theme tuning lives once in
     global.css (--lvl-* tokens, AA ≥3:1 on --bg-elev in both themes); these
     classes just map an award level onto its token so accents never desync. */
  .level-evp {
    --lvl: var(--lvl-evp);
  }
  .level-cio {
    --lvl: var(--lvl-cio);
  }
  .level-senior-director {
    --lvl: var(--lvl-senior-director);
  }
  .level-director {
    --lvl: var(--lvl-director);
  }
  .level-associate-director {
    --lvl: var(--lvl-associate-director);
  }
  .level-national-level {
    --lvl: var(--lvl-national);
  }

  /* Multi-color per view: cards/tiles read the shared --accent-card; feed it each
     item's per-level --lvl so every award level shows its own hue, falling back to
     the Recognition accent (gold) when an element has no level class.
     Scoped to #awards so the rule doesn't bleed into About/Vision theme-cards. */
  :global(#awards .theme-card.card) {
    --accent-card: var(--lvl, var(--view-accent-recognition));
    --mark-fg: var(--accent-card);
  }

  .awards-summary {
    --theme-cols: 3;
    margin-bottom: var(--text-gap-section);
  }

  @media (min-width: 900px) {
    .awards-summary {
      --theme-cols: 6;
    }
  }

  .awards-grid {
    --theme-cols: 3;
    grid-auto-rows: 1fr;
  }

  .awards-grid > li {
    display: flex;
  }

  :global(#awards .awards-grid > li > .theme-card.card) {
    flex: 1;
    width: 100%;
    height: 100%;
  }

  :global(#awards .awards-grid .awards-card__message) {
    margin-top: auto;
  }

  @media (max-width: 980px) {
    .awards-grid {
      --theme-cols: 2;
    }
  }

  @media (max-width: 560px) {
    .awards-grid {
      --theme-cols: 1;
      grid-auto-rows: auto;
    }
  }

  .awards-summary :global(li),
  .awards-grid :global(li) {
    min-width: 0;
  }

  .awards-grid :global(.recog-card-divider) {
    margin-block: var(--text-gap-inline);
  }

  :global(#awards .theme-card.card .recog-card-divider) {
    background: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 40%,
      var(--border)
    );
  }

  .awards-card__kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
    margin: var(--text-gap-pair) 0 0;
    max-width: none;
  }

  :global(#awards .theme-card.card.hidden) {
    display: none;
  }
</style>

<script>
  import { initRecogGrid } from '../../scripts/recog-grid';

  const root = document.getElementById('awards');
  if (root) {
    initRecogGrid({
      root,
      gridSelector: '[data-awards-grid]',
      itemSelector: '.theme-card.card[data-level]',
      searchSelector: '[data-awards-search]',
      countSelector: '[data-awards-count]',
      emptySelector: '[data-awards-empty]',
      filterAttr: 'data-level',
      searchAttrs: ['data-title', 'data-nominator', 'data-reason'],
    });
  }
</script>
