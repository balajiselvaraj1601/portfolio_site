---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import {
  profile,
  site,
  collaborations,
  getEntityUrl,
  logoSrc,
} from '@lib/content';

const title = site.sections.leadership.title;
const {
  intro,
  blockHeadings,
  strategicVision,
  businessImpact,
  platform,
  peopleMentoring,
  governanceAI,
  governancePrivacy,
  governanceGxP,
} = profile.leadershipPhilosophy;

const cardBlocks = [
  {
    key: 'strategicVision',
    heading: blockHeadings.strategicVision,
    items: strategicVision,
  },
  {
    key: 'businessImpact',
    heading: blockHeadings.businessImpact,
    items: businessImpact,
  },
  { key: 'platform', heading: blockHeadings.platform, items: platform },
  {
    key: 'peopleMentoring',
    heading: blockHeadings.peopleMentoring,
    items: peopleMentoring,
  },
  {
    key: 'governanceAI',
    heading: blockHeadings.governanceAI,
    items: governanceAI,
  },
  {
    key: 'governancePrivacy',
    heading: blockHeadings.governancePrivacy,
    items: governancePrivacy,
  },
  {
    key: 'governanceGxP',
    heading: blockHeadings.governanceGxP,
    items: governanceGxP,
  },
];
const visibleBlocks = cardBlocks.filter((b) => b.items && b.items.length > 0);
---

<Section
  id="leadership"
  title={title}
  variant="alt"
  class="section--compact-top"
>
  {
    intro && (
      <div class="leadership__intro reveal">
        {(Array.isArray(intro) ? intro : [intro]).map((line) => (
          <p class="section__subtitle leadership__intro-line">{line}</p>
        ))}
      </div>
    )
  }

  <div
    class="leadership__filters reveal"
    role="group"
    aria-label="Filter About focus areas"
  >
    <button
      type="button"
      class="recog-chip is-active"
      data-filter="all"
      aria-pressed="true"
    >
      All
    </button>
    {
      visibleBlocks.map((b) => (
        <button
          type="button"
          class:list={['recog-chip', `cat-${b.key}`]}
          data-filter={b.key}
          aria-pressed="false"
        >
          {b.heading}
        </button>
      ))
    }
  </div>

  <div class="leadership__blocks" data-about-grid>
    {
      visibleBlocks.map(({ key, heading, items }) => (
        <div
          class:list={['leadership__card-row', 'reveal', `cat-${key}`]}
          data-category={key}
        >
          <h3 class="leadership__diff-heading">{heading}</h3>
          <ul class="theme-grid" role="list">
            {(items ?? []).map((item) => (
              <li class="theme-card card">
                {item.icon && (
                  <CardMark icon={item.icon} context="theme-card" />
                )}
                <h3 class="theme-card__title">{item.title}</h3>
                <p class="theme-card__desc">{item.description}</p>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="leadership__collabs reveal">
    <h3 class="leadership__collabs-heading">{collaborations.title}</h3>
    <ul class="leadership__collabs-list" role="list">
      {
        collaborations.items.map((item) => {
          const href = getEntityUrl(item.entity);
          const src = logoSrc(item.logo);
          if (!href || !src) return null;
          return (
            <li>
              <a
                href={href}
                class="leadership__collab-mark"
                aria-label={item.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <CardMark
                  slug={item.logo}
                  logoUrl={src}
                  altText=""
                  useBadge={false}
                  logoSize="lg"
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>

<script>
  import { initRecogGrid } from '../../scripts/recog-grid';

  const root = document.getElementById('leadership');
  if (root) {
    initRecogGrid({
      root,
      gridSelector: '[data-about-grid]',
      itemSelector: '.leadership__card-row',
      filterAttr: 'data-category',
    });
  }
</script>

<style>
  .leadership__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0 0 var(--text-gap-inline);
  }
  .leadership__card-row.hidden {
    display: none;
  }

  /* Per-category token mapping — one hue per category key. Mirrors the Awards
     pattern (level → --lvl → --accent-card); keys match data-category so
     theming and filtering share one source. */
  .cat-strategicVision {
    --cat: var(--about-cat-strategic);
  }
  .cat-businessImpact {
    --cat: var(--about-cat-impact);
  }
  .cat-platform {
    --cat: var(--about-cat-platform);
  }
  .cat-peopleMentoring {
    --cat: var(--about-cat-people);
  }
  .cat-governanceAI {
    --cat: var(--about-cat-ai);
  }
  .cat-governancePrivacy {
    --cat: var(--about-cat-privacy);
  }
  .cat-governanceGxP {
    --cat: var(--about-cat-gxp);
  }
  /* Per-group colour: each leadership row carries its own curated hue via --cat
     (set by its .cat-* class); cards, borders, and icon marks inherit it. */
  .leadership__card-row {
    --accent-card: var(--cat);
    --mark-fg: var(--accent-card);
  }
  /* Active category chip takes its hue; the "All" chip has no .cat-* class, so
     it falls back to the brand purple. */
  .recog-chip.is-active {
    --accent-card: var(--cat, var(--view-accent-about));
    --mark-fg: var(--accent-card);
  }
  /* Dark-mode prominence wash is built into the base `.card` rule (global.css),
     keyed to --accent-card (== --cat on each row). */

  .leadership__diff-heading {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
    font-weight: var(--fw-regular);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
    margin-bottom: var(--text-gap-block);
  }

  .leadership__blocks {
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
  }

  .leadership__card-row {
    margin-top: 0;
  }
  .leadership__card-row .theme-grid {
    margin-top: 0;
  }
  .leadership__collabs {
    margin-top: var(--stack-xl);
  }
  .leadership__collabs-heading {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
    font-weight: var(--fw-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--text-gap-block);
  }
  .leadership__collabs-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4);
    width: 100%;
    max-width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .leadership__collabs-list li {
    min-width: 0;
  }
  .leadership__intro {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-block);
    margin-bottom: var(--text-gap-section);
  }
  .leadership__intro-line {
    max-width: none;
    margin-bottom: 0;
  }
  .leadership__collab-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    height: clamp(56px, 7vw, 80px);
    padding: var(--space-3) var(--logo-pad);
    background: var(--logo-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .leadership__collab-mark:hover {
    border-color: var(--accent-light);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent-light) 25%, transparent),
      var(--shadow-md);
  }
  @media (prefers-reduced-motion: no-preference) {
    .leadership__collab-mark:hover {
      transform: translateY(var(--card-lift));
    }
  }
  .leadership__collab-mark:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .leadership__collab-mark :global(.logo-badge) {
    max-width: min(var(--logo-w-max-lg), 100%);
  }
  @media (max-width: 768px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 90%;
    }
  }
</style>
