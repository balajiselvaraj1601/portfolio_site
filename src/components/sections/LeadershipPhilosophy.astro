---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import {
  profile,
  site,
  collaborations,
  getEntityUrl,
  logoSrc,
} from '@lib/content';

const title = site.sections.leadership.title;
const {
  intro,
  strategicVision,
  businessImpact,
  platform,
  peopleMentoring,
  governance,
} = profile.leadershipPhilosophy;

// CTO-for-AI pillars, in render order. Each renders as an identical card row;
// blocks with no cards are skipped.
const cardBlocks = [
  { heading: 'Strategy & Sponsorship', items: strategicVision },
  { heading: 'Business & P&L Impact', items: businessImpact },
  { heading: 'Platform & Infrastructure', items: platform },
  { heading: 'Team & Org Building', items: peopleMentoring },
  { heading: 'Governance & Responsible AI', items: governance },
];
---

<Section id="leadership" title={title} variant="default">
  {intro && <p class="leadership__intro reveal">{intro}</p>}

  {
    cardBlocks.map(
      ({ heading, items }) =>
        items &&
        items.length > 0 && (
          <div class="leadership__card-row reveal">
            <h3 class="leadership__diff-heading">{heading}</h3>
            <ul
              class="leadership__themes"
              style={`--card-cols: ${items.length}`}
              role="list"
            >
              {items.map((item) => (
                <li class="leadership__theme card">
                  {item.icon && (
                    <span class="leadership__theme-icon" aria-hidden="true">
                      <Icon name={item.icon} size={22} />
                    </span>
                  )}
                  <h4 class="leadership__theme-title">{item.title}</h4>
                  <p class="leadership__theme-desc">{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
        )
    )
  }

  <div class="leadership__collabs reveal">
    <h3 class="leadership__collabs-heading">{collaborations.title}</h3>
    <ul class="leadership__collabs-list" role="list">
      {
        collaborations.items.map((item) => {
          const href = getEntityUrl(item.entity);
          const src = logoSrc(item.logo);
          if (!href || !src) return null;
          return (
            <li>
              <a
                href={href}
                class="leadership__collab-mark"
                aria-label={item.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="logo-mark logo-mark--lg"
                  src={src}
                  alt=""
                  loading="lazy"
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>

<style>
  .leadership__intro {
    font-size: var(--fs-body);
    max-width: var(--maxw-text);
    color: var(--text-muted);
    line-height: var(--lh-body);
  }
  .leadership__diff-heading {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .leadership__card-row {
    margin-top: var(--space-10);
  }
  .leadership__card-row .leadership__themes {
    margin-top: 0;
    grid-template-columns: repeat(var(--card-cols, 4), minmax(0, 1fr));
  }
  .leadership__themes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--stack-sm);
    list-style: none;
    padding: 0;
    margin: var(--space-10) auto 0;
  }
  .leadership__theme {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: var(--card-padding);
  }
  .leadership__theme-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .leadership__theme-title {
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--heading);
    margin: 0;
  }
  .leadership__theme-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }
  .leadership__collabs {
    margin-top: var(--space-10);
  }
  .leadership__collabs-heading {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .leadership__collabs-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4);
    width: 100%;
    max-width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .leadership__collabs-list li {
    min-width: 0;
  }
  .leadership__collab-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    height: clamp(56px, 7vw, 80px);
    padding: var(--space-3) var(--space-4);
    background: var(--logo-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .leadership__collab-mark:hover {
    border-color: var(--accent-light);
    box-shadow: 0 0 0 1px
      color-mix(in srgb, var(--accent-light) 25%, transparent);
  }
  .leadership__collab-mark:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .leadership__collab-mark .logo-mark {
    max-width: min(var(--logo-w-max-lg), 100%);
  }
  @media (max-width: 768px) {
    .leadership__card-row .leadership__themes {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .leadership__collabs-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }
  }
  @media (max-width: 480px) {
    .leadership__card-row .leadership__themes {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 90%;
    }
  }
</style>
