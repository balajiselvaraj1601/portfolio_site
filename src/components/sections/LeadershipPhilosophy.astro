---
import Section from '@components/ui/Section.astro';
import LeadershipFocusAreas from '@components/sections/about/LeadershipFocusAreas.astro';
import LeadershipCollaborations from '@components/sections/about/LeadershipCollaborations.astro';
import { profile, site } from '@lib/content';

const title = site.sections.leadership.title;
const { intro } = profile.leadershipPhilosophy;
---

<Section
  id="leadership"
  eyebrow={site.sections.leadership.eyebrow}
  title={title}
  variant="alt"
  class="section--compact-top"
>
  {
    intro && (
      <div class="leadership__intro reveal">
        {(Array.isArray(intro) ? intro : [intro]).map((line) => (
          <p class="section__subtitle leadership__intro-line">{line}</p>
        ))}
      </div>
    )
  }

  <LeadershipFocusAreas />

  <LeadershipCollaborations />
</Section>

<style>
  .leadership__intro {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-block);
    margin-bottom: var(--text-gap-section);
  }
  .leadership__intro-line {
    max-width: none;
    margin-bottom: 0;
  }
</style>
