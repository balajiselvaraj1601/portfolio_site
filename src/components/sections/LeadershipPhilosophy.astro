---
import Section from '@components/ui/Section.astro';
import CardMark from '@components/ui/CardMark.astro';
import {
  profile,
  site,
  collaborations,
  getEntityUrl,
  logoSrc,
} from '@lib/content';

const title = site.sections.leadership.title;
const {
  intro,
  blockHeadings,
  strategicVision,
  businessImpact,
  platform,
  peopleMentoring,
  governanceAI,
  governancePrivacy,
  governanceGxP,
} = profile.leadershipPhilosophy;

const cardBlocks = [
  { heading: blockHeadings.strategicVision, items: strategicVision },
  { heading: blockHeadings.businessImpact, items: businessImpact },
  { heading: blockHeadings.platform, items: platform },
  { heading: blockHeadings.peopleMentoring, items: peopleMentoring },
  { heading: blockHeadings.governanceAI, items: governanceAI },
  { heading: blockHeadings.governancePrivacy, items: governancePrivacy },
  { heading: blockHeadings.governanceGxP, items: governanceGxP },
];
---

<Section id="leadership" title={title} variant="default">
  {intro && <p class="leadership__intro reveal">{intro}</p>}

  {
    cardBlocks.map(
      ({ heading, items }) =>
        items &&
        items.length > 0 && (
          <div class="leadership__card-row reveal">
            <h3 class="leadership__diff-heading">{heading}</h3>
            <ul
              class="theme-grid"
              style={`--theme-cols: ${items.length}`}
              role="list"
            >
              {items.map((item) => (
                <li class="theme-card card">
                  {item.icon && (
                    <CardMark icon={item.icon} context="theme-card" />
                  )}
                  <h3 class="theme-card__title">{item.title}</h3>
                  <p class="theme-card__desc">{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
        )
    )
  }

  <div class="leadership__collabs reveal">
    <h3 class="leadership__collabs-heading">{collaborations.title}</h3>
    <ul class="leadership__collabs-list" role="list">
      {
        collaborations.items.map((item) => {
          const href = getEntityUrl(item.entity);
          const src = logoSrc(item.logo);
          if (!href || !src) return null;
          return (
            <li>
              <a
                href={href}
                class="leadership__collab-mark"
                aria-label={item.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <CardMark
                  slug={item.logo}
                  logoUrl={src}
                  altText=""
                  useBadge={false}
                  logoSize="lg"
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>

<style>
  .leadership__intro {
    font-size: var(--fs-body);
    max-width: var(--maxw-text);
    color: var(--text-muted);
    line-height: var(--lh-body);
  }
  .leadership__diff-heading {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent-ll);
    margin-bottom: var(--space-4);
  }
  .leadership__card-row {
    margin-top: var(--space-10);
  }
  .leadership__card-row .theme-grid {
    margin-top: 0;
  }
  .leadership__collabs {
    margin-top: var(--space-10);
  }
  .leadership__collabs-heading {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .leadership__collabs-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4);
    width: 100%;
    max-width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .leadership__collabs-list li {
    min-width: 0;
  }
  .leadership__collab-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    height: clamp(56px, 7vw, 80px);
    padding: var(--space-3) var(--logo-pad);
    background: var(--logo-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .leadership__collab-mark:hover {
    border-color: var(--accent-light);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent-light) 25%, transparent),
      var(--shadow-md);
  }
  @media (prefers-reduced-motion: no-preference) {
    .leadership__collab-mark:hover {
      transform: translateY(var(--card-lift));
    }
  }
  .leadership__collab-mark:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .leadership__collab-mark :global(.logo-badge) {
    max-width: min(var(--logo-w-max-lg), 100%);
  }
  @media (max-width: 768px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 90%;
    }
  }
</style>
