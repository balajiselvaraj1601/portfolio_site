---
import Section from '@components/ui/Section.astro';
import ProjectAccordion from '@components/cards/ProjectAccordion.astro';
import Chip from '@components/ui/Chip.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { experience, site, getEntityUrl, logoSrc } from '@lib/content';
import { logoUsesBadge } from '@lib/logo-display';

function periodLabel(p: { start: string; end: string | null; endLabel: string }) {
  const end = p.endLabel || p.end || '';
  return end ? `${p.start} – ${end}` : p.start;
}
---

<Section
  id="experience"
  title=""
  hideTitle
  eyebrow="Experience"
  variant="default"
>
  <h2 class="experience__title section__title">
    Building AI at the <span class="accent">frontier</span> of medicine
  </h2>
  <div class="work-layout">
    <div class="work-timeline" role="tablist" aria-label="Career timeline">
      <div class="timeline-line" aria-hidden="true"></div>
      {
        experience.roles.map((role, i) => (
          <button
            type="button"
            role="tab"
            class:list={['tl-item', { active: i === 0 }]}
            data-panel={role.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${role.id}`}
            tabindex={i === 0 ? '0' : '-1'}
            id={`tab-${role.id}`}
          >
            <div class="tl-dot" aria-hidden="true"></div>
            <div class="tl-year">{periodLabel(role.period)}</div>
            <div class="tl-role">{role.position}</div>
            <div class="tl-company">
              <EntityLink href={getEntityUrl(role.entity)} label={role.organization} />
            </div>
          </button>
        ))
      }
    </div>

    <div class="work-panels">
      {
        experience.roles.map((role, ri) => (
          <div
            class:list={['work-panel', { active: ri === 0 }]}
            id={`panel-${role.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${role.id}`}
            hidden={ri !== 0}
          >
            <div class="role-header">
              {logoSrc(role.entity) && (
                <div class:list={['role-logo', { 'role-logo--plain': !logoUsesBadge(role.entity) }]}>
                  <img src={logoSrc(role.entity)} alt={`${role.organization} logo`} loading="lazy" />
                </div>
              )}
              <h3>{role.position}</h3>
              <div class="role-meta">
                <span>
                  <EntityLink href={getEntityUrl(role.entity)} label={role.organization} />
                </span>
                {role.location && <span>{role.location}</span>}
                <span>{periodLabel(role.period)}</span>
              </div>
              {role.tech && role.tech.length > 0 && (
                <div class="role-tech">
                  {role.tech.map((t) => (
                    <Chip>{t}</Chip>
                  ))}
                </div>
              )}
              {role.mission && <p class="role-description">{role.mission}</p>}
            </div>
            <div class="projects-grid">
              {
                role.projects.map((project, pi) => (
                  project.name ? (
                    <ProjectAccordion
                      name={project.name}
                      subtitle={project.subtitle}
                      icon={project.icon}
                      bullets={project.bullets}
                      open={pi === 0}
                    />
                  ) : (
                    <ul class="bullet-list">
                      {project.bullets.map((b) => (
                        <li class:list={[{ 'is-secondary': b.tier === 'secondary' }]}>
                          {b.text}
                        </li>
                      ))}
                    </ul>
                  )
                ))
              }
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>

<style>
  .experience__title {
    margin-bottom: var(--space-6);
  }
  .work-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--stack-xl);
  }
  .work-timeline {
    position: relative;
  }
  .timeline-line {
    position: absolute;
    left: 16px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--accent-red), transparent);
  }
  .tl-item {
    position: relative;
    padding-left: 44px;
    padding-bottom: var(--stack-lg);
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
    width: 100%;
    color: inherit;
    display: block;
  }
  .tl-dot {
    position: absolute;
    left: 8px;
    top: 4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    transition: background 0.2s;
  }
  .tl-item.active .tl-dot {
    background: var(--accent);
  }
  .tl-year {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-light);
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }
  .tl-role {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.3;
  }
  .tl-company {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .work-panel {
    display: none;
  }
  .work-panel.active {
    display: block;
  }
  .role-header {
    margin-bottom: var(--stack-lg);
  }
  .role-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    max-width: 160px;
    padding: var(--space-2) var(--space-3);
    margin-bottom: 0.75rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .role-logo--plain {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 180px;
  }
  .role-logo img {
    display: block;
    max-width: 140px;
    max-height: 30px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .role-logo--plain img {
    max-width: 160px;
    max-height: 32px;
  }
  .role-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .role-meta {
    display: flex;
    gap: var(--stack-md);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .role-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .role-description {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.8;
    max-width: 680px;
    margin-bottom: var(--stack-lg);
  }
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: var(--stack-sm);
  }
  .is-secondary {
    color: var(--text-muted);
  }
  @media (max-width: 900px) {
    .work-layout {
      grid-template-columns: 1fr;
    }
    .work-timeline {
      max-height: 200px;
      overflow-x: auto;
      display: flex;
      flex-direction: row;
    }
    .timeline-line {
      display: none;
    }
    .tl-item {
      padding-left: 0;
      padding-right: 1.5rem;
      padding-bottom: 0;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .tl-dot {
      display: none;
    }
  }
</style>

<script>
  import { initExperiencePanel } from '../../scripts/site-chrome';
  initExperiencePanel();
</script>
