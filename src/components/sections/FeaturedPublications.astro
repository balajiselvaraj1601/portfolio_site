---
import Section from '@components/Section.astro';
import ResearchCard from '@components/ResearchCard.astro';
import { publications, site } from '@lib/content';

const featured = publications.items.slice(0, 3);
const title = site.sections['featured-publications'].title;
---

<Section id="featured-publications" title={title} variant="alt">
  <div class="research-grid reveal">
    {
      featured.map((p) => (
        <ResearchCard
          venue={p.label}
          title={p.title}
          href={p.url}
          logo={p.logo}
        />
      ))
    }
  </div>
  <p class="pub-more reveal">
    <a class="btn btn-secondary" href="/research">All research →</a>
  </p>
</Section>

<style>
  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .pub-more {
    margin-top: var(--space-8);
    max-width: none;
  }
</style>
