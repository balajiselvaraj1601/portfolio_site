---
import CardMark from '@components/ui/CardMark.astro';
import { profile } from '@lib/content';

const {
  blockHeadings,
  blockSubheadings,
  strategicVision,
  businessImpact,
  platform,
  peopleMentoring,
  responsibleGovernance,
  governanceGxP,
} = profile.about;

const cardBlocks = [
  {
    key: 'strategicVision',
    heading: blockHeadings.strategicVision,
    subheading: blockSubheadings?.strategicVision,
    items: strategicVision,
  },
  {
    key: 'businessImpact',
    heading: blockHeadings.businessImpact,
    subheading: blockSubheadings?.businessImpact,
    items: businessImpact,
  },
  {
    key: 'platform',
    heading: blockHeadings.platform,
    subheading: blockSubheadings?.platform,
    items: platform,
  },
  {
    key: 'peopleMentoring',
    heading: blockHeadings.peopleMentoring,
    subheading: blockSubheadings?.peopleMentoring,
    items: peopleMentoring,
  },
  {
    key: 'responsibleGovernance',
    heading: blockHeadings.responsibleGovernance,
    subheading: blockSubheadings?.responsibleGovernance,
    items: responsibleGovernance,
  },
  {
    key: 'governanceGxP',
    heading: blockHeadings.governanceGxP,
    subheading: blockSubheadings?.governanceGxP,
    items: governanceGxP,
  },
];
const visibleBlocks = cardBlocks.filter((b) => b.items && b.items.length > 0);
---

<div
  class="about__filters reveal"
  role="group"
  aria-label="Filter About focus areas"
>
  <button
    type="button"
    class="recog-chip is-active"
    data-filter="all"
    aria-pressed="true"
  >
    All
  </button>
  {
    visibleBlocks.map((b) => (
      <button
        type="button"
        class:list={['recog-chip', `cat-${b.key}`]}
        data-filter={b.key}
        aria-pressed="false"
      >
        {b.heading}
      </button>
    ))
  }
</div>

<div class="about__blocks" data-about-grid>
  {
    visibleBlocks.map(({ key, heading, subheading, items }) => (
      <div
        class:list={['about__card-row', 'reveal', `cat-${key}`]}
        data-category={key}
      >
        <p class="subhead-eyebrow about__diff-heading">{heading}</p>
        {subheading && (
          <p class="subhead-eyebrow subhead-eyebrow--muted about__block-subheading">
            {subheading}
          </p>
        )}
        <ul class="theme-grid" role="list">
          {(items ?? []).map((item) => (
            <li class="theme-card card">
              {item.icon && <CardMark icon={item.icon} context="theme-card" />}
              <h3 class="theme-card__title">{item.title}</h3>
              <p class="theme-card__desc">{item.description}</p>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  .about__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0 0 var(--text-gap-section);
  }
  .about__card-row.hidden {
    display: none;
  }

  /* Per-category token mapping — one hue per category key. Mirrors the Awards
     pattern (level → --lvl → --accent-card); keys match data-category so
     theming and filtering share one source. */
  .cat-strategicVision {
    --cat: var(--about-cat-strategic);
  }
  .cat-businessImpact {
    --cat: var(--about-cat-impact);
  }
  .cat-platform {
    --cat: var(--about-cat-platform);
  }
  .cat-peopleMentoring {
    --cat: var(--about-cat-people);
  }
  .cat-responsibleGovernance {
    --cat: var(--about-cat-ai);
  }
  .cat-governanceGxP {
    --cat: var(--about-cat-gxp);
  }
  /* Per-group colour: each about row carries its own curated hue via --cat
     (set by its .cat-* class); cards, borders, and icon marks inherit it. */
  .about__card-row {
    --accent-card: var(--cat);
    --mark-fg: var(--accent-card);
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-block);
    margin-top: 0;
  }
  /* Active category chip takes its hue; the "All" chip has no .cat-* class, so
     it falls back to the brand purple. */
  .recog-chip.is-active {
    --accent-card: var(--cat, var(--view-accent-about));
    --mark-fg: var(--accent-card);
  }
  /* Dark-mode prominence wash is built into the base `.card` rule (global.css),
     keyed to --accent-card (== --cat on each row). */

  .about__diff-heading {
    color: var(--accent-card, var(--accent-ll));
  }

  .about__block-subheading {
    margin-top: 0;
    margin-bottom: 0;
  }

  .about__blocks {
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
  }

  .about__card-row .about__diff-heading,
  .about__card-row .about__block-subheading {
    margin-bottom: 0;
  }
  .about__card-row .theme-grid {
    margin-top: 0;
  }
</style>
