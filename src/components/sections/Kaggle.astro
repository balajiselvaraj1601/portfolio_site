---
import Section from '@components/ui/Section.astro';
import CompetitionCard from '@components/cards/CompetitionCard.astro';
import RecogControls from '@components/ui/RecogControls.astro';
import RecogTile from '@components/ui/RecogTile.astro';
import { kaggle, site } from '@lib/content';

import { MEDALS, medalClass } from '@lib/recognition';

// Presentation order = impact: best percentile first. Parse the number out of
// strings like "Top 1.8%" and sort ascending. Fixed server-side, never hardcoded.
const pct = (p: string) => parseFloat(p.replace(/[^\d.]/g, '')) || Infinity;
const items = [...kaggle.items].sort(
  (a, b) => pct(a.percentile) - pct(b.percentile)
);

// Counts are DERIVED from the items — single source of truth, never hardcoded.
const total = items.length;
const silver = items.filter((i) => i.medal === 'Silver').length;
const bronze = items.filter((i) => i.medal === 'Bronze').length;
---

<Section
  id="kaggle"
  title={site.sections.kaggle.title}
  variant="alt"
  class="section--compact-top section--compact-bottom"
>
  <!-- Summary stat tiles — competition + medal counts and global rank -->
  <div class="recog-summary reveal">
    <RecogTile icon="kaggle" count={total} label="Competitions" />
    <RecogTile
      class="blob--silver"
      icon="trophy"
      markSlug="logo_trophy_badge"
      count={silver}
      label="Silver"
    />
    <RecogTile
      class="blob--bronze"
      icon="trophy"
      markSlug="logo_trophy_badge"
      count={bronze}
      label="Bronze"
    />
    <RecogTile icon="target" count={kaggle.rank} label="Global Rank">
      {
        kaggle.rankDenominator && (
          <span slot="label-extra"> · {kaggle.rankDenominator}</span>
        )
      }
    </RecogTile>
  </div>

  <RecogControls
    countLabel="Competitions"
    total={total}
    countDataAttr="data-kaggle-count"
    searchDataAttr="data-kaggle-search"
    searchPlaceholder="Search competitions…"
    searchAriaLabel="Search competitions by name, domain, or tag"
    filterGroupLabel="Filter by medal"
  >
    <a
      slot="tools"
      class="btn btn-secondary"
      href={kaggle.profile}
      target="_blank"
      rel="noopener noreferrer"
    >
      View Kaggle profile
    </a>
    <button
      type="button"
      class="recog-chip is-active"
      data-filter="all"
      aria-pressed="true"
    >
      All
    </button>
    {
      MEDALS.map((m) => (
        <button
          type="button"
          class:list={['recog-chip', medalClass(m)]}
          data-filter={m}
          aria-pressed="false"
        >
          {m}
        </button>
      ))
    }
  </RecogControls>

  <!-- Competition card grid -->
  <div class="recog-grid reveal" data-kaggle-grid>
    {items.map((item) => <CompetitionCard {...item} />)}
  </div>

  <p class="recog-empty" data-kaggle-empty hidden>
    No competitions match your search.
  </p>
</Section>

<style>
  /* Medal accents — map to the shared --medal-* tokens (theme tuning lives once
     in global.css) so tiles and filter chips match the cards. */
  .blob--silver {
    --medal: var(--medal-silver);
  }
  .blob--bronze {
    --medal: var(--medal-bronze);
  }
  /* Multi-color per view: tiles and chips read each item's per-medal --medal so
     silver and bronze show their own hue, falling back to the Recognition accent
     (gold) when an element has no medal class. */
  .recog-tile.blob--silver,
  .recog-tile.blob--bronze,
  .recog-chip.blob--silver,
  .recog-chip.blob--bronze {
    --accent-card: var(--medal, var(--view-accent-recognition));
    --mark-fg: var(--accent-card);
  }
</style>

<script>
  import { initRecogGrid } from '../../scripts/recog-grid';

  const root = document.getElementById('kaggle');
  if (root) {
    initRecogGrid({
      root,
      gridSelector: '[data-kaggle-grid]',
      searchSelector: '[data-kaggle-search]',
      countSelector: '[data-kaggle-count]',
      emptySelector: '[data-kaggle-empty]',
      filterAttr: 'data-medal',
      searchAttrs: ['data-name', 'data-domain', 'data-tags'],
    });
  }
</script>
