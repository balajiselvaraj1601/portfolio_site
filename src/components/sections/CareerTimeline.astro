---
import Section from '@components/ui/Section.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { experience, site, getEntityUrl } from '@lib/content';

interface Props {
  compact?: boolean;
  showCta?: boolean;
}

const { compact = false, showCta = true } = Astro.props;
const title = site.sections.timeline.title;

function periodLabel(p: { start: string; end: string | null; endLabel: string }) {
  const end = p.endLabel || p.end || '';
  return end ? `${p.start} – ${end}` : p.start;
}
---

<Section id="timeline" title={title} eyebrow="Experience" variant="alt">
  <ol class="work-timeline reveal" aria-label="Career timeline">
    <div class="timeline-line" aria-hidden="true"></div>
    {
      experience.roles.map((role, i) => (
        <li
          class:list={['tl-item', { active: i === 0 }]}
        >
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-year">{periodLabel(role.period)}</div>
          <div class="tl-role">{role.position}</div>
          <div class="tl-company">
            <EntityLink href={getEntityUrl(role.entity)} label={role.organization} />
          </div>
        </li>
      ))
    }
  </ol>
  {!compact && showCta && (
    <p class="timeline-more reveal">
      <a class="btn btn-secondary" href="/experience">Full experience →</a>
    </p>
  )}
</Section>

<style>
  .work-timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 280px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline-line {
    position: absolute;
    left: 16px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--accent-red), transparent);
  }
  .tl-item {
    position: relative;
    padding-left: 44px;
    padding-bottom: var(--stack-lg);
    color: inherit;
  }
  .tl-dot {
    position: absolute;
    left: 8px;
    top: 4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    transition: background 0.2s, border-color 0.2s;
  }
  .tl-item.active .tl-dot {
    background: var(--accent);
  }
  .tl-year {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-light);
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }
  .tl-role {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.3;
  }
  .tl-company {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .timeline-more {
    margin-top: var(--section-cta-gap);
    max-width: none;
  }
  @media (max-width: 900px) {
    .work-timeline {
      max-height: 200px;
      overflow-x: auto;
      flex-direction: row;
      max-width: 100%;
    }
    .timeline-line {
      display: none;
    }
    .tl-item {
      padding-left: 0;
      padding-right: 1.5rem;
      padding-bottom: 0;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .tl-dot {
      display: none;
    }
  }
</style>
