---
import Section from '@components/ui/Section.astro';
import EducationHero from '@components/sections/recognition/EducationHero.astro';
import EducationStats from '@components/sections/recognition/EducationStats.astro';
import EducationHighlight from '@components/sections/recognition/EducationHighlight.astro';
import { education, site } from '@lib/content';

// Schema guarantees at least one record (educationSchema.records.min(1)); this guard
// keeps rendering safe if the data ever degrades rather than throwing at build time.
const [record] = education.records;
if (!record) return;
---

<Section
  id="education"
  title={site.sections.education.title}
  subtitle={education.intro}
  variant="default"
  class="section--compact-top"
>
  <article class="edu-panel card reveal edu-accent">
    <div class="edu-layout">
      <EducationHero record={record} />

      <div class="edu-body">
        <EducationStats record={record} />

        {record.summary && <EducationHighlight summary={record.summary} />}
      </div>
    </div>
  </article>
</Section>

<style>
  .edu-accent {
    /* Recognition gold — matches Kaggle summary tiles and icon-standardization SSOT. */
    --accent-card: var(--accent-gold);
    --mark-fg: var(--accent-card);
  }

  .edu-panel {
    position: relative;
    padding: var(--card-padding);
  }

  .edu-layout {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-6);
  }
  @media (min-width: 768px) /* --bp-md */ {
    .edu-layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
      align-items: stretch;
      gap: clamp(var(--space-6), 4vw, var(--space-10));
    }
  }

  .edu-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-2);
  }
  @media (min-width: 768px) /* --bp-md */ {
    .edu-body {
      padding-top: calc(var(--space-6) + var(--space-2));
    }
  }

  @media (max-width: 767px) /* --bp-md - 1px */ {
    .edu-panel {
      display: flex;
      flex-direction: column;
    }
  }
</style>
