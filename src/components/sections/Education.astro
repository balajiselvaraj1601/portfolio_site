---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import CardMark from '@components/ui/CardMark.astro';
import { education, getEntityUrl, logoSrc, site } from '@lib/content';
import type { IconName } from '@lib/icons';

// Schema guarantees at least one record (educationSchema.records.min(1)); this guard
// keeps rendering safe if the data ever degrades rather than throwing at build time.
const [record] = education.records;
if (!record) return;
const logo = logoSrc(record.entity);
const entityUrl = getEntityUrl(record.entity);
const degreeShort = record.degree.split(' ')[0];
const fieldLabel = record.field ?? record.degree.replace(/^[^\s]+\s*/, '');

function formatGpa(value?: string) {
  if (!value) return undefined;
  return value.toLowerCase().startsWith('cgpa') ? value : `CGPA ${value}`;
}

const achievementLines = [record.achievement, record.achievementDetail].filter(
  (line): line is string => Boolean(line)
);

type StatCell = {
  icon: IconName;
  label: string;
  value?: string;
  lines?: string[];
  href?: string;
  linkLabel?: string;
};

const stats: StatCell[] = [
  {
    icon: 'institution',
    label: 'Institution',
    value: record.institution,
    href: entityUrl,
    linkLabel: record.institution,
  },
  { icon: 'calendar', label: 'Period', value: record.period },
  ...(record.gpa
    ? [
        {
          icon: 'chart' as IconName,
          label: 'GPA',
          value: formatGpa(record.gpa)!,
        },
      ]
    : []),
  ...(achievementLines.length > 0
    ? [
        {
          icon: 'trophy' as IconName,
          label: 'Achievement',
          lines: achievementLines,
        },
      ]
    : []),
];
---

<Section
  id="education"
  title={site.sections.education.title}
  subtitle={education.intro}
  variant="default"
>
  <article class="edu-panel reveal edu-accent">
    <div class="edu-layout">
      <div class="edu-hero">
        <CardMark
          logoUrl={logo}
          slug={record.entity}
          altText={record.institution + ' logo'}
          logoSize="lg"
          icon="graduation"
          iconFallback="graduation"
          variant="recog"
          class={logo ? 'edu-hero__logo' : 'edu-hero__icon icon-tile--accented'}
        />
        <p class="edu-degree-short">{degreeShort}</p>
        <h3 class="edu-field">{fieldLabel}</h3>
        <div class="edu-rule" aria-hidden="true"></div>
      </div>

      <div class="edu-body">
        <dl class="edu-stats">
          {
            stats.map((s) => (
              <div class="edu-stat">
                <span
                  class="icon-tile icon-tile--recog icon-tile--accented edu-stat__icon"
                  aria-hidden="true"
                >
                  <Icon name={s.icon} size={18} />
                </span>
                <div class="edu-stat__copy">
                  <dt class="recog-label">{s.label}</dt>
                  <dd
                    class:list={[
                      'recog-value',
                      s.lines && 'edu-stat__value--stacked',
                    ]}
                  >
                    {s.lines ? (
                      s.lines.map((line) => (
                        <span class="edu-stat__line">{line}</span>
                      ))
                    ) : s.href && s.linkLabel ? (
                      <EntityLink href={s.href} label={s.linkLabel} />
                    ) : (
                      s.value
                    )}
                  </dd>
                </div>
              </div>
            ))
          }
        </dl>

        {
          record.summary && (
            <div class="card-tint card-tint--accent edu-highlight">
              <span
                class="icon-tile icon-tile--recog icon-tile--accented edu-highlight__icon"
                aria-hidden="true"
              >
                <Icon name="trophy" size={20} />
              </span>
              <p class="edu-highlight__text">{record.summary}</p>
            </div>
          )
        }
      </div>
    </div>
  </article>
</Section>

<style>
  .edu-accent {
    --accent-card: var(--accent-gold);
  }

  .edu-panel {
    position: relative;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent-card, var(--accent-gold));
    border-radius: var(--radius-xl);
    padding: var(--card-padding);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }
  @media (prefers-reduced-motion: no-preference) {
    .edu-panel:hover {
      transform: translateY(var(--card-lift));
      box-shadow: var(--shadow-md);
      border-color: var(--border-strong);
    }
  }
  .edu-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(
        circle at 0.4rem 0.4rem,
        color-mix(
            in srgb,
            var(--accent-card, var(--accent-gold)) 12%,
            transparent
          )
          0.5px,
        transparent 0.5px
      ),
      radial-gradient(
        120% 80% at 0% 0%,
        color-mix(
          in srgb,
          var(--accent-card, var(--accent-gold)) 10%,
          transparent
        ),
        transparent 55%
      );
    background-size:
      18px 18px,
      auto;
    opacity: 0.55;
  }

  .edu-panel__badge {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
    z-index: 1;
  }

  .edu-layout {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-6);
  }
  @media (min-width: 768px) /* --bp-md */ {
    .edu-layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
      align-items: start;
      gap: clamp(var(--space-6), 4vw, var(--space-10));
    }
  }

  .edu-hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .edu-hero__logo {
    margin-bottom: var(--space-1);
  }
  .edu-hero__icon {
    margin-bottom: var(--space-1);
  }

  .edu-degree-short {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    line-height: 1;
    color: var(--accent-card, var(--accent-gold));
    margin: 0;
  }

  .edu-field {
    font-family: var(--font-sans);
    font-size: clamp(1.35rem, 2.8vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--heading);
    margin: 0;
  }

  .edu-rule {
    width: min(100%, 12rem);
    height: 2px;
    margin-top: var(--space-2);
    background: linear-gradient(
      to right,
      transparent,
      var(--accent-card, var(--accent-gold)),
      transparent
    );
    opacity: 0.85;
  }

  .edu-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-2);
  }
  @media (min-width: 768px) /* --bp-md */ {
    .edu-body {
      padding-top: calc(var(--space-6) + var(--space-2));
    }
  }

  .edu-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin: 0;
  }

  .edu-stat {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: color-mix(in srgb, var(--bg) 55%, var(--bg-elev));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .edu-stat__icon {
    flex-shrink: 0;
  }
  .edu-stat__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }
  .edu-stat dd {
    margin: 0;
    font-size: var(--fs-md);
    line-height: var(--lh-normal);
  }
  .edu-stat__value--stacked {
    display: flex;
    flex-direction: column;
    gap: var(--space-0-5);
  }
  .edu-stat__line {
    display: block;
  }

  .edu-highlight {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
  }
  .edu-highlight__icon {
    flex-shrink: 0;
  }
  .edu-highlight__text {
    margin: 0;
    font-size: var(--fs-base);
    line-height: 1.65;
    color: var(--text);
    max-width: none;
  }

  @media (max-width: 767px) /* --bp-md - 1px */ {
    .edu-panel__badge {
      position: static;
      align-self: flex-start;
      margin-bottom: var(--space-2);
    }
    .edu-panel {
      display: flex;
      flex-direction: column;
    }
    .edu-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
