---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { education, site, getEntityUrl, logoSrc } from '@lib/content';

function formatGpa(gpa?: string) {
  if (!gpa) return '';
  return gpa.toLowerCase().startsWith('cgpa') ? gpa : `CGPA ${gpa}`;
}
---

<Section id="education" title={site.sections.education.title} variant="default">
  <div class="edu-list reveal">
    {
      education.records.map((edu) => (
      <div class="edu-block">
        {logoSrc(edu.entity) ? (
          <div class="edu-logo">
            <img src={logoSrc(edu.entity)} alt={`${edu.institution} logo`} loading="lazy" />
          </div>
        ) : (
          <div class="edu-icon" aria-hidden="true">
            <Icon name="graduation" size={24} />
          </div>
        )}
        <div class="edu-text">
          <h4>Education</h4>
          <h3>{edu.degree}</h3>
          <p>
            <EntityLink href={getEntityUrl(edu.entity)} label={edu.institution} /> · {edu.period}
            {edu.gpa && ` · ${formatGpa(edu.gpa)}`}
          </p>
        </div>
        {edu.achievement && <div class="gold-badge">{edu.achievement}</div>}
      </div>
      ))
    }
  </div>
</Section>

<style>
  .edu-list {
    display: grid;
    gap: var(--space-4);
  }
  .edu-block {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: var(--card-padding);
    display: flex;
    gap: var(--stack-sm);
    align-items: flex-start;
    max-width: 640px;
  }
  .edu-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .edu-logo {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 44px;
    padding: var(--space-2) var(--space-2);
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  .edu-logo img {
    display: block;
    max-width: 100%;
    max-height: 28px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .edu-text h4 {
    margin-bottom: 0.3rem;
  }
  .edu-text h3 {
    font-size: 0.95rem;
    font-weight: 700;
  }
  .edu-text p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    max-width: none;
  }
  .gold-badge {
    margin-left: auto;
    background: linear-gradient(135deg, #f5c518, #c8960c);
    color: #000;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
</style>
