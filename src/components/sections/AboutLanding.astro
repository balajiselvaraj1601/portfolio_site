---

<div id="about-landing" class="about-landing">
  <slot />
</div>

<style>
  .about-landing {
    /* Hero band: major blocks use --text-gap-section; hero intro steps use --text-gap-block */
    --landing-gap: var(--text-gap-section);

    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: var(--landing-gap);
    padding-block: var(--stack-xl);
    overflow: visible;
    background: var(--hero-gradient);
  }

  .about-landing :global(#hero) {
    background: transparent;
    /* Full-viewport intro feel without trailing slack below Thirukural */
    min-height: calc(100svh - var(--header-h) - 2 * var(--stack-xl));
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 1023px) {
    .about-landing {
      height: auto;
    }

    .about-landing :global(#hero) {
      min-height: calc(100svh - var(--header-h) - 2 * var(--stack-xl));
      justify-content: flex-start;
    }
  }
</style>
