---
import Section from '@components/ui/Section.astro';
import ThemeCard from '@components/cards/ThemeCard.astro';
import { visionBoard, site } from '@lib/content';
---

<Section
  id="vision-impact"
  title={site.sections['vision-impact'].title}
  variant="default"
  class="section--compact-top"
>
  {
    visionBoard.orgCards && visionBoard.orgCards.length > 0 && (
      <ul
        class="theme-grid vision-impact__grid reveal"
        style="--theme-cols: 4"
        role="list"
      >
        {visionBoard.orgCards.map((c) => (
          <li class="vision-accent-hook">
            <ThemeCard mark={c.mark} title={c.title} lines={c.lines} />
          </li>
        ))}
      </ul>
    )
  }
</Section>

<style>
  /* 7 equal tiles in a 4-col grid → 4 on row 1, then 3 on row 2 left-aligned
     with a natural empty trailing cell (no span). grid-auto-rows: 1fr equalises
     both rows to the tallest row's height, so all 7 tiles are identical in width
     AND height. Each <li> flexes so its card fills the track. */
  .vision-impact__grid {
    grid-auto-rows: 1fr;
  }
  /* Impact tiles: single blue via #vision-impact .vision-accent-hook (VI-001). */
  .vision-impact__grid > li {
    display: flex;
  }
  .vision-impact__grid > li > :global(.theme-card) {
    width: 100%;
    height: 100%;
  }

  /* Unify Impact-tile glyphs with the Vision hub marks (--vision-mark-glyph 28px).
     The logo_vision_* emblems bake in their own ring and fill their glyph box
     edge-to-edge (mask contain); 28px keeps an ~8px gap inside the 44px chrome
     circle (--mark-slot unchanged). Scoped here so Recognition/About marks keep
     the site-default 22px. */
  .vision-impact__grid :global(.theme-card__icon) {
    --mark-glyph: 32px;
  }

  /* 1180px — matches --bp-2xl (CSS vars invalid in @media features).
     Base .theme-grid keeps 4 cols down to 769px, which cramps the cards and
     collides with the fixed dot rail in the 950–1180px band — drop to 2 cols
     at the same breakpoint where the vision flow stacks. */
  @media (max-width: 1180px) {
    .vision-impact__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Single-column phones — restate the base .theme-grid collapse (this scoped
     rule out-specifies it). */
  @media (max-width: 480px) {
    .vision-impact__grid {
      grid-template-columns: 1fr;
      /* Single column: content-sized cards (don't force tallest height × 7). */
      grid-auto-rows: auto;
    }
  }
</style>
