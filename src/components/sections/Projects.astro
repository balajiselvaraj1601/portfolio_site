---
import Section from '@components/ui/Section.astro';
import Chip from '@components/ui/Chip.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { projects, site, getEntityUrl } from '@lib/content';
import type { Project } from '@schemas';

const title = site.sections.projects.title;

function groupFor(project: Project) {
  if (
    project.domain.includes('Oncology') ||
    project.domain.includes('Pathology')
  ) {
    return 'Oncology & Pathology';
  }

  return 'Vision & Imaging Foundations';
}

interface Group {
  heading: string;
  items: Project[];
}

const others = projects.projects.filter((p) => !p.featured);
const groups: Group[] = [
  {
    heading: 'Oncology & Pathology',
    items: others.filter((p) => groupFor(p) === 'Oncology & Pathology'),
  },
  {
    heading: 'Vision & Imaging Foundations',
    items: others.filter((p) => groupFor(p) === 'Vision & Imaging Foundations'),
  },
].filter((g) => g.items.length > 0);
---

<Section id="projects" title={title} eyebrow="Other Work" variant="default">
  <div class="proj-groups reveal">
    {
      groups.map((group) => (
        <div class="proj-group">
          <h3 class="proj-group__heading">{group.heading}</h3>
          <ul class="proj-grid">
            {group.items.map((p) => (
              <li class="proj-compact card">
                <p class="pc-meta">
                  <span>{p.domain}</span>
                  <span class="pc-dot" aria-hidden="true">·</span>
                  <span>{p.period}</span>
                </p>
                <h4 class="pc-name">{p.name}</h4>
                <p class="pc-role">
                  {p.role} ·{' '}
                  <EntityLink href={getEntityUrl(p.entity)} label={p.org} />
                </p>
                <p class="pc-summary">{p.summary}</p>
                {p.highlights.length > 0 && (
                  <ul class="pc-highlights">
                    {p.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                )}
                {p.tags.length > 0 && (
                  <ul class="pc-tags" aria-label="Project tags">
                    {p.tags.map((t) => (
                      <li>
                        <Chip>{t}</Chip>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .proj-groups {
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
  }
  .proj-group__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent-ll);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .proj-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--stack-md);
  }
  .proj-compact {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .pc-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-light);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    max-width: none;
  }
  .pc-dot {
    color: var(--text-muted);
    opacity: 0.6;
  }
  .pc-meta > span:last-child {
    color: var(--text-muted);
  }
  .pc-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--heading);
    line-height: var(--lh-tight);
    margin: 0;
  }
  .pc-role {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
    max-width: none;
  }
  .pc-summary {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }
  .pc-highlights {
    margin: var(--space-2) 0 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .pc-highlights li + li {
    margin-top: var(--space-2);
  }
  .pc-tags {
    list-style: none;
    padding: 0;
    margin: var(--space-1) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
