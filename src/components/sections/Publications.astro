---
import Section from '@components/Section.astro';
import ResearchCard from '@components/ResearchCard.astro';
import { publications, site } from '@lib/content';
---

<Section
  id="publications"
  title={site.sections.publications.title}
  eyebrow="Research & Recognition"
  subtitle="Published, presented, and peer-recognized"
  variant="default"
>
  <div class="research-grid reveal">
    {
      publications.items.map((p) => (
        <ResearchCard venue={p.label} title={p.title} href={p.url} youtube={p.youtube} image={p.image} logo={p.logo} />
      ))
    }
  </div>
</Section>

<style>
  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
