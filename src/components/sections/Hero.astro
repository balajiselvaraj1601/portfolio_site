---
import { profile } from '@lib/content';
import Portrait from '@components/cards/Portrait.astro';
import HeroCopy from '@components/sections/about/HeroCopy.astro';
---

<section id="hero" class="hero reveal" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <HeroCopy />

    {
      profile.portrait && (
        <div class="hero__portrait">
          <Portrait
            src={profile.portrait.src}
            alt={profile.portrait.alt}
            webp={profile.portrait.webp}
            avif={profile.portrait.avif}
            width={profile.portrait.width}
            height={profile.portrait.height}
            priority
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    padding-block: 0;
    overflow: hidden;
    background: var(--hero-gradient);
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--hero-band-gap);
    align-items: start;
    align-content: start;
  }
  @media (min-width: 1025px) /* inline nav / save — matches Header */ {
    .hero__grid {
      grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
      gap: var(--hero-band-gap);
      align-items: start;
    }
  }
  .hero__portrait {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero__portrait :global(.portrait) {
    width: clamp(260px, 38vw, 500px);
  }
  @media (min-width: 1025px) {
    .hero__portrait {
      align-self: start;
    }
  }
  @media (max-width: 1024px) {
    .hero__portrait {
      order: -1;
    }
  }
</style>
