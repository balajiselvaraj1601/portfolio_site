---
import { profile } from '@lib/content';
import Icon from '@components/Icon.astro';
import AvailabilityBadge from '@components/AvailabilityBadge.astro';
import Portrait from '@components/Portrait.astro';

function isExternal(href: string) {
  return href.startsWith('http') || href.startsWith('/assets/');
}
---

<section id="hero" class="hero reveal" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <div class="hero__copy">
      {profile.heroTag && <div class="hero-tag">{profile.heroTag}</div>}

      {profile.availability && (
        <AvailabilityBadge
          status={profile.availability.status}
          label={profile.availability.label}
        />
      )}

      {profile.greeting && (
        <p class="hero__greeting">{profile.greeting}</p>
      )}

      <h1 id="hero-heading" class="hero__title">
        {
          profile.heroTitle ? (
            <>
              {profile.heroTitle.lead}{' '}
              <em>{profile.heroTitle.emphasis}</em>
              {profile.heroTitle.tail && (
                <>
                  <br />
                  {profile.heroTitle.tail}
                </>
              )}
            </>
          ) : (
            profile.name
          )
        }
      </h1>

      <p class="hero__sub">{profile.headline}</p>

      <div class="hero-stats" role="list" aria-label="Career highlights">
        {profile.metrics.map((m) => (
          <div class="hero-stat" role="listitem">
            <div class="hero-stat__num">{m.value}</div>
            <div class="hero-stat__label">{m.label}</div>
          </div>
        ))}
      </div>

      <div class="hero__cta">
        {profile.ctas.map((cta) => (
          <a
            class:list={[
              'btn',
              {
                'btn-primary': cta.variant === 'primary',
                'btn-secondary': cta.variant === 'secondary',
              },
            ]}
            href={cta.href}
            {...(isExternal(cta.href)
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            {cta.label === 'Download Resume' && (
              <Icon name="download" size={16} />
            )}
            {cta.label}
          </a>
        ))}
      </div>

    </div>

    {profile.portrait && (
      <div class="hero__portrait">
        <Portrait
          src={profile.portrait.src}
          alt={profile.portrait.alt}
          webp={profile.portrait.webp}
          width={profile.portrait.width}
          height={profile.portrait.height}
        />
      </div>
    )}
  </div>

  {profile.heroQuote && (
    <div class="hero-quote-bar container">
      <blockquote class="hero-quote" cite="Thiruvalluvar">
        <p class="hero-quote__tamil" lang="ta">{profile.heroQuote.tamil}</p>
        <p class="hero-quote__translation">
          <em lang="en">{profile.heroQuote.translation}</em>
        </p>
        <cite class="hero-quote__author">— {profile.heroQuote.author}</cite>
      </blockquote>
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-h));
    display: flex;
    flex-direction: column;
    padding-block: calc(var(--header-h) + var(--space-8)) var(--space-16);
    overflow: hidden;
    background: var(--hero-gradient);
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    padding: 0.35rem 1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.1em;
    color: var(--accent-ll);
  }
  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-light);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-tag::before {
      animation: hero-tag-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes hero-tag-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    flex: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-12);
    align-items: center;
    align-content: center;
  }
  @media (min-width: 1024px) {
    .hero__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-12);
      align-items: center;
    }
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .hero__greeting {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-ll);
    margin: 0;
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6.5vw, 5.5rem);
    line-height: 1.05;
    color: var(--heading);
    margin: 0;
    font-weight: 400;
  }
  .hero__title em {
    font-style: italic;
    color: var(--accent-ll);
  }
  .hero__sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 580px;
    margin: 0;
    line-height: 1.85;
  }
  .hero-quote-bar {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }
  .hero-quote {
    margin: 0;
    padding: var(--space-4) 0 0;
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    max-width: 36rem;
    text-align: center;
  }
  .hero-quote__tamil {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--heading);
    margin: 0 0 0.35rem;
  }
  .hero-quote__translation {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
    line-height: 1.6;
  }
  .hero-quote__translation em {
    font-style: italic;
  }
  .hero-quote__author {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.06em;
    color: var(--accent-ll);
    font-style: normal;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
    margin: 0;
  }
  @media (min-width: 640px) {
    .hero-stats {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  .hero-stat {
    border-left: 2px solid var(--accent);
    padding-left: var(--space-4);
  }
  .hero-stat__num {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 600;
    color: var(--heading);
    line-height: 1;
  }
  .hero-stat__label {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-top: 0.35rem;
    line-height: 1.3;
    max-width: none;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0;
  }
  .hero__portrait {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero__portrait :global(.portrait) {
    width: clamp(280px, 100%, 560px);
  }
  @media (max-width: 1023px) {
    .hero__portrait {
      order: -1;
    }
  }
</style>
