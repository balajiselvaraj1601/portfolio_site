---
import RecogTile from '@components/ui/RecogTile.astro';
import type { IconName } from '@lib/icons';
import { profile } from '@lib/content';
import Icon from '@components/ui/Icon.astro';
import AvailabilityBadge from '@components/ui/AvailabilityBadge.astro';
import Portrait from '@components/cards/Portrait.astro';

function isExternal(href: string) {
  return href.startsWith('http') || href.startsWith('/assets/');
}

const DEFAULT_METRIC_ICON: IconName = 'chart';
---

<section id="hero" class="hero reveal" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <div class="hero__copy">
      <div class="hero__intro">
        {profile.heroTag && <div class="hero-tag">{profile.heroTag}</div>}

        {
          profile.availability && (
            <AvailabilityBadge
              status={profile.availability.status}
              label={profile.availability.label}
            />
          )
        }

        {profile.greeting && <p class="hero__greeting">{profile.greeting}</p>}

        <h1 id="hero-heading" class="hero__title">
          {
            profile.heroTitle ? (
              <>
                <span class="hero__title-line">
                  {profile.heroTitle.lead} <em>{profile.heroTitle.emphasis}</em>
                </span>
                {profile.heroTitle.tail && (
                  <span class="hero__title-line">{profile.heroTitle.tail}</span>
                )}
              </>
            ) : (
              profile.name
            )
          }
        </h1>
      </div>

      <div
        class="recog-summary hero-stats"
        role="list"
        aria-label="Career highlights"
      >
        {
          profile.metrics.map((m) => (
            <RecogTile
              icon={m.icon ?? DEFAULT_METRIC_ICON}
              count={m.value}
              label={m.detail ? `${m.label} · ${m.detail}` : m.label}
              class="card-accent"
              role="listitem"
            />
          ))
        }
      </div>

      {
        profile.ctas.length > 0 && (
          <div class="hero__cta">
            {profile.ctas.map((cta) => (
              <a
                class:list={[
                  'btn',
                  {
                    'btn-primary': cta.variant === 'primary',
                    'btn-secondary': cta.variant === 'secondary',
                  },
                ]}
                href={cta.href}
                {...(isExternal(cta.href)
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {cta.icon && <Icon name={cta.icon} size={16} />}
                {cta.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    {
      profile.portrait && (
        <div class="hero__portrait">
          <Portrait
            src={profile.portrait.src}
            alt={profile.portrait.alt}
            webp={profile.portrait.webp}
            width={profile.portrait.width}
            height={profile.portrait.height}
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    padding-block: 0;
    overflow: hidden;
    background: var(--hero-gradient);
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    padding: var(--pill-padding-y) var(--pill-padding-x);
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-wide);
    color: var(--accent-ll);
  }
  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-light);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-tag::before {
      animation: hero-tag-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes hero-tag-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--landing-gap, var(--space-8));
    align-items: start;
    align-content: start;
  }
  @media (min-width: 1024px) {
    .hero__grid {
      grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
      gap: var(--space-10);
      align-items: start;
    }
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero__copy > * {
    margin: 0;
  }
  .hero__intro {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-block);
  }
  .hero__intro > * {
    margin: 0;
  }
  .hero__intro + .hero-stats {
    margin-top: var(--text-gap-section);
  }
  .hero__greeting {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent-ll);
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    line-height: var(--lh-none);
    color: var(--heading);
    font-weight: var(--fw-regular);
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }
  .hero__title-line {
    display: block;
  }
  .hero__title em {
    font-style: italic;
    color: var(--accent-ll);
  }
  .hero-stats {
    margin-top: 0;
    margin-bottom: 0;
  }
  .hero-stats + .hero__cta {
    margin-top: var(--text-gap-section);
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .hero__portrait {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero__portrait :global(.portrait) {
    width: clamp(260px, 38vw, 500px);
  }
  @media (min-width: 1024px) {
    .hero__portrait {
      align-self: start;
    }
  }
  @media (max-width: 1023px) {
    .hero__portrait {
      order: -1;
    }
  }
</style>
