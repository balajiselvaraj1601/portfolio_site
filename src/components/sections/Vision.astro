---
import Section from '@components/ui/Section.astro';
import { profile } from '@lib/content';

const vision = profile.vision;

function splitHeading(heading: string, emphasis?: string) {
  if (!emphasis || !heading.includes(emphasis)) {
    return { before: heading, emphasis: null as string | null, after: '' };
  }
  const index = heading.indexOf(emphasis);
  return {
    before: heading.slice(0, index),
    emphasis,
    after: heading.slice(index + emphasis.length),
  };
}

const headingParts = vision
  ? splitHeading(vision.heading, vision.headingEmphasis)
  : null;
---

{vision && (
  <Section
    id="technical-vision"
    title="Technical Vision"
    hideTitle
    eyebrow="Technical Vision"
    variant="alt"
  >
    <div class="vision-text reveal">
      {headingParts && (
        <h2 class="vision__title">
          {headingParts.before}
          {headingParts.emphasis ? <em>{headingParts.emphasis}</em> : null}
          {headingParts.after}
        </h2>
      )}

      <div class="vision__body">
        {vision.paragraphs.map((para) => (
          <p class="vision__para">{para}</p>
        ))}
      </div>

      {vision.mentorship && (
        <div class="vision__mentorship-block">
          <h4>Mentorship</h4>
          <p class="vision__mentorship">{vision.mentorship}</p>
        </div>
      )}
    </div>
  </Section>
)}

<style>
  .vision__title {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 400;
    line-height: 1.1;
    color: var(--heading);
    margin-bottom: 1rem;
  }
  .vision__title em {
    font-style: italic;
    color: var(--accent-ll);
  }
  .vision__body {
    margin-bottom: var(--space-8);
  }
  .vision__para {
    color: var(--text-muted);
    line-height: 1.85;
    margin-bottom: var(--space-4);
    font-size: 0.92rem;
    max-width: none;
  }
  .vision__para:last-child {
    margin-bottom: 0;
  }
  .vision__mentorship-block h4 {
    margin-bottom: 1rem;
  }
  .vision__mentorship {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: none;
  }
</style>
