---
import Section from '@components/ui/Section.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { affiliations, site, getEntityUrl, resolveAffiliationEntity, logoSrc } from '@lib/content';

const title = site.sections.affiliations.title;
---

<Section id="affiliations" title={title} variant="default">
  <div class="collab-list reveal">
    {
      affiliations.items.map((a) => (
        <div class="collab-item">
          {
            logoSrc(a.logo) ? (
              <div class="collab-logo">
                <img src={logoSrc(a.logo)} alt={`${a.name} logo`} loading="lazy" />
              </div>
            ) : (
              <div class="collab-dot" aria-hidden="true"></div>
            )
          }
          <div class="collab-text">
            <EntityLink
              href={getEntityUrl(resolveAffiliationEntity(a))}
              label={a.name}
            />
          </div>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .collab-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .collab-item {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .collab-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-light);
    flex-shrink: 0;
  }
  .collab-logo {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 96px;
    height: 40px;
    padding: var(--space-2) var(--space-3);
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .collab-logo img {
    display: block;
    max-width: 120px;
    max-height: 26px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .collab-text {
    font-size: 0.85rem;
    line-height: 1.6;
    max-width: none;
  }
</style>
