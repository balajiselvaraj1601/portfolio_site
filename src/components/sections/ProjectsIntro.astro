---
import Section from '@components/ui/Section.astro';
import MetricCard from '@components/cards/MetricCard.astro';
import { projects, site } from '@lib/content';

const title = site.sections['projects-intro'].title;
---

<Section
  id="projects-intro"
  title={title}
  subtitle={projects.intro}
  variant="default"
>
  {
    projects.snapshot && projects.snapshot.length > 0 && (
      <div class="snapshot-grid reveal">
        {projects.snapshot.map((m) => (
          <MetricCard value={m.value} label={m.label} />
        ))}
      </div>
    )
  }
</Section>
