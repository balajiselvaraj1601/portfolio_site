---
import Section from '@components/ui/Section.astro';
import VisionFlowChevrons from '@components/sections/vision/VisionFlowChevrons.astro';
import VisionImpactGrid from '@components/sections/vision/VisionImpactGrid.astro';
import VisionProgramGrid from '@components/sections/vision/VisionProgramGrid.astro';
import VisionHub from '@components/ui/VisionHub.astro';
import { visionBoard, site } from '@lib/content';
---

<Section
  id="vision-programs"
  eyebrow={site.sections['vision-programs'].eyebrow}
  title={visionBoard.header}
  subtitle={visionBoard.intro}
  variant="alt"
  class="section--compact-top section--compact-bottom"
>
  <div class="vision-flow reveal">
    {
      visionBoard.groups && visionBoard.groups.length >= 2 && (
        <>
          <div
            class:list={[
              'vision-hub-accent',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[0].accent}`,
            ]}
          >
            <VisionHub group={visionBoard.groups[0]} />
          </div>

          <VisionFlowChevrons accent={visionBoard.groups[0].accent} />

          <div
            class:list={[
              'vision-hub-accent',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[1].accent}`,
            ]}
          >
            <VisionHub group={visionBoard.groups[1]} />
          </div>

          <VisionFlowChevrons accent={visionBoard.groups[1].accent} />

          <VisionProgramGrid programs={visionBoard.programs} />
        </>
      )
    }
  </div>

  {
    visionBoard.orgCards && visionBoard.orgCards.length > 0 && (
      <>
        <h3 class="vision-impact__heading reveal">{visionBoard.orgHeader}</h3>
        <VisionImpactGrid cards={visionBoard.orgCards} />
      </>
    )
  }
</Section>

<style>
  /* Chevron styles → vision/VisionFlowChevrons.astro;
     program-card grid styles → vision/VisionProgramGrid.astro;
     impact-grid styles → vision/VisionImpactGrid.astro. */

  /* Sub-heading above the org-impact grid — deliberately below the section h2
     (--fs-h2) in the type scale: this is a sub-part of the single Vision
     section, not a section title. */
  .vision-impact__heading {
    font-size: var(--fs-2xl);
    font-weight: var(--fw-regular);
    color: var(--heading);
    /* Bottom gap one step above the header→content default (--text-gap-section):
       the heading must read as introducing the grid, with clear air before it. */
    margin: var(--space-12) 0 var(--stack-xl);
  }

  .vision-flow {
    display: grid;
    /* Chevron tracks are `auto` (intrinsic width) so every track-to-track gap equals
       --vision-flow-gap exactly. Hub tracks follow the fluid --vision-hub-w SSOT
       (20vw, capped at --vision-hub-max) so hubs and cards shrink together across
       the desktop range; the cards track is 1fr, so the row spans the full
       container — flush with the impact grid below. */
    grid-template-columns:
      var(--vision-hub-w)
      auto
      var(--vision-hub-w)
      auto
      minmax(300px, 1fr);
    justify-content: center;
    /* Hubs and chevrons centre on the row's vertical middle — the midpoint
       between the two rows of the 2×2 program grid (the tallest item). */
    align-items: center;
    column-gap: var(--vision-flow-gap, var(--space-4));
    width: 100%;
  }

  .vision-flow > :global(.vision-hub) {
    width: var(--vision-hub-w);
    max-width: var(--vision-hub-max);
    justify-self: center;
    min-width: 0;
    /* Grid centres the MARGIN box; the label footer is out-of-flow and the row
       is far taller than the hub here, so drop the reservation to put the
       circle's centre exactly on the row middle. Restored when stacked. */
    margin-bottom: 0;
  }

  /* Hub wrappers inherit categorical accent from vision-accent-* + vision-accent-hook
     (IDEA hub = purple, VISION hub = teal, from each group's content accent). */

  @media (max-width: 1180px) {
    /* 1180px — matches --bp-2xl (CSS vars invalid in @media features) */
    .vision-flow {
      grid-template-columns: 1fr 1fr 1fr;
      row-gap: var(--space-6);
      /* Hubs share row 1 with nothing taller — back to top alignment. */
      align-items: start;
      --vision-hub-max: var(--vision-hub-max-md);
      /* Stacked override of the fluid hub-width SSOT (:root has the desktop
         20vw clamp). 120px floor lets 38vw govern on small phones, so the two
         side-by-side hubs fit the container without bleeding into its padding
         at ≤526px. stage-mid MUST be redefined here too: the :root-level
         stage-mid computed its var(--vision-hub-w) against :root, so this
         scope's override alone would not reach it. */
      --vision-hub-w: clamp(120px, 38vw, var(--vision-hub-max-md));
      --vision-hub-stage-mid: calc(var(--vision-hub-w) / 2);
    }

    .vision-flow > :global(.vision-hub):first-of-type {
      grid-column: 1;
      grid-row: 1;
      width: var(--vision-hub-w);
      max-width: var(--vision-hub-max-md);
    }

    .vision-flow > :global(.vision-hub):last-of-type {
      grid-column: 3;
      grid-row: 1;
      width: var(--vision-hub-w);
      max-width: var(--vision-hub-max-md);
    }

    /* The cards row sits directly below the hubs here — restore the space the
       out-of-flow rule + label footer needs. */
    .vision-flow > :global(.vision-hub) {
      margin-bottom: var(--vision-hub-footer-h);
    }
  }
</style>
