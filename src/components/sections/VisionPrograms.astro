---
import Section from '@components/ui/Section.astro';
import ThemeCard from '@components/cards/ThemeCard.astro';
import VisionHub from '@components/ui/VisionHub.astro';
import { visionBoard, site, logoSrc } from '@lib/content';
import type { VisionBoard } from '@schemas';

type VisionProgram = VisionBoard['programs'][number];

/** Entity slug first, then pipeline badge asset — for uniform rect logo boxes. */
function resolveProgramLogoSlug(p: VisionProgram): string {
  const entity = p.entity;
  if (entity && logoSrc(entity)) return entity;
  if (p.badge?.kind === 'logo' && logoSrc(p.badge.asset)) return p.badge.asset;
  return entity ?? '';
}
---

<Section
  id="vision-programs"
  eyebrow={site.sections['vision-programs'].eyebrow}
  title={visionBoard.header}
  subtitle={visionBoard.intro}
  variant="alt"
  class="section--compact-top section--compact-bottom"
>
  <div class="vision-flow reveal">
    {
      visionBoard.groups && visionBoard.groups.length >= 2 && (
        <>
          <div
            class:list={[
              'vision-hub-accent',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[0].accent}`,
            ]}
          >
            <VisionHub group={visionBoard.groups[0]} />
          </div>

          <span
            class:list={[
              'vision-flow__chevrons',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[0].accent}`,
            ]}
            aria-hidden="true"
          >
            <span class="vision-flow__chevron vision-flow__chevron--1" />
            <span class="vision-flow__chevron vision-flow__chevron--2" />
            <span class="vision-flow__chevron vision-flow__chevron--3" />
          </span>

          <div
            class:list={[
              'vision-hub-accent',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[1].accent}`,
            ]}
          >
            <VisionHub group={visionBoard.groups[1]} />
          </div>

          <span
            class:list={[
              'vision-flow__chevrons',
              'vision-accent-hook',
              `vision-accent-${visionBoard.groups[1].accent}`,
            ]}
            aria-hidden="true"
          >
            <span class="vision-flow__chevron vision-flow__chevron--1" />
            <span class="vision-flow__chevron vision-flow__chevron--2" />
            <span class="vision-flow__chevron vision-flow__chevron--3" />
          </span>

          {visionBoard.programs && visionBoard.programs.length > 0 && (
            <div class="vision-flow__cards">
              <ul
                class="theme-grid vision-flow__grid"
                style="--theme-cols: 2"
                role="list"
              >
                {visionBoard.programs.map((p) => (
                  <li
                    class:list={['vision-accent-hook', `vision-accent-${p.accent}`]}
                  >
                    <ThemeCard
                      title={p.title}
                      lines={p.lines}
                      mark={p.badge}
                      slug={p.entity}
                      logoSlug={resolveProgramLogoSlug(p)}
                      markDisplay="rect"
                      altText={p.title}
                      label={p.label}
                      entity={p.entity}
                      accent={false}
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </>
      )
    }
  </div>
</Section>

<style>
  .vision-flow {
    display: grid;
    /* Chevron tracks are `auto` (intrinsic width) so every track-to-track gap equals
       --vision-flow-gap exactly. Hub tracks follow the fluid --vision-hub-w SSOT
       (20vw, capped at --vision-hub-max) so hubs and cards shrink together across
       the desktop range; the cards track is 1fr, so the row spans the full
       container — flush with the impact grid below. */
    grid-template-columns:
      var(--vision-hub-w)
      auto
      var(--vision-hub-w)
      auto
      minmax(300px, 1fr);
    justify-content: center;
    /* Hubs and chevrons centre on the row's vertical middle — the midpoint
       between the two rows of the 2×2 program grid (the tallest item). */
    align-items: center;
    column-gap: var(--vision-flow-gap, var(--space-4));
    width: 100%;
  }

  .vision-flow > :global(.vision-hub) {
    width: var(--vision-hub-w);
    max-width: var(--vision-hub-max);
    justify-self: center;
    min-width: 0;
    /* Grid centres the MARGIN box; the label footer is out-of-flow and the row
       is far taller than the hub here, so drop the reservation to put the
       circle's centre exactly on the row middle. Restored when stacked. */
    margin-bottom: 0;
  }

  .vision-flow__cards {
    min-width: 0;
    justify-self: stretch;
    /* The hub is a circle whose ring is inset ~4% from its track edge, while the cards
       are flush to theirs. Inset the cards' left edge by that amount so chevron set 2
       is optically centred and the hub↔box visible gap matches the hub↔hub gap.
       margin (not transform) keeps the right edge flush with the container. */
    margin-inline-start: var(--vision-hub-ring-inset);
  }

  .vision-flow__chevrons {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
    min-width: max-content;
    /* Same centring as the hubs — chevrons sit on the circles' equator line. */
    align-self: center;
    gap: 0;
  }

  .vision-flow__chevron + .vision-flow__chevron {
    margin-inline-start: calc(-1 * var(--chevron-flow-overlap));
  }

  .vision-flow__chevron {
    width: var(--chevron-flow-w);
    height: var(--chevron-flow-h);
    clip-path: polygon(0% 0%, 48% 0%, 100% 50%, 48% 100%, 0% 100%, 52% 50%);
  }

  .vision-flow__chevron--1 {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent-card, var(--accent)) 75%, var(--bg-elev)),
      var(--accent-card, var(--accent))
    );
  }

  .vision-flow__chevron--2 {
    background: linear-gradient(
      135deg,
      var(--accent-card, var(--accent)),
      color-mix(in srgb, var(--accent-card, var(--accent)) 70%, var(--accent-strong))
    );
  }

  .vision-flow__chevron--3 {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent-card, var(--accent)) 70%, var(--accent-strong)),
      color-mix(in srgb, var(--accent-card, var(--accent)) 45%, var(--bg))
    );
  }

  .vision-flow__grid {
    margin-top: 0;
    /* Equal rows: 1fr implicit rows resolve to the tallest row's content, so all
       four cards are the same size and the block centre — where the hubs and
       chevrons align — is exactly the midpoint of the gap between the rows. */
    grid-auto-rows: 1fr;
  }

  .vision-flow__grid li {
    display: flex;
    min-width: 0;
  }

  /* Hub wrappers inherit categorical accent from vision-accent-* + vision-accent-hook. */

  /* Program cards — per-item accent from content JSON (Leadership row pattern). */
  .vision-flow__grid :global(.theme-card.card) {
    flex: 1;
    height: 100%;
  }

  .vision-flow__grid :global(.program-card__label) {
    color: var(--accent-card, var(--accent-ll));
  }

  .vision-flow__grid :global(.program-card__lines li) {
    font-size: var(--fs-body);
  }

  /* Uniform white logo slots in each program quadrant. */
  .vision-flow__grid :global(.program-card__mark) {
    display: flex;
    justify-content: center;
    margin-bottom: var(--text-gap-inline);
    width: 100%;
  }

  .vision-flow__grid :global(.program-card__logo) {
    width: 100%;
    max-width: 100%;
  }

  .vision-flow__grid :global(.logo-badge) {
    width: 100%;
    min-height: var(--logo-box-h);
    justify-content: center;
    background: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 8%,
      var(--logo-surface)
    );
    border-color: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 35%,
      var(--border)
    );
  }

  .vision-flow__grid :global(.logo-badge img) {
    max-height: var(--logo-h-md);
    max-width: var(--logo-w-max-md);
  }

  @media (max-width: 1180px) {
    /* 1180px — matches --bp-2xl (CSS vars invalid in @media features) */
    .vision-flow {
      grid-template-columns: 1fr 1fr 1fr;
      row-gap: var(--space-6);
      /* Hubs share row 1 with nothing taller — back to top alignment. */
      align-items: start;
      --vision-hub-max: var(--vision-hub-max-md);
      /* Stacked override of the fluid hub-width SSOT (:root has the desktop
         20vw clamp). 120px floor lets 38vw govern on small phones, so the two
         side-by-side hubs fit the container without bleeding into its padding
         at ≤526px. stage-mid MUST be redefined here too: the :root-level
         stage-mid computed its var(--vision-hub-w) against :root, so this
         scope's override alone would not reach it. */
      --vision-hub-w: clamp(120px, 38vw, var(--vision-hub-max-md));
      --vision-hub-stage-mid: calc(var(--vision-hub-w) / 2);
    }

    .vision-flow > :global(.vision-hub):first-of-type {
      grid-column: 1;
      grid-row: 1;
      width: var(--vision-hub-w);
      max-width: var(--vision-hub-max-md);
    }

    .vision-flow > :global(.vision-hub):last-of-type {
      grid-column: 3;
      grid-row: 1;
      width: var(--vision-hub-w);
      max-width: var(--vision-hub-max-md);
    }

    /* The cards row sits directly below the hubs here — restore the space the
       out-of-flow rule + label footer needs. */
    .vision-flow > :global(.vision-hub) {
      margin-bottom: var(--vision-hub-footer-h);
    }

    .vision-flow__chevrons:first-of-type {
      grid-column: 2;
      grid-row: 1;
      /* Top-aligned row: anchor the chevron to the hub circles' vertical
         centre via the stacked stage-mid (derived from --vision-hub-w above). */
      align-self: start;
      margin-top: calc(var(--vision-hub-stage-mid) - var(--chevron-flow-h) / 2);
    }

    .vision-flow__chevrons:last-of-type {
      display: none;
    }

    .vision-flow__cards {
      grid-column: 1 / -1;
      grid-row: 2;
      /* Stacked layout: the 2×2 grid spans the full container (matching the
         impact grid below) — drop the desktop ring-inset nudge. */
      width: 100%;
      justify-self: stretch;
      margin-inline: 0;
    }
  }

  @media (max-width: 560px) {
    /* 560px — matches --bp-sm */
    .vision-flow__grid {
      grid-template-columns: 1fr;
      /* Single column: content-sized cards (don't force the tallest height ×4). */
      grid-auto-rows: auto;
    }
  }
</style>
