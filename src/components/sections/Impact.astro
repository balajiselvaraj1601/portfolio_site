---
import Section from '@components/ui/Section.astro';
import JourneyRow from '@components/cards/JourneyRow.astro';
import ImpactCard from '@components/cards/ImpactCard.astro';
import LeadershipCard from '@components/cards/LeadershipCard.astro';
import MetricCard from '@components/cards/MetricCard.astro';
import { strategicImpact, site } from '@lib/content';

const meta = site.sections.impact;
const title = strategicImpact.headline ?? meta.title;
const highlight = strategicImpact.headlineHighlight;
const highlightIndex =
  highlight && title.includes(highlight) ? title.indexOf(highlight) : -1;
---

<Section
  id="impact"
  title=""
  hideTitle
  eyebrow="AI Leadership & Strategic Impact"
  subtitle={strategicImpact.subtitle}
  variant="impact"
  class="impact-section"
>
  <h2 class="impact__title section__title">
    {
      highlightIndex >= 0 && highlight ? (
        <>
          {title.slice(0, highlightIndex)}
          <span class="accent">{highlight}</span>
          {title.slice(highlightIndex + highlight.length)}
        </>
      ) : (
        title
      )
    }
  </h2>
  {
    strategicImpact.journey && strategicImpact.journey.length > 0 && (
      <JourneyRow journey={strategicImpact.journey} />
    )
  }

  {
    strategicImpact.metrics.length > 0 && (
      <div class="impact-metrics reveal" aria-label="Strategic impact metrics">
        {strategicImpact.metrics.map((metric) => (
          <MetricCard value={metric.value} label={metric.label} />
        ))}
      </div>
    )
  }

  {
    strategicImpact.programs && strategicImpact.programs.length > 0 && (
      <div class="impact-grid reveal">
        {strategicImpact.programs.map((p) => (
          <ImpactCard {...p} />
        ))}
      </div>
    )
  }

  {
    strategicImpact.leadershipCards &&
      strategicImpact.leadershipCards.length > 0 && (
        <div class="leadership-block reveal">
          <p class="eyebrow eyebrow--red leadership-block__eyebrow">
            Leadership & Organizational Impact
          </p>
          <div class="leadership-cards">
            {strategicImpact.leadershipCards.map((c) => (
              <LeadershipCard {...c} />
            ))}
          </div>
        </div>
      )
  }

  {
    strategicImpact.highlights.length > 0 && (
      <ul class="impact-highlights reveal">
        {strategicImpact.highlights.map((highlight) => (
          <li>{highlight.text}</li>
        ))}
      </ul>
    )
  }
</Section>

<style>
  :global(.impact-section .eyebrow),
  .impact__title {
    text-align: center;
  }
  :global(.impact-section .section__subtitle) {
    text-align: center;
    margin-inline: auto;
    max-width: 580px;
  }
  .impact__title {
    margin-bottom: var(--space-4);
  }
  .impact-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-4);
    margin: var(--space-8) 0 var(--space-12);
  }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--stack-md);
    margin-bottom: var(--space-12);
  }
  .leadership-block {
    margin-top: var(--stack-xl);
  }
  .leadership-block__eyebrow {
    text-align: center;
    margin-bottom: var(--stack-lg);
  }
  .leadership-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--stack-sm);
  }
  .impact-highlights {
    list-style: none;
    padding: 0;
    margin: var(--space-10) auto 0;
    max-width: 820px;
    display: grid;
    gap: var(--space-4);
  }
  .impact-highlights li {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-5);
    color: var(--text);
    line-height: 1.7;
  }
  @media (max-width: 900px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
