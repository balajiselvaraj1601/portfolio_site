---
import Icon from '@components/ui/Icon.astro';
import { resolveIcon } from '@lib/icons';
import type { VisionBoard } from '@schemas';

// SSOT: props derive from the vision-board `orgCards` schema item.
type Props = NonNullable<VisionBoard['orgCards']>[number];

const { icon, title, lines } = Astro.props;
const iconName = resolveIcon(icon, 'diamond');
---

<article class="ocard">
  <div class="ocard__icon" aria-hidden="true">
    <Icon name={iconName} size={26} />
  </div>
  <h3 class="ocard__title">{title}</h3>
  <div class="ocard__rule" aria-hidden="true"></div>
  <div class="ocard__body">
    {lines.map((line) => <p>{line}</p>)}
  </div>
</article>

<style>
  .ocard {
    position: relative;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    min-height: 210px;
    padding: var(--space-6) var(--space-4) var(--space-5);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .ocard:hover {
    border-color: var(--accent);
    transform: translateY(var(--card-lift));
    box-shadow: var(--shadow-md);
  }
  .ocard__icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    margin: var(--space-2) auto var(--space-4);
    display: grid;
    place-items: center;
    color: var(--accent-ll);
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
  }
  .ocard__title {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
    color: var(--heading);
  }
  .ocard__rule {
    width: 92%;
    height: 2px;
    margin: var(--space-3) auto var(--space-4);
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--text-muted) 50%, transparent) 0 2px,
      transparent 2px 5px
    );
  }
  .ocard__body {
    display: grid;
    gap: 0.15rem;
  }
  .ocard__body p {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-muted);
  }
</style>
