---
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import { logoHasOwnRing } from '@lib/logo-display';
import type { VisionBoard } from '@schemas';

// SSOT: props derive from the vision-board `orgCards` schema item.
type Props = NonNullable<VisionBoard['orgCards']>[number];

const { mark, title, lines } = Astro.props;

// Self-ringed logo_* emblems draw their own solid disc — drop the chrome disc.
const plain = mark.kind === 'logo' && logoHasOwnRing(mark.asset);
---

<article class="ocard">
  <div
    class:list={['ocard__icon', { 'ocard__icon--plain': plain }]}
    aria-hidden="true"
  >
    <MarkEmblem mark={mark} iconSize={26} />
  </div>
  <h3 class="ocard__title">{title}</h3>
  <div class="ocard__rule" aria-hidden="true"></div>
  <div class="ocard__body">
    {lines.map((line) => <p>{line}</p>)}
  </div>
</article>

<style>
  .ocard {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 4;
    row-gap: 0;
    background: var(--bg-elev);
    border-radius: var(--radius-xl);
    min-height: 210px;
    padding: var(--space-6) var(--space-4) var(--space-5);
    text-align: center;
    box-shadow: 4px 7px 14px rgba(26, 21, 48, 0.14);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  /* Top gradient bar. */
  .ocard::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 6px;
    background: linear-gradient(90deg, var(--accent), var(--accent-strong));
  }
  /* Left purple→red gradient bar. */
  .ocard::after {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(
      180deg,
      var(--accent),
      var(--accent-strong) 70%,
      var(--accent-red)
    );
  }
  .ocard:hover {
    transform: translateY(var(--card-lift));
    box-shadow: var(--shadow-md);
  }
  .ocard__icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: var(--space-2) auto var(--space-4);
    display: grid;
    place-items: center;
    color: var(--accent-contrast);
    background: radial-gradient(
      circle at 30% 30%,
      var(--accent-strong),
      var(--accent)
    );
  }
  /* Self-ringed emblem draws its own solid disc — no chrome behind it. */
  .ocard__icon--plain {
    background: none;
    border: none;
    color: var(--accent-light);
  }
  .ocard__title {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
    color: var(--accent);
  }
  .ocard__rule {
    width: 92%;
    height: 2px;
    margin: var(--space-3) auto var(--space-4);
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--text-muted) 50%, transparent) 0 2px,
      transparent 2px 5px
    );
  }
  .ocard__body {
    display: grid;
    gap: 0.15rem;
  }
  .ocard__body p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
  }
</style>
