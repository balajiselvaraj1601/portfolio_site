---
import CardMark from '@components/ui/CardMark.astro';
import { logoSrc } from '@lib/content';
import { logoUsesBadge } from '@lib/logo-display';
import { youtubeId } from '@lib/youtube';

interface Props {
  icon?: string;
  venue: string;
  title: string;
  description?: string;
  href?: string;
  youtube?: string;
  image?: string;
  logo?: string;
  variant?: 'default' | 'stacked';
  logoBadge?: boolean;
}
const {
  icon,
  venue,
  title,
  description,
  href,
  youtube,
  image,
  logo,
  variant = 'default',
  logoBadge: logoBadgeOverride,
} = Astro.props;
const isStacked = variant === 'stacked';
const showLogoBadge = logoUsesBadge(logo, logoBadgeOverride);

const ytId = youtubeId(youtube);
const ytEmbed = ytId ? `https://www.youtube-nocookie.com/embed/${ytId}` : null;
const logoUrl = logoSrc(logo);
---

<article
  class:list={['rcard', 'content-card', { 'rcard--stacked': isStacked }]}
>
  {
    logoUrl ? (
      <CardMark
        slug={logo}
        logoUrl={logoUrl}
        altText={venue}
        useBadge={showLogoBadge}
        class="rcard-logo"
      />
    ) : (
      <CardMark icon={icon} iconFallback="document" class="rcard-logo" />
    )
  }
  {isStacked && <hr class="rcard-divider" aria-hidden="true" />}
  {!isStacked && <div class="venue">{venue}</div>}
  {
    href ? (
      <h3>
        <a href={href} target="_blank" rel="noopener noreferrer">
          {title}
          <span class="visually-hidden"> (opens in new window)</span>
        </a>
      </h3>
    ) : (
      <h3>{title}</h3>
    )
  }
  {
    isStacked && (
      <>
        <div class="venue venue--stacked">{venue}</div>
        {description && <hr class="rcard-divider" aria-hidden="true" />}
      </>
    )
  }
  {
    image && (
      <div class="rcard-media">
        <img src={image} alt={`${venue} — ${title}`} loading="lazy" />
      </div>
    )
  }
  {description && <p>{description}</p>}
  {
    ytEmbed && (
      <div class="rcard-video">
        <iframe
          src={ytEmbed}
          title={`${title} — video`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
      </div>
    )
  }
</article>

<style>
  .rcard-logo {
    margin-bottom: var(--stack-sm);
  }
  .rcard :global(.icon-tile),
  .rcard :global(.theme-card__icon) {
    margin-bottom: var(--stack-sm);
  }
  .rcard--stacked .rcard-logo,
  .rcard--stacked :global(.icon-tile),
  .rcard--stacked :global(.theme-card__icon) {
    align-self: flex-start;
    width: fit-content;
    margin-bottom: 0;
  }
  .rcard--stacked {
    display: flex;
    flex-direction: column;
    gap: var(--stack-sm);
  }
  .rcard-divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 0;
  }
  .venue {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--accent-ll);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }
  .venue--stacked {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: normal;
    text-transform: none;
    margin-bottom: 0;
    margin-top: 0;
  }
  .rcard h3 {
    font-size: var(--fs-card-title-sm);
    font-weight: 600;
    font-family: var(--font-sans);
    margin-bottom: var(--space-2);
  }
  .rcard--stacked h3 {
    margin-bottom: 0;
  }
  .rcard h3 a {
    color: var(--heading);
    text-decoration: none;
  }
  .rcard h3 a:hover {
    color: var(--accent-light);
  }
  .rcard p {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    line-height: var(--lh-relaxed);
    max-width: none;
  }
  .rcard--stacked p {
    margin-bottom: 0;
  }
  .rcard--stacked .rcard-media,
  .rcard--stacked .rcard-video {
    margin: 0;
  }
  .rcard-media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: var(--stack-sm) 0 var(--space-3);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--overlay-scrim);
  }
  .rcard-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .rcard-video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: var(--stack-sm) 0 var(--space-3);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--overlay-scrim);
  }
  .rcard-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
