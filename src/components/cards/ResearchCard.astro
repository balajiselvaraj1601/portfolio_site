---
import Icon from '@components/ui/Icon.astro';
import { resolveIcon, type IconName } from '@lib/icons';
import { logoSrc } from '@lib/content';
import { logoUsesBadge } from '@lib/logo-display';

interface Props {
  icon?: string;
  venue: string;
  title: string;
  description?: string;
  href?: string;
  youtube?: string;
  image?: string;
  logo?: string;
  variant?: 'default' | 'stacked';
  logoBadge?: boolean;
}
const {
  icon,
  venue,
  title,
  description,
  href,
  youtube,
  image,
  logo,
  variant = 'default',
  logoBadge: logoBadgeOverride,
} = Astro.props;
const iconName = resolveIcon(icon, 'document') as IconName;
const isStacked = variant === 'stacked';
const showLogoBadge = logoUsesBadge(logo, logoBadgeOverride);

/** Extract an 11-char YouTube video id from common URL shapes. */
function youtubeId(url?: string): string | null {
  if (!url) return null;
  const m = url.match(
    /(?:youtu\.be\/|youtube(?:-nocookie)?\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([\w-]{11})/
  );
  return m ? m[1] : null;
}
const ytId = youtubeId(youtube);
const ytEmbed = ytId ? `https://www.youtube-nocookie.com/embed/${ytId}` : null;
const logoUrl = logoSrc(logo);
---

<article class:list={['rcard', { 'rcard--stacked': isStacked }]}>
  {
    logoUrl ? (
      showLogoBadge ? (
        <div class="rcard-logo">
          <img src={logoUrl} alt={venue} loading="lazy" />
        </div>
      ) : (
        <div class="rcard-logo-plain">
          <img src={logoUrl} alt={venue} loading="lazy" />
        </div>
      )
    ) : (
      <div class="rcard-icon" aria-hidden="true">
        <Icon name={iconName} size={22} />
      </div>
    )
  }
  {isStacked && <hr class="rcard-divider" />}
  {
    !isStacked && <div class="venue">{venue}</div>
  }
  {
    href ? (
      <h3>
        <a href={href} target="_blank" rel="noopener noreferrer">{title}</a>
      </h3>
    ) : (
      <h3>{title}</h3>
    )
  }
  {
    isStacked && (
      <>
        <div class="venue venue--stacked">{venue}</div>
        {description && <hr class="rcard-divider" />}
      </>
    )
  }
  {
    image && (
      <div class="rcard-media">
        <img src={image} alt={`${venue} — ${title}`} loading="lazy" />
      </div>
    )
  }
  {description && <p>{description}</p>}
  {
    ytEmbed && (
      <div class="rcard-video">
        <iframe
          src={ytEmbed}
          title={`${title} — video`}
          loading="lazy"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
      </div>
    )
  }
</article>

<style>
  .rcard {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--card-padding-lg);
    transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
    height: 100%;
  }
  .rcard:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .rcard-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .rcard-logo {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: var(--space-2) var(--space-3);
    margin-bottom: 0.85rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
  }
  .rcard-logo img {
    display: block;
    max-height: 28px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }
  .rcard-logo-plain {
    display: flex;
    align-items: center;
    min-height: 40px;
    margin-bottom: 0.85rem;
  }
  .rcard-logo-plain img {
    display: block;
    max-height: 36px;
    width: auto;
    max-width: min(220px, 100%);
    object-fit: contain;
  }
  .rcard--stacked .rcard-logo,
  .rcard--stacked .rcard-logo-plain {
    margin-bottom: 0;
  }
  .rcard-divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 1rem 0;
  }
  .venue {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-ll);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .venue--stacked {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: normal;
    text-transform: none;
    margin-bottom: 0;
    margin-top: 0.35rem;
  }
  .rcard h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .rcard--stacked h3 {
    margin-bottom: 0;
  }
  .rcard h3 a {
    color: var(--heading);
    text-decoration: none;
  }
  .rcard h3 a:hover {
    color: var(--accent-light);
  }
  .rcard p {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: none;
  }
  .rcard--stacked p {
    margin-bottom: 0;
  }
  .rcard-media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0.85rem 0 0.6rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .rcard-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .rcard-video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0.85rem 0 0.6rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .rcard-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
