---
import Icon from '@components/ui/Icon.astro';
import LogoBadge from '@components/ui/LogoBadge.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { resolveIcon } from '@lib/icons';
import { getEntityUrl, logoSrc } from '@lib/content';
import { logoUsesBadge } from '@lib/logo-display';
import type { Impact } from '@schemas';

// SSOT: props derive from the strategic-impact `leadershipCards` schema item.
type Props = NonNullable<Impact['leadershipCards']>[number];
const { icon, title, subtitle, entity } = Astro.props;
const iconName = resolveIcon(icon, 'diamond');
const logoUrl = logoSrc(entity);
const showLogoBadge = Boolean(logoUrl && logoUsesBadge(entity));
---

<article class="lcard">
  <div class="lcard-mark" aria-hidden="true">
    {
      logoUrl ? (
        <LogoBadge
          logoUrl={logoUrl}
          useBadge={showLogoBadge}
          size="md"
          class="lcard-logo"
        />
      ) : (
        <div class="lcard-icon">
          <Icon name={iconName} size={22} />
        </div>
      )
    }
  </div>
  <div class="lcard-title">
    <EntityLink href={getEntityUrl(entity)} label={title} />
  </div>
  <div class="lcard-sub">{subtitle}</div>
</article>

<style>
  .lcard {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--card-padding) var(--space-4);
    text-align: center;
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
    position: relative;
    overflow: hidden;
  }
  .lcard:hover {
    border-color: var(--accent);
    transform: translateY(var(--card-lift));
    box-shadow: var(--shadow-md);
  }
  .lcard-mark {
    display: flex;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .lcard-logo {
    width: fit-content;
    max-width: 100%;
  }
  .lcard-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-red));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-contrast);
  }
  .lcard-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .lcard-sub {
    font-size: 0.76rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>
