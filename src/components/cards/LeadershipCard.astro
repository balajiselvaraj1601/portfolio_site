---
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { resolveIcon, type IconName } from '@lib/icons';
import { getEntityUrl } from '@lib/content';

interface Props {
  icon: string;
  title: string;
  subtitle: string;
  entity?: string;
}
const { icon, title, subtitle, entity } = Astro.props;
const iconName = resolveIcon(icon, 'diamond') as IconName;
---

<article class="lcard">
  <div class="lcard-icon" aria-hidden="true">
    <Icon name={iconName} size={22} />
  </div>
  <div class="lcard-title">
    <EntityLink href={getEntityUrl(entity)} label={title} />
  </div>
  <div class="lcard-sub">{subtitle}</div>
</article>

<style>
  .lcard {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: var(--card-padding) var(--space-4);
    text-align: center;
    transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
    position: relative;
    overflow: hidden;
  }
  .lcard:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }
  .lcard-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-red));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: #fff;
  }
  .lcard-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .lcard-sub {
    font-size: 0.76rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>
