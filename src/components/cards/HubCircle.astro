---
import Icon from '@components/ui/Icon.astro';
import { logoSrc } from '@lib/content';
import type { VisionBoard } from '@schemas';

type Hub = VisionBoard['hubs'][number];

interface Props {
  center: Hub['center'];
  satellites: Hub['satellites'];
  label: string;
  variant: Hub['variant'];
}

const { center, satellites, label, variant } = Astro.props;

// Geometry for the hub-and-spoke ring (matches the 300×300 SVG viewBox below).
const SIZE = 300;
const C = SIZE / 2; // centre
const RING = 108; // satellite ring radius
const START = -90; // first satellite at top, then clockwise every 60°

const nodes = satellites.map((mark, i) => {
  const angle = ((START + i * (360 / satellites.length)) * Math.PI) / 180;
  return {
    mark,
    // Resolve the logo URL only on the 'logo' branch; the emblem is painted via
    // a CSS mask so it inherits the satellite's accent color (see styles below).
    logo: mark.kind === 'logo' ? logoSrc(mark.asset) : undefined,
    x: C + RING * Math.cos(angle),
    y: C + RING * Math.sin(angle),
  };
});

// `center` is a VisionMark discriminated union; resolve the logo URL only on the
// 'logo' branch so the template can narrow without re-touching the union.
const centerLogo = center.kind === 'logo' ? logoSrc(center.asset) : undefined;
---

<figure class:list={['hub', `hub--${variant}`]}>
  <div class="hub__ring">
    <!-- dotted spokes from centre to each satellite -->
    <svg class="hub__spokes" viewBox={`0 0 ${SIZE} ${SIZE}`} aria-hidden="true">
      {nodes.map((n) => <line x1={C} y1={C} x2={n.x} y2={n.y} />)}
    </svg>

    <!-- centre mark -->
    <div class="hub__center">
      {
        center.kind === 'icon' ? (
          <Icon name={center.name} size={44} />
        ) : centerLogo ? (
          <img src={centerLogo} alt={center.alt ?? label} loading="lazy" />
        ) : null
      }
    </div>

    <!-- satellites -->
    {
      nodes.map((n, i) => (
        <span
          class="hub__sat"
          style={`left:${(n.x / SIZE) * 100}%;top:${(n.y / SIZE) * 100}%;--sat-accent:${
            variant === 'red'
              ? i % 2 === 0
                ? 'var(--accent-red)'
                : 'var(--accent-red-light)'
              : i % 2 === 0
                ? 'var(--accent)'
                : 'var(--accent-light)'
          }`}
          aria-hidden="true"
        >
          {
            n.mark.kind === 'icon' ? (
              <Icon name={n.mark.name} size={22} />
            ) : n.logo ? (
              <span
                class="hub__sat-emblem"
                style={`--emblem:url("${n.logo}")`}
              />
            ) : null
          }
        </span>
      ))
    }
  </div>
  <figcaption class="hub__label">{label}</figcaption>
</figure>

<style>
  .hub {
    --hub-accent: var(--accent);
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }
  .hub--red {
    --hub-accent: var(--accent-red);
  }
  .hub__ring {
    position: relative;
    width: 320px;
    max-width: 78vw;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 38%,
      var(--bg-elev),
      var(--bg-alt)
    );
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .hub__spokes {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hub__spokes line {
    stroke: var(--hub-accent);
    stroke-width: 1.4;
    stroke-dasharray: 2 5;
    stroke-linecap: round;
    opacity: 0.55;
  }
  .hub__center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 30%;
    height: 30%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--bg-elev);
    border: 2px solid var(--hub-accent);
    box-shadow: 0 0 0 5px var(--bg);
    color: var(--hub-accent);
    z-index: 2;
  }
  .hub__center:has(img) {
    background: var(--bg-elev);
  }
  .hub__center img {
    width: var(--logo-emblem-img);
    height: var(--logo-emblem-img);
    object-fit: contain;
  }
  .hub__sat {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 17%;
    height: 17%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--bg-elev);
    border: 1.5px solid var(--sat-accent, var(--hub-accent));
    color: var(--sat-accent, var(--hub-accent));
    box-shadow: 0 0 0 4px var(--bg);
  }
  /* Monochrome logo emblems are painted via a mask so they take the satellite's
     accent color (currentColor), matching the stroke icons in both themes. */
  .hub__sat-emblem {
    width: 22px;
    height: 22px;
    background: currentColor;
    -webkit-mask: var(--emblem) center / contain no-repeat;
    mask: var(--emblem) center / contain no-repeat;
  }
  .hub__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-ll);
    margin: 0;
  }
  .hub--red .hub__label {
    color: var(--accent-red-light);
  }
</style>
