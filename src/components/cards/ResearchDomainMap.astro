---
import Icon from '@components/ui/Icon.astro';
import type { DomainItem } from '@schemas';

interface Props {
  domains: DomainItem[];
}

const { domains } = Astro.props;
---

<div class="domain-map reveal" aria-label="Research domain map">
  <ul class="domain-map__list">
    {
      domains.map((d) => (
        <li class="domain-map__item">
          <div class="domain-map__icon icon-tile" aria-hidden="true">
            <Icon name={d.icon} size={22} />
          </div>
          <div>
            <div class="domain-map__label">{d.label}</div>
            <p class="domain-map__detail">{d.detail}</p>
          </div>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .domain-map {
    margin-bottom: var(--space-8);
  }
  .domain-map__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
  }
  .domain-map__item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--card-padding);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .domain-map__item:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: no-preference) {
    .domain-map__item:hover {
      transform: translateY(var(--card-lift));
    }
  }
  .domain-map__label {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ll);
    margin-bottom: var(--space-1);
  }
  .domain-map__detail {
    font-size: var(--fs-md);
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }
</style>
