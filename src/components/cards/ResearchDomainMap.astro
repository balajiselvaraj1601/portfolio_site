---
import Icon from '@components/ui/Icon.astro';
import type { IconName } from '@lib/icons';

interface Domain {
  label: string;
  icon: IconName;
  detail: string;
}

const domains: Domain[] = [
  {
    label: 'Medical Imaging',
    icon: 'scan',
    detail: 'CT, endoscopy, echocardiography foundation models',
  },
  {
    label: 'Oncology',
    icon: 'microscope',
    detail: 'Single-cell transcriptomics & tumor recurrence',
  },
  {
    label: 'Drug Safety',
    icon: 'pill',
    detail: 'Multimodal toxicology & omics integration',
  },
  {
    label: 'Generative AI',
    icon: 'brain',
    detail: 'LLM embeddings, RAG, and knowledge graphs',
  },
];
---

<div class="domain-map reveal" aria-label="Research domain map">
  <ul class="domain-map__list">
    {
      domains.map((d) => (
        <li class="domain-map__item">
          <div class="domain-map__icon">
            <Icon name={d.icon} size={22} />
          </div>
          <div>
            <div class="domain-map__label">{d.label}</div>
            <p class="domain-map__detail">{d.detail}</p>
          </div>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .domain-map {
    margin-bottom: var(--space-8);
  }
  .domain-map__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
  }
  .domain-map__item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-5);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color var(--dur) var(--ease);
  }
  .domain-map__item:hover {
    border-color: var(--border-strong);
  }
  .domain-map__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .domain-map__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ll);
    margin-bottom: 0.35rem;
  }
  .domain-map__detail {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }
</style>
