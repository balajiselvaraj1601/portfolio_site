---
import type { Profile } from '@schemas';

interface Props extends NonNullable<Profile['portrait']> {
  class?: string;
  /** LCP candidate on home — prioritize browser fetch when true. */
  priority?: boolean;
}

const {
  src,
  alt,
  webp,
  avif,
  width = 480,
  height = 480,
  class: cls,
  priority = false,
} = Astro.props;

const sizes = '(max-width: 768px) 220px, 360px';
const hasModern = Boolean(webp || avif);
---

<figure class:list={['portrait', cls]}>
  <div class="portrait__frame">
    {
      hasModern ? (
        <picture>
          {avif && <source srcset={avif} type="image/avif" sizes={sizes} />}
          {webp && <source srcset={webp} type="image/webp" sizes={sizes} />}
          <img
            src={src}
            alt={alt}
            width={width}
            height={height}
            sizes={sizes}
            loading="eager"
            decoding="async"
            fetchpriority={priority ? 'high' : undefined}
          />
        </picture>
      ) : (
        <img
          src={src}
          alt={alt}
          width={width}
          height={height}
          loading="eager"
          decoding="async"
          fetchpriority={priority ? 'high' : undefined}
        />
      )
    }
  </div>
</figure>

<style>
  .portrait {
    margin: 0;
    width: clamp(220px, 30vw, 360px);
    aspect-ratio: 1 / 1;
    position: relative;
  }
  .portrait::before {
    content: '';
    position: absolute;
    inset: 10% 4% 2%;
    border-radius: 42% 38% 44% 40%;
    background:
      radial-gradient(
        circle at 50% 28%,
        color-mix(in srgb, var(--accent-light) 24%, transparent),
        transparent 62%
      ),
      radial-gradient(
        circle at 58% 72%,
        color-mix(in srgb, var(--accent-red-light) 12%, transparent),
        transparent 58%
      );
    filter: blur(10px);
    opacity: 0.8;
    pointer-events: none;
  }
  .portrait__frame {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
    overflow: visible;
    border: 0;
    background: transparent;
    box-shadow: none;
    position: relative;
    isolation: isolate;
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 18px 28px var(--shadow-drop-color));
  }
  @media (prefers-reduced-motion: no-preference) {
    .portrait__frame {
      transition:
        transform var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .portrait:hover .portrait__frame {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px var(--shadow-drop-color-strong);
    }
  }
</style>
