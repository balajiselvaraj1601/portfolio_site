---
import type { MetricItem } from '@schemas';

// SSOT: shape derives from the shared MetricItem schema (value/label/detail?).
// `detail` is rendered when provided.
interface Props extends MetricItem {
  class?: string;
}
const { value, label, detail, class: cls } = Astro.props;
---

<div class:list={['metric-card', 'card', cls]}>
  <p class="metric-card__value">{value}</p>
  <p class="metric-card__label metric-label">{label}</p>
  {detail && <p class="metric-card__detail">{detail}</p>}
</div>

<style>
  .metric-card {
    padding: var(--card-padding);
    text-align: center;
  }
  .metric-card__value {
    font-family: var(--font-mono);
    font-size: var(--fs-metric);
    font-weight: 600;
    color: var(--accent);
    line-height: var(--lh-tight);
    max-width: none;
    margin-bottom: var(--space-2);
  }
  .metric-card__label {
    font-size: var(--fs-small);
    max-width: none;
  }
  .metric-card__detail {
    font-size: var(--fs-2xs);
    color: var(--text-muted);
    margin-top: var(--space-1);
    max-width: none;
  }
</style>
