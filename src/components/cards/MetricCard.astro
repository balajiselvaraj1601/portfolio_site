---
interface Props {
  value: string;
  label: string;
  class?: string;
}
const { value, label, class: cls } = Astro.props;
---

<div class:list={['metric-card', 'card', cls]}>
  <p class="metric-card__value">{value}</p>
  <p class="metric-card__label metric-label">{label}</p>
</div>

<style>
  .metric-card {
    padding: var(--card-padding);
    text-align: center;
  }
  .metric-card__value {
    font-family: var(--font-mono);
    font-size: var(--fs-metric);
    font-weight: 600;
    color: var(--accent);
    line-height: var(--lh-tight);
    max-width: none;
    margin-bottom: var(--space-2);
  }
  .metric-card__label {
    font-size: var(--fs-small);
    max-width: none;
  }
</style>
