---
import Chip from '@components/ui/Chip.astro';
import Icon from '@components/ui/Icon.astro';
import PipelineStrip from '@components/cards/PipelineStrip.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { getEntityUrl } from '@lib/content';
import type { Project } from '@schemas';

// Props are a schema-derived subset of a project record (SSOT: src/schemas.ts).
type Props = Pick<
  Project,
  | 'name'
  | 'role'
  | 'org'
  | 'entity'
  | 'period'
  | 'domain'
  | 'summary'
  | 'tags'
  | 'problem'
  | 'solution'
  | 'architecture'
  | 'businessImpact'
  | 'outcome'
  | 'lessons'
>;

const {
  name,
  role,
  org,
  entity,
  period,
  domain,
  summary,
  tags,
  problem,
  solution,
  architecture,
  businessImpact,
  outcome,
  lessons,
} = Astro.props;

// Cap visible tags at 3; full set stays in the data layer (projects.json).
const MAX_VISIBLE_TAGS = 3;
const visibleTags = tags.slice(0, MAX_VISIBLE_TAGS);
const hiddenTagCount = Math.max(0, tags.length - MAX_VISIBLE_TAGS);

// Collapsed card surfaces summary + business impact + tags.
// The deep detail (problem → lessons) is progressively disclosed below.
const blocks: Array<{ label: string; body: string }> = [];
if (problem) blocks.push({ label: 'Problem', body: problem });
if (solution) blocks.push({ label: 'Solution', body: solution });
if (architecture) blocks.push({ label: 'Architecture', body: architecture });
if (outcome) blocks.push({ label: 'Outcome', body: outcome });
if (lessons) blocks.push({ label: 'Lessons', body: lessons });

const hasDetail = blocks.length > 0;
---

<article class="case-study card card--accent">
  <header class="cs-head">
    <p class="cs-meta">
      <span class="cs-domain">{domain}</span>
      <span class="cs-dot" aria-hidden="true">·</span>
      <span class="cs-period">{period}</span>
    </p>
    <h3 class="cs-name">{name}</h3>
    <p class="cs-role">
      {role} · <EntityLink href={getEntityUrl(entity)} label={org} />
    </p>
    <p class="cs-summary">{summary}</p>
    {
      businessImpact && (
        <p class="cs-impact">
          <span class="cs-impact__label">Impact</span>
          <span class="cs-impact__body">{businessImpact}</span>
        </p>
      )
    }
    {
      visibleTags.length > 0 && (
        <ul class="cs-tags" aria-label="Project tags">
          {visibleTags.map((t) => (
            <li>
              <Chip>{t}</Chip>
            </li>
          ))}
          {hiddenTagCount > 0 && (
            <li>
              <Chip class="cs-tag-more">+{hiddenTagCount} more</Chip>
            </li>
          )}
        </ul>
      )
    }
  </header>

  {
    hasDetail && (
      <details class="cs-disclosure">
        <summary class="cs-disclosure__summary">
          <span class="cs-disclosure__text">Read the full case study</span>
          <span class="cs-disclosure__icon" aria-hidden="true">
            <Icon name="chevron" size="xs" />
          </span>
        </summary>
        <div class="cs-disclosure__body">
          <PipelineStrip
            problem={problem}
            solution={solution}
            architecture={architecture}
            businessImpact={businessImpact}
          />
          <dl class="cs-blocks">
            {blocks.map((b) => (
              <div class="cs-block">
                <dt>{b.label}</dt>
                <dd>{b.body}</dd>
              </div>
            ))}
          </dl>
        </div>
      </details>
    )
  }
</article>

<style>
  .case-study {
    padding: var(--card-padding-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cs-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-light);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    max-width: none;
  }
  .cs-dot {
    color: var(--text-muted);
    opacity: 0.6;
  }
  .cs-period {
    color: var(--text-muted);
  }

  .cs-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--heading);
    line-height: var(--lh-tight);
    margin: 0;
  }
  .cs-role {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
    max-width: none;
  }
  .cs-summary {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.65;
    margin: 0;
    max-width: var(--maxw-text);
  }

  .cs-impact {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    margin: var(--space-1) 0 0;
    padding: var(--space-3) var(--space-4);
    background: color-mix(in srgb, var(--accent-soft) 40%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    max-width: none;
  }
  .cs-impact__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ll);
    font-weight: 600;
    flex-shrink: 0;
  }
  .cs-impact__body {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.55;
  }

  .cs-tags {
    list-style: none;
    padding: 0;
    margin: var(--space-1) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .cs-tag-more {
    border-style: dashed;
  }

  /* Progressive disclosure — native <details>, works without JS, keyboard accessible. */
  .cs-disclosure {
    border-top: 1px solid var(--border);
    padding-top: var(--space-4);
  }
  .cs-disclosure__summary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    list-style: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent-ll);
    width: max-content;
  }
  .cs-disclosure__summary::-webkit-details-marker {
    display: none;
  }
  .cs-disclosure__summary:hover {
    color: var(--accent-light);
  }
  .cs-disclosure__summary:focus-visible {
    outline: 2px solid var(--accent-light);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }
  .cs-disclosure__icon {
    display: flex;
    align-items: center;
    transition: transform var(--dur) var(--ease);
  }
  .cs-disclosure[open] .cs-disclosure__icon {
    transform: rotate(180deg);
  }
  .cs-disclosure[open] .cs-disclosure__text::after {
    content: ' — collapse';
  }
  .cs-disclosure__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-top: var(--space-5);
  }

  .cs-blocks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-6) var(--space-8);
    margin: 0;
  }
  .cs-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .cs-block dt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ll);
    font-weight: 600;
  }
  .cs-block dd {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  @media (max-width: 600px) {
    .case-study {
      padding: var(--space-6);
    }
    .cs-name {
      font-size: 1.25rem;
    }
    .cs-blocks {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
