---
import Icon from '@components/ui/Icon.astro';
import { resolveIcon } from '@lib/icons';

interface Bullet {
  text: string;
  tier?: 'primary' | 'secondary';
}
interface Props {
  name: string;
  subtitle?: string;
  icon?: string;
  bullets: Bullet[];
  open?: boolean;
}
const { name, subtitle, icon, bullets, open = false } = Astro.props;
const iconName = resolveIcon(icon, 'folder');
---

<details class="proj-card" open={open}>
  <summary class="proj-header">
    <div class="proj-title-row">
      <div
        class="icon-tile icon-tile--compact icon-tile--round icon-tile--elev"
        aria-hidden="true"
      >
        <Icon name={iconName} size={18} />
      </div>
      <div>
        <div class="proj-name">{name}</div>
        {subtitle && <div class="proj-sub">{subtitle}</div>}
      </div>
    </div>
    <span class="proj-arrow" aria-hidden="true">
      <Icon name="chevron" size="xs" />
    </span>
  </summary>
  <div class="proj-inner">
    <ul class="bullet-list">
      {
        bullets.map((b) => (
          <li class:list={[{ 'is-secondary': b.tier === 'secondary' }]}>
            {b.text}
          </li>
        ))
      }
    </ul>
  </div>
</details>

<style>
  .proj-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .proj-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: no-preference) {
    .proj-card:hover {
      transform: translateY(var(--card-lift));
    }
  }
  .proj-header {
    padding: var(--space-5) var(--card-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--stack-sm);
    cursor: pointer;
    list-style: none;
  }
  .proj-header::-webkit-details-marker {
    display: none;
  }
  .proj-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .proj-name {
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--heading);
  }
  .proj-sub {
    font-size: var(--fs-xs);
    color: var(--text-muted);
    margin-top: 0.1rem;
  }
  .proj-arrow {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: transform var(--dur) var(--ease);
    flex-shrink: 0;
  }
  .proj-card[open] .proj-arrow {
    transform: rotate(180deg);
  }
  .proj-inner {
    padding: 0 var(--card-padding) var(--card-padding);
    border-top: 1px solid var(--border);
  }
  .proj-inner .bullet-list {
    margin-top: var(--space-3);
  }
  .is-secondary {
    color: var(--text-muted);
    font-size: var(--fs-base);
  }
</style>
