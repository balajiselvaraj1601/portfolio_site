---
import Icon from '@components/ui/Icon.astro';
import type { IconName } from '@lib/icons';

interface Step {
  label: string;
  icon: IconName;
  present: boolean;
}

interface Props {
  problem?: string;
  solution?: string;
  architecture?: string;
  businessImpact?: string;
}

const { problem, solution, architecture, businessImpact } = Astro.props;

// `satisfies` supplies the contextual type so each `icon` literal is checked
// against IconName (and stays narrowed) before `.filter` strips the type.
const steps = (
  [
    { label: 'Problem', icon: 'target', present: Boolean(problem) },
    { label: 'Data & Design', icon: 'layers', present: Boolean(solution) },
    { label: 'Platform', icon: 'blocks', present: Boolean(architecture) },
    { label: 'Impact', icon: 'chart', present: Boolean(businessImpact) },
  ] satisfies Step[]
).filter((s) => s.present);

const show = steps.length >= 2;
---

{
  show && (
    <div class="pipeline" aria-label="Project delivery pipeline">
      <ol class="pipeline__list">
        {steps.map((step, i) => (
          <li class="pipeline__step">
            <div class="pipeline__node">
              <Icon name={step.icon} size={18} />
            </div>
            <span class="pipeline__label">{step.label}</span>
            {i < steps.length - 1 && (
              <span class="pipeline__connector" aria-hidden="true">
                <Icon name="chevron-right" size="sm" />
              </span>
            )}
          </li>
        ))}
      </ol>
    </div>
  )
}

<style>
  .pipeline {
    padding: var(--space-4) var(--space-5);
    background: color-mix(in srgb, var(--accent-soft) 40%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .pipeline__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
  }
  .pipeline__step {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .pipeline__node {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elev);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
    flex-shrink: 0;
  }
  .pipeline__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .pipeline__connector {
    display: flex;
    align-items: center;
    color: var(--accent-light);
    opacity: 0.75;
    margin-left: var(--space-1);
  }
  @media (max-width: 640px) {
    .pipeline__list {
      flex-direction: column;
      align-items: flex-start;
    }
    .pipeline__connector {
      display: none;
    }
  }
</style>
