---
/**
 * ThemeCard — unified theme-card shell merging OrgSnapshotCard + ProgramBadgeCard.
 *
 * Resolves DG-006: both originals shared ~85% of markup/CSS. This component is the
 * SSOT for all `.theme-card.card` surfaces in the Vision board sections.
 *
 * Prop guide:
 *   title    — card heading (always rendered as h3)
 *   lines[]  — body content; if label is set these render as a list, else joined as prose
 *   mark     — VisionMark (pipeline logo_* or icon) passed to CardMark emblem mode
 *   slug     — entity slug; triggers logo-file lookup (logoSrc). When a file exists and
 *               !logoHasOwnRing, renders a rect logo badge instead of the emblem circle.
 *   altText  — alt text for logo image (falls back to title)
 *   label    — mono kicker above the lines list (program cards only)
 *   entity   — entity slug for EntityLink wrapping the title (program cards only)
 *   logoSlug — optional override for logo file lookup (entity slug fallback)
 *   markDisplay — 'rect' forces uniform white logo-badge box (vision program cards)
 */
import CardMark from '@components/ui/CardMark.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { getEntityUrl, logoSrc } from '@lib/content';
import { logoHasOwnRing } from '@lib/logo-display';
import type { VisionMark } from '@schemas';

interface Props {
  title: string;
  lines: string[];
  mark?: VisionMark;
  slug?: string;
  altText?: string;
  label?: string;
  entity?: string;
  logoSlug?: string;
  markDisplay?: 'auto' | 'rect';
}

const {
  title,
  lines,
  mark,
  slug,
  altText,
  label,
  entity,
  logoSlug,
  markDisplay = 'auto',
} = Astro.props;

// Logo resolution: prefer rect logo when a file asset exists and has no self-ring.
// Self-ringed pipeline logo_* assets are handled via emblem mode (mark prop).
// Vision program cards pass markDisplay='rect' to always use the white logo-badge box.
const lookupSlug = logoSlug ?? slug;
let resolvedLogoUrl = lookupSlug ? logoSrc(lookupSlug) : undefined;
if (!resolvedLogoUrl && mark?.kind === 'logo') {
  resolvedLogoUrl = logoSrc(mark.asset);
}
if (!resolvedLogoUrl && slug) {
  resolvedLogoUrl = logoSrc(slug);
}

const usesRectLogo =
  markDisplay === 'rect'
    ? Boolean(resolvedLogoUrl)
    : Boolean(
        resolvedLogoUrl &&
        !logoHasOwnRing(
          lookupSlug ?? slug ?? (mark?.kind === 'logo' ? mark.asset : undefined)
        )
      );
const rectLogoSlug =
  lookupSlug ?? (mark?.kind === 'logo' ? mark.asset : undefined) ?? slug;
---

<article class="theme-card card">
  {
    usesRectLogo ? (
      <div class="program-card__mark" aria-hidden="true">
        <CardMark
          slug={rectLogoSlug}
          logoUrl={resolvedLogoUrl}
          altText={altText ?? title}
          class="program-card__logo"
        />
      </div>
    ) : (
      mark && <CardMark mark={mark} context="theme-card" emblemInCircle />
    )
  }
  <h3 class="theme-card__title">
    {entity ? <EntityLink href={getEntityUrl(entity)} label={title} /> : title}
  </h3>
  {
    label ? (
      <>
        <p class="program-card__label">{label}</p>
        <ul class="program-card__lines">
          {lines.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      </>
    ) : (
      <p class="theme-card__desc">{lines.join(' ')}</p>
    )
  }
</article>

<style>
  /* Rect logo wrapper (program cards with entity logo files) */
  .program-card__mark {
    margin-bottom: var(--text-gap-inline);
  }
  .program-card__logo {
    width: fit-content;
    max-width: 100%;
  }

  /* Program label kicker (mono, uppercase) */
  .program-card__label {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
    margin: var(--text-gap-pair) 0 0;
    max-width: none;
  }

  /* Program bullet list */
  .program-card__lines {
    list-style: none;
    margin: var(--text-gap-inline) 0 0;
    padding: 0;
    display: grid;
    gap: var(--text-gap-pair);
  }
  .program-card__lines li {
    font-size: var(--fs-base);
    color: var(--text-muted);
    line-height: var(--lh-relaxed);
    overflow-wrap: break-word;
  }
</style>
