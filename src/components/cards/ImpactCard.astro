---
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { resolveIcon, type IconName } from '@lib/icons';
import { getEntityUrl } from '@lib/content';

interface Props {
  title: string;
  icon: string;
  tag: string;
  tagVariant?: 'purple' | 'red';
  cardVariant?: 'purple' | 'red';
  bullets: string[];
  entity?: string;
}
const {
  title,
  icon,
  tag,
  tagVariant = 'red',
  cardVariant = 'purple',
  bullets,
  entity,
} = Astro.props;
const iconName = resolveIcon(icon, 'target') as IconName;
---

<article class:list={['impact-card', 'card', cardVariant === 'red' ? 'card--red' : 'card--accent']}>
  <div class="impact-card__head">
    <div class:list={['ic-icon', { red: cardVariant === 'red' }]} aria-hidden="true">
      <Icon name={iconName} size={22} />
    </div>
    <div>
      <h3>
        <EntityLink href={getEntityUrl(entity)} label={title} />
      </h3>
      <span class:list={['backed-tag', { 'backed-tag--purple': tagVariant === 'purple' }]}>{tag}</span>
    </div>
  </div>
  <ul class="bullet-list">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
</article>

<style>
  .impact-card {
    padding: var(--card-padding-lg);
  }
  .impact-card__head {
    display: flex;
    align-items: center;
    gap: var(--stack-sm);
    margin-bottom: 1.25rem;
  }
  .ic-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    flex-shrink: 0;
    color: var(--accent-ll);
  }
  .ic-icon.red {
    background: var(--accent-red-soft);
    border-color: rgba(192, 24, 42, 0.4);
    color: var(--accent-red-light);
  }
  .impact-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.15rem;
  }
  .backed-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-red-light);
    background: var(--accent-red-soft);
    border: 1px solid rgba(192, 24, 42, 0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .backed-tag--purple {
    color: var(--accent-ll);
    background: var(--accent-soft);
    border-color: var(--border-strong);
  }
</style>
