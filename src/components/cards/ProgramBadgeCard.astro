---
/**
 * ProgramBadgeCard — Strategic Impact Program Showcase
 *
 * Renders a program badge card within the Vision page hub structure. Each card
 * displays the program title, label, key bullet lines, and an icon or logo badge.
 *
 * Props are derived from the VisionBoard schema's programs array — a discriminated
 * union where badge can be either an icon or a logo asset. The component narrows
 * the union based on badge.kind to cleanly resolve URLs only for the 'logo' branch.
 */

import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { getEntityUrl, logoSrc } from '@lib/content';
import type { VisionBoard } from '@schemas';

// `programs` is optional on the schema, so unwrap with NonNullable before indexing.
type Program = NonNullable<VisionBoard['programs']>[number];

interface Props {
  title: string;
  label: string;
  variant: Program['variant'];
  badge: Program['badge'];
  lines: string[];
  entity?: string;
}

const { title, label, variant, badge, lines, entity } = Astro.props;

// `badge` is a VisionMark discriminated union; resolve the logo URL only on the
// 'logo' branch so the template narrows cleanly by `kind`.
const badgeLogo = badge.kind === 'logo' ? logoSrc(badge.asset) : undefined;
---

<article class:list={['pcard', `pcard--${variant}`]}>
  <header class="pcard__head">
    <h3 class="pcard__title">
      <EntityLink
        href={getEntityUrl(entity)}
        label={title}
        class="pcard__title-link"
      />
    </h3>
    <p class="pcard__label">{label}</p>
  </header>

  <ul class="pcard__lines">
    {lines.map((line) => <li>{line}</li>)}
  </ul>

  <div
    class:list={[
      'pcard__badge',
      { 'pcard__badge--logo': badge.kind === 'logo' },
    ]}
    aria-hidden="true"
  >
    {
      badge.kind === 'icon' ? (
        <Icon name={badge.name} size={44} />
      ) : badgeLogo ? (
        <img src={badgeLogo} alt={badge.alt ?? ''} loading="lazy" />
      ) : null
    }
  </div>
</article>

<style>
  .pcard {
    --pc: var(--accent);
    --pc-soft: var(--accent-soft);
    position: relative;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding-bottom: var(--space-5);
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .pcard--red {
    --pc: var(--accent-red);
    --pc-soft: var(--accent-red-soft);
  }
  .pcard:hover {
    border-color: var(--pc);
    transform: translateY(var(--card-lift));
    box-shadow: var(--shadow-md);
  }
  .pcard__head {
    background: var(--pc);
    color: var(--accent-contrast);
    padding: var(--space-4) 7.5rem var(--space-4) var(--space-5);
  }
  .pcard__title {
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: var(--accent-contrast);
  }
  .pcard__title :global(.pcard__title-link) {
    color: var(--accent-contrast);
  }
  .pcard__title :global(.pcard__title-link:hover) {
    color: var(--accent-contrast);
    opacity: 0.92;
  }
  .pcard__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0.35rem 0 0;
    opacity: 0.92;
  }
  .pcard__lines {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0 var(--space-5);
    display: grid;
    gap: 0.4rem;
  }
  .pcard__lines li {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .pcard__badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    width: 104px;
    height: 104px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--bg-elev);
    border: 4px solid var(--pc);
    color: var(--pc);
    box-shadow: 0 18px 32px -8px color-mix(in srgb, var(--pc) 50%, transparent);
  }
  .pcard__badge img {
    width: var(--logo-emblem-img);
    height: var(--logo-emblem-img);
    object-fit: contain;
  }
  .pcard__badge--logo img {
    width: auto;
    height: auto;
    max-width: 68%;
    max-height: 68%;
  }
  @media (max-width: 520px) {
    .pcard__head {
      padding-right: var(--space-5);
    }
    .pcard__badge {
      position: static;
      margin: var(--space-4) var(--space-5) 0;
    }
  }
</style>
