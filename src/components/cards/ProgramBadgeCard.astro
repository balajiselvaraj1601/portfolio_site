---
/**
 * ProgramBadgeCard — Strategic Impact Program Showcase
 *
 * Renders a program badge card within the Vision page hub structure. Each card
 * displays the program title, label, key bullet lines, and an icon or logo badge.
 *
 * Props are derived from the VisionBoard schema's programs array — a discriminated
 * union where badge can be either an icon or a logo asset. The component narrows
 * the union based on badge.kind to cleanly resolve URLs only for the 'logo' branch.
 */

import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { getEntityUrl, logoSrc } from '@lib/content';
import type { VisionBoard } from '@schemas';

// `programs` is optional on the schema, so unwrap with NonNullable before indexing.
type Program = NonNullable<VisionBoard['programs']>[number];

interface Props {
  title: string;
  label: string;
  variant: Program['variant'];
  badge: Program['badge'];
  lines: string[];
  entity?: string;
}

const { title, label, variant, badge, lines, entity } = Astro.props;

// `badge` is a VisionMark discriminated union; resolve the logo URL only on the
// 'logo' branch so the template narrows cleanly by `kind`.
const badgeLogo = badge.kind === 'logo' ? logoSrc(badge.asset) : undefined;
---

<article
  class:list={[
    'pcard',
    'card',
    'card--top-accent',
    `pcard--${variant}`,
    { 'pcard--has-logo': badge.kind === 'logo' },
  ]}
>
  <header class="pcard__head">
    <h3 class="pcard__title">
      <EntityLink
        href={getEntityUrl(entity)}
        label={title}
        class="pcard__title-link"
      />
    </h3>
    <p class="pcard__label">{label}</p>
  </header>

  <ul class="pcard__lines">
    {lines.map((line) => <li>{line}</li>)}
  </ul>

  <div
    class:list={[
      'pcard__badge',
      { 'pcard__badge--logo': badge.kind === 'logo' },
    ]}
    aria-hidden="true"
  >
    {
      badge.kind === 'icon' ? (
        <Icon name={badge.name} size={44} />
      ) : badgeLogo ? (
        <img src={badgeLogo} alt={badge.alt ?? ''} loading="lazy" />
      ) : null
    }
  </div>
</article>

<style>
  .pcard {
    --accent-card: var(--accent);
    position: relative;
    padding-bottom: var(--space-5);
  }
  .pcard--red {
    --accent-card: var(--accent-red);
  }
  .pcard:hover {
    border-color: var(--accent-card);
  }
  .pcard__head {
    padding: var(--space-4) 8.75rem var(--space-3) var(--space-5);
    min-height: 5.5rem;
  }
  .pcard--has-logo .pcard__head {
    padding-right: 11.5rem;
  }
  .pcard__title {
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    color: var(--heading);
    overflow-wrap: normal;
    word-break: keep-all;
  }
  .pcard__title :global(.pcard__title-link) {
    color: var(--heading);
  }
  .pcard__title :global(.pcard__title-link:hover) {
    color: var(--accent-light);
  }
  .pcard__label {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0.35rem 0 0;
    color: var(--accent-ll);
  }
  .pcard--red .pcard__label {
    color: var(--accent-red-light);
  }
  .pcard__lines {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0 var(--space-5);
    display: grid;
    gap: 0.4rem;
  }
  .pcard__lines li {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .pcard__badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    width: 104px;
    height: 104px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
    box-shadow: var(--shadow-sm);
  }
  .pcard--red .pcard__badge {
    background: var(--accent-red-soft);
    color: var(--accent-red-light);
  }
  .pcard__badge--logo {
    background: var(--logo-surface);
    width: auto;
    min-width: 96px;
    max-width: 148px;
    height: 52px;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    border-color: color-mix(in srgb, var(--accent-card) 35%, var(--border));
  }
  .pcard__badge img {
    width: var(--logo-emblem-img);
    height: var(--logo-emblem-img);
    object-fit: contain;
  }
  .pcard__badge--logo img {
    width: auto;
    height: auto;
    max-width: 128px;
    max-height: 32px;
  }
  @media (max-width: 520px) {
    .pcard__head {
      padding-right: var(--space-5);
    }
    .pcard__badge {
      position: static;
      margin: var(--space-4) var(--space-5) 0;
    }
  }
</style>
