---
import CardMark from '@components/ui/CardMark.astro';
import { logoSrc } from '@lib/content';
import { youtubeId } from '@lib/youtube';
import type { Speakers } from '@schemas';

type Item = Speakers['items'][number];

interface Props {
  item: Item;
}

const { item } = Astro.props;
const logoUrl = logoSrc(item.logo);

const ytId = youtubeId(item.youtube);
const ytThumb = ytId
  ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg`
  : null;
const hasModernImage = Boolean(item.imageWebp || item.imageAvif);
---

<article class="speaking-card content-card card-accent">
  <header class="speaking-card__head">
    {
      logoUrl ? (
        <CardMark
          slug={item.logo}
          logoUrl={logoUrl}
          altText={`${item.event} logo`}
          useBadge={item.logoBadge}
          class="speaking-card__mark"
        />
      ) : (
        <CardMark
          iconFallback="presentation"
          variant="accented"
          class="speaking-card__mark"
        />
      )
    }
    <div class="speaking-card__meta">
      <span class="speaking-card__role">{item.role}</span>
      <strong class="speaking-card__event">{item.event}</strong>
    </div>
    <div class="speaking-card__when">
      <span class="speaking-card__location">{item.location}</span>
      <time class="speaking-card__date" datetime={item.dateSort ?? item.date}
        >{item.date}</time
      >
    </div>
  </header>

  <h3 class="speaking-card__title">
    <a href={item.url} target="_blank" rel="noopener noreferrer"
      >{item.title}<span class="visually-hidden">
        (opens in new window)</span
      ></a
    >
  </h3>
  {item.description && <hr class="speaking-card__divider" aria-hidden="true" />}
  {item.description && <p class="speaking-card__desc">{item.description}</p>}

  {
    ytThumb && item.youtube && (
      <a
        class="speaking-card__media speaking-card__media--video"
        href={item.youtube}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Watch ${item.title} on YouTube (opens in new window)`}
      >
        <img
          src={ytThumb}
          alt={`Video thumbnail: ${item.title}`}
          width={480}
          height={360}
          loading="lazy"
        />
        <span class="speaking-card__play" aria-hidden="true">
          <svg viewBox="0 0 68 48" width="68" height="48" focusable="false">
            <path
              class="speaking-card__play-bg"
              d="M66.52 7.74c-.78-2.93-2.94-5.41-5.73-6.19C55.79.13 34 0 34 0S12.21.13 6.21 1.55C3.42 2.33 1.26 4.81.48 7.74.06 9.4 0 11.02 0 12.54s.06 3.14.48 4.8c.78 2.93 2.94 5.41 5.73 6.19C12.21 24.87 34 25 34 25s21.79-.13 27.79-1.47c2.79-.78 4.95-3.26 5.73-6.19.42-1.66.48-3.22.48-4.8s-.06-3.14-.48-4.8z"
            />
            <path class="speaking-card__play-icon" d="M 45,24 27,14 27,34" />
          </svg>
        </span>
      </a>
    )
  }

  {
    item.image && (
      <div class="speaking-card__media">
        {hasModernImage ? (
          <picture>
            {item.imageAvif && (
              <source srcset={item.imageAvif} type="image/avif" />
            )}
            {item.imageWebp && (
              <source srcset={item.imageWebp} type="image/webp" />
            )}
            <img
              src={item.image}
              alt={`${item.event} — ${item.title}`}
              width={640}
              height={360}
              loading="lazy"
            />
          </picture>
        ) : (
          <img
            src={item.image}
            alt={`${item.event} — ${item.title}`}
            width={640}
            height={360}
            loading="lazy"
          />
        )}
      </div>
    )
  }
</article>

<style>
  .speaking-card {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
  }

  .speaking-card__head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-3) var(--stack-sm);
    align-items: start;
  }

  .speaking-card__mark {
    flex-shrink: 0;
  }

  .speaking-card__meta {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-pair);
    min-width: 0;
  }

  .speaking-card__role {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
  }

  .speaking-card__event {
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
    color: var(--heading);
  }

  .speaking-card__when {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--text-gap-pair);
    flex-shrink: 0;
    min-width: max-content;
    text-align: right;
  }

  .speaking-card__location {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .speaking-card__date {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-muted);
    white-space: nowrap;
    line-height: var(--lh-normal);
  }

  .speaking-card__title {
    font-family: var(--font-sans);
    font-size: var(--fs-card-title);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-normal);
    margin: 0;
  }

  .speaking-card__title a {
    color: var(--heading);
    text-decoration: none;
  }

  .speaking-card__title a:hover {
    color: var(--accent-light);
  }

  .speaking-card__divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  .speaking-card__desc {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    line-height: var(--lh-relaxed);
    margin: 0;
    max-width: none;
  }

  .speaking-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--overlay-scrim);
  }

  .speaking-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .speaking-card__media--video {
    display: block;
    text-decoration: none;
  }

  .speaking-card__media--video:hover .speaking-card__play-bg {
    fill: var(--overlay-play-mark);
  }

  .speaking-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .speaking-card__play-bg {
    fill: var(--overlay-scrim-soft);
    transition: fill var(--dur) var(--ease);
  }

  .speaking-card__play-icon {
    fill: var(--overlay-play);
  }
</style>
