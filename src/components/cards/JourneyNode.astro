---
import Icon from '@components/ui/Icon.astro';
import type { Impact } from '@schemas';

type Props = NonNullable<Impact['journey']>[number];

const { icon, label, description, variant = 'purple' } = Astro.props;
---

<div class="journey-node">
  <div class:list={['journey-icon', variant]} aria-hidden="true">
    <Icon name={icon} size={28} />
  </div>
  <div>
    <div class="journey-label">{label}</div>
    <p class="journey-desc">{description}</p>
  </div>
</div>

<style>
  .journey-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }
  .journey-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--border-strong);
    background: var(--bg-chip);
    color: var(--accent-ll);
  }
  .journey-icon.purple {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .journey-icon.red {
    border-color: var(--accent-red);
    background: var(--accent-red-soft);
    color: var(--accent-red-light);
  }
  .journey-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-ll);
  }
  .journey-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
    max-width: none;
    line-height: 1.4;
  }
</style>
