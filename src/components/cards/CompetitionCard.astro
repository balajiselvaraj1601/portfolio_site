---
import Icon from '@components/ui/Icon.astro';
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import RecogCardShell from '@components/ui/RecogCardShell.astro';
import { competitionIcon, resolveIcon } from '@lib/icons';
import type { IconName } from '@lib/icons';
import type { KaggleCompetition } from '@schemas';
import { medalClass } from '@lib/recognition';
import { logoSrc } from '@lib/content';

type Props = KaggleCompetition;

const {
  id,
  icon,
  logo,
  name,
  url,
  role,
  medal,
  rank,
  percentile,
  period,
  summary,
  evaluationMetric,
  domain,
  tags,
  stats,
} = Astro.props;

const headerIcon = resolveIcon(icon, competitionIcon(id, domain));

// Total Entrants is DERIVED from stats.entrants — single source of truth, never
// a separate content field.
const totalEntrants = stats?.entrants;

const medalCls = medalClass(medal);

// Fixed stat row mirroring the reference layout. Entries with no value drop out.
// img slugs are logo_metric_kaggle_* (pipeline SVGs for MarkEmblem tinting — D5/TC2).
// Icon fallback covers the gap while SVG assets are generated (BC5).
const stats6: { icon: IconName; img: string; label: string; value?: string }[] =
  [
    {
      icon: 'target',
      img: 'logo_metric_kaggle_role',
      label: 'Role',
      value: role,
    },
    {
      icon: 'trophy',
      img: 'logo_metric_kaggle_medal',
      label: 'Medal',
      value: medal,
    },
    {
      icon: 'chart',
      img: 'logo_metric_kaggle_rank',
      label: 'Rank',
      value: rank,
    },
    {
      icon: 'diamond',
      img: 'logo_metric_kaggle_percentile',
      label: 'Percentile',
      value: percentile,
    },
    {
      icon: 'calendar',
      img: 'logo_metric_kaggle_time_period',
      label: 'Period',
      value: period,
    },
    {
      icon: 'team',
      img: 'logo_metric_kaggle_entrants',
      label: 'Total Entrants',
      value: totalEntrants,
    },
  ];
const visibleStats = stats6.filter((s) => s.value);

// Slugs for summary/eval block icons (logo_* → MarkEmblem; Icon fallback per BC5).
const summarySlug = 'logo_metric_kaggle_summary';
const evalSlug = 'logo_metric_kaggle_evaluation';
---

<RecogCardShell
  class:list={[medalCls]}
  data-medal={medal}
  data-name={name}
  data-domain={domain}
  data-tags={(tags ?? []).join(' ')}
>
  <Fragment slot="headTop">
    <div
      class="icon-tile icon-tile--round icon-tile--accented"
      aria-hidden="true"
    >
      {
        /* logo_* slugs are pipeline SVGs → MarkEmblem (medal-tinted glyph, D5).
           Non-logo_* slugs are org PNG rasters → .comp-image cover-fill.
           Neither resolves → Lucide <Icon> fallback (BC5). */
        logo && logo.startsWith('logo_') && logoSrc(logo) ? (
          <MarkEmblem mark={{ kind: 'logo', asset: logo }} />
        ) : logo && logoSrc(logo) ? (
          <img src={logoSrc(logo)} alt="" class="comp-image" />
        ) : (
          <Icon name={headerIcon} size="lg" />
        )
      }
    </div>
  </Fragment>
  <h3 slot="title" class="recog-title recog-clamp" style="--clamp: 2">
    <a href={url} target="_blank" rel="noopener noreferrer"
      >{name}<span class="visually-hidden"> (opens in new window)</span></a
    >
  </h3>

  <dl class="blob-stats">
    {
      visibleStats.map((s) => (
        <div class="blob-stat">
          <span class="blob-stat__icon" aria-hidden="true">
            {logoSrc(s.img) ? (
              <span class="blob-icon--md">
                <MarkEmblem mark={{ kind: 'logo', asset: s.img }} />
              </span>
            ) : (
              <Icon name={s.icon} size="sm" />
            )}
          </span>
          <dt class="recog-label">{s.label}</dt>
          <dd class="recog-value">{s.value}</dd>
        </div>
      ))
    }
  </dl>

  {
    summary && (
      <div class="blob-block">
        <div class="blob-block__head">
          <span class="blob-block__icon" aria-hidden="true">
            {logoSrc(summarySlug) ? (
              <span class="blob-icon--sm">
                <MarkEmblem mark={{ kind: 'logo', asset: summarySlug }} />
              </span>
            ) : (
              <Icon name="target" size={16} />
            )}
          </span>
          <span class="blob-block__label recog-label">Summary</span>
        </div>
        <p class="blob-block__body recog-body recog-clamp" style="--clamp: 3">
          {summary}
        </p>
      </div>
    )
  }

  {
    evaluationMetric && (
      <Fragment slot="footer">
        <div class="blob-block blob-block--eval">
          <div class="blob-block__head">
            <span class="blob-block__icon" aria-hidden="true">
              {logoSrc(evalSlug) ? (
                <span class="blob-icon--sm">
                  <MarkEmblem mark={{ kind: 'logo', asset: evalSlug }} />
                </span>
              ) : (
                <Icon name="pulse" size={16} />
              )}
            </span>
            <span class="blob-block__label recog-label">Evaluation Metric</span>
          </div>
          <p class="blob-block__body recog-body">{evaluationMetric}</p>
        </div>
      </Fragment>
    )
  }
</RecogCardShell>

<style>
  .comp-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  /* Medal accent — drives border, icon tint, and stat dividers. Maps to the
     shared --medal-* tokens (theme tuning lives once in global.css). */
  .blob--silver {
    --medal: var(--medal-silver);
  }
  .blob--bronze {
    --medal: var(--medal-bronze);
  }

  /* One-accent-per-view: Recognition uses a single hue (gold). Override the
     per-medal --medal so competition cards match the rest of the view. */
  :global(.recog-card.blob--silver),
  :global(.recog-card.blob--bronze) {
    --accent-card: var(--view-accent-recognition);
    --mark-fg: var(--accent-card);
  }

  /* ── Stat grid ──────────────────────────────────────────────────── */
  .blob-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .blob-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--text-gap-pair);
    padding: var(--space-3) var(--space-2);
    background: var(--bg-elev);
  }
  .blob-stat__icon {
    color: var(--medal);
    display: flex;
  }
  /* Sized wrappers for MarkEmblem in bare-span icon contexts (TC2 binding sizes).
     MarkEmblem's own width:100%/height:100% fills these fixed containers. */
  .blob-icon--md {
    width: var(--icon-md); /* 20px — .blob-stat__icon primary stats (TC2) */
    height: var(--icon-md);
    display: flex;
    flex-shrink: 0;
  }
  .blob-icon--sm {
    width: var(--icon-sm); /* 16px — .blob-block__icon summary/eval (TC2) */
    height: var(--icon-sm);
    display: flex;
    flex-shrink: 0;
  }
  .blob-stat dd {
    margin: 0;
  }

  /* ── Summary / Evaluation blocks ────────────────────────────────── */
  .blob-block {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
  }
  /* Pin the Evaluation Metric block to the bottom so every card's footer aligns
     regardless of summary length — the engine of equal-height blob cards. */
  .blob-block--eval {
    margin-top: auto;
  }
  .blob-block__head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .blob-block__icon {
    color: var(--accent-card, var(--medal));
    display: flex;
  }
  .blob-block__body {
    margin: 0;
    max-width: none;
  }
  @media (max-width: 600px) {
    :global(.recog-card) {
      padding: var(--card-padding);
    }
  }
</style>
