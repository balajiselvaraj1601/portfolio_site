---
import Icon from '@components/ui/Icon.astro';
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import RecogCardShell from '@components/ui/RecogCardShell.astro';
import CompetitionStats from '@components/cards/competition/CompetitionStats.astro';
import CompetitionBlock from '@components/cards/competition/CompetitionBlock.astro';
import { competitionIcon, resolveIcon } from '@lib/icons';
import type { KaggleCompetition } from '@schemas';
import { medalClass } from '@lib/recognition';
import { logoSrc } from '@lib/content';

type Props = KaggleCompetition;

const {
  id,
  icon,
  logo,
  name,
  url,
  role,
  medal,
  rank,
  percentile,
  period,
  summary,
  evaluationMetric,
  domain,
  tags,
  stats,
} = Astro.props;

const headerIcon = resolveIcon(icon, competitionIcon(id, domain));

const medalCls = medalClass(medal);

// Slugs for summary/eval block icons (logo_* → MarkEmblem; Icon fallback per BC5).
const summarySlug = 'logo_metric_kaggle_summary';
const evalSlug = 'logo_metric_kaggle_evaluation';
---

<RecogCardShell
  class:list={[medalCls]}
  collapsible
  detailsId={`kaggle-details-${id}`}
  data-medal={medal}
  data-name={name}
  data-domain={domain}
  data-tags={(tags ?? []).join(' ')}
>
  <Fragment slot="headTop">
    <div
      class="icon-tile icon-tile--round icon-tile--accented"
      aria-hidden="true"
    >
      {
        /* logo_* slugs are pipeline SVGs → MarkEmblem (medal-tinted glyph, D5).
           Non-logo_* slugs are org PNG rasters → .comp-image cover-fill.
           Neither resolves → Lucide <Icon> fallback (BC5). */
        logo && logo.startsWith('logo_') && logoSrc(logo) ? (
          <MarkEmblem mark={{ kind: 'logo', asset: logo }} />
        ) : logo && logoSrc(logo) ? (
          <img src={logoSrc(logo)} alt="" class="comp-image" />
        ) : (
          <Icon name={headerIcon} />
        )
      }
    </div>
  </Fragment>
  <h3 slot="title" class="recog-title recog-clamp" style="--clamp: 2">
    <a href={url} target="_blank" rel="noopener noreferrer"
      >{name}<span class="visually-hidden"> (opens in new window)</span></a
    >
  </h3>

  <CompetitionStats
    role={role}
    medal={medal}
    rank={rank}
    percentile={percentile}
    period={period}
    stats={stats}
  />

  {
    summary && (
      <CompetitionBlock
        slug={summarySlug}
        fallbackIcon="target"
        label="Summary"
        clamp={3}
        body={summary}
      />
    )
  }

  {
    evaluationMetric && (
      <Fragment slot="footer">
        <CompetitionBlock
          slug={evalSlug}
          fallbackIcon="pulse"
          label="Evaluation Metric"
          clamp={2}
          body={evaluationMetric}
          isEval
        />
      </Fragment>
    )
  }
</RecogCardShell>

<style>
  .comp-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  /* Medal accent — drives border, icon tint, and stat dividers. Maps to the
     shared --medal-* tokens (theme tuning lives once in global.css). Consumed
     by the extracted stat grid / blocks via custom-property inheritance. */
  .blob--silver {
    --medal: var(--medal-silver);
  }
  .blob--bronze {
    --medal: var(--medal-bronze);
  }

  /* Multi-color per view: competition cards read each item's per-medal --medal so
     silver and bronze show their own hue, falling back to the Recognition accent
     (gold) when a card has no medal class. */
  :global(.recog-card.blob--silver),
  :global(.recog-card.blob--bronze) {
    --accent-card: var(--medal, var(--view-accent-recognition));
    --mark-fg: var(--accent-card);
  }

  /* ── Standardized region heights ────────────────────────────────────
     Reserve a fixed line-height per region so every element lands at the
     same Y across all cards — titles, stat rows, summaries and eval metrics
     align box-to-box regardless of copy length. Uses the shared --lh-* tokens
     as the single source of truth (no magic px). Scoped to this component, so
     Awards/Education (same RecogCardShell + .recog-* classes) are untouched. */

  /* Title: always occupy 2 lines (recog-clamp caps the max at 2). */
  .recog-title {
    min-height: calc(2 * var(--lh-snug) * 1em);
  }

  @media (max-width: 560px) /* --bp-sm */ {
    :global(.recog-card) {
      padding: var(--card-padding);
    }
  }

  /* Dark mode: boost per-medal prominence (mirrors Awards). */
  :global(:root[data-theme='dark']) :global(.recog-card.blob--silver),
  :global(:root[data-theme='dark']) :global(.recog-card.blob--bronze) {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--medal) 12%, var(--bg-elev)),
      color-mix(in srgb, var(--medal) 4%, var(--bg-elev))
    );
    border-color: color-mix(in srgb, var(--medal) 45%, var(--border));
    border-top-width: 3px;
  }
</style>
