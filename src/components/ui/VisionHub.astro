---
/**
 * VisionHub — radial hub-and-spoke diagram for a Vision board group.
 * A faint outer ring frames a central brand mark, six satellite marks orbit it,
 * and dotted spokes bridge the gap between the centre and each satellite.
 * All marks are resolved from existing icons/logos via Icon + MarkEmblem.
 */
import Icon from '@components/ui/Icon.astro';
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import type { VisionBoard } from '@schemas';

// All vision-board marks are now logo_* SVGs rendered via MarkEmblem (TC5 gate met
// 2026-07-04: icon_*.png deleted, screenshots confirmed zero raster nodes).

type VisionGroup = VisionBoard['groups'][number];

interface Props {
  group: VisionGroup;
}

const { group } = Astro.props;

// Radial geometry — orbit in cqi (1cqi = 1% of the square stage width).
// Node/center diameters derive from --mark-slot on .vision-hub__stage (global.css).
const ORBIT = 36; // centre → satellite distance
const count = group.marks.length;

// Pre-compute each satellite's offset + spoke angle so the CSS stays trig-free.
const nodes = group.marks.map((mark, i) => {
  const angle = (2 * Math.PI * i) / count - Math.PI / 2; // start at 12 o'clock
  return {
    mark,
    tx: +(Math.cos(angle) * ORBIT).toFixed(3),
    ty: +(Math.sin(angle) * ORBIT).toFixed(3),
    rot: +((360 * i) / count - 90).toFixed(3),
  };
});
---

<figure class="vision-hub">
  <div class="vision-hub__stage" style={`--orbit:${ORBIT}cqi`}>
    <div class="vision-hub__ring" aria-hidden="true"></div>

    {
      nodes.map((n) => (
        <span
          class="vision-hub__spoke"
          style={`--rot:${n.rot}deg`}
          aria-hidden="true"
        />
      ))
    }

    <div class="vision-hub__center">
      {
        group.lead.kind === 'icon' ? (
          <Icon name={group.lead.name} size="md" />
        ) : (
          <MarkEmblem mark={group.lead} class="vision-hub__lead" />
        )
      }
    </div>

    {
      nodes.map((n) => (
        <span
          class="vision-hub__node"
          style={`--tx:${n.tx}cqi;--ty:${n.ty}cqi`}
        >
          <MarkEmblem mark={n.mark} />
        </span>
      ))
    }
  </div>

  <div class="vision-hub__below">
    <div class="vision-hub__rule" aria-hidden="true">
      <span class="vision-hub__rule-line"></span>
      <span class="vision-hub__rule-dot"></span>
      <span class="vision-hub__rule-line"></span>
    </div>

    <figcaption class="vision-hub__label">{group.label}</figcaption>
  </div>
</figure>

<style>
  .vision-hub {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    /* Reserve space for rule + label below the stage (out-of-flow footer). */
    margin-bottom: var(--vision-hub-footer-h);
  }

  .vision-hub__stage {
    container-type: inline-size;
    position: relative;
    width: 100%;
    max-width: var(--vision-hub-max);
    aspect-ratio: 1;
    /* Hub node/center circles track --mark-slot at reference hub width */
    --vision-hub-node: calc(100cqi * var(--mark-slot) / var(--vision-hub-max));
    --vision-hub-center: var(--vision-hub-node);
    /* Glyph scales with node so the fill ratio holds at every hub width
       (~64% at reference, from --vision-mark-glyph 28px / --mark-slot 44px) */
    --vision-hub-glyph: calc(
      var(--vision-hub-node) * var(--vision-mark-glyph) / var(--mark-slot)
    );
    --spoke-start: calc(var(--vision-hub-center) / 2);
    --spoke-len: calc(var(--orbit) - var(--vision-hub-node));
  }

  /* Outer circle — bright purple ring, echoing the reference (no glow). */
  .vision-hub__ring {
    position: absolute;
    inset: 4%;
    border-radius: 50%;
    border: 2px solid
      color-mix(in srgb, var(--accent-card, var(--accent)) 55%, transparent);
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--accent-card, var(--accent)) 14%, transparent) 0%,
      transparent 64%
    );
    z-index: 1;
  }

  .vision-hub__center {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--vision-hub-center);
    height: var(--vision-hub-center);
    transform: translate(-50%, -50%);
    z-index: 2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .vision-hub__center :global(.icon),
  .vision-hub__center :global(.vision-hub__lead) {
    width: var(--vision-hub-glyph);
    height: var(--vision-hub-glyph);
  }
  .vision-hub__node {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--vision-hub-node);
    height: var(--vision-hub-node);
    transform: translate(-50%, -50%) translate(var(--tx), var(--ty));
    z-index: 2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .vision-hub__node :global(.mark-emblem),
  .vision-hub__node :global(.icon) {
    width: var(--vision-hub-glyph);
    height: var(--vision-hub-glyph);
  }

  /* Dotted spoke bridging centre-ring edge → satellite-ring edge. */
  .vision-hub__spoke {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--spoke-len);
    height: 0;
    border-top: 2px dotted
      color-mix(in srgb, var(--accent-card, var(--accent)) 45%, transparent);
    transform-origin: 0 0;
    transform: rotate(var(--rot)) translateX(var(--spoke-start));
    z-index: 1;
  }

  .vision-hub__below {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .vision-hub__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 62%;
    max-width: 220px;
  }

  .vision-hub__rule-line {
    flex: 1;
    height: 1px;
    background: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 40%,
      transparent
    );
  }

  .vision-hub__rule-dot {
    width: calc(var(--space-1) + var(--space-0-5));
    height: calc(var(--space-1) + var(--space-0-5));
    border-radius: 50%;
    background: var(--mark-fg);
    flex-shrink: 0;
  }

  .vision-hub__label {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mark-fg);
    margin: 0;
  }

  @media (max-width: 480px) {
    .vision-hub__stage {
      max-width: 300px;
    }
  }
</style>
