---
/**
 * VisionHub — radial hub-and-spoke diagram for a Vision board group.
 * A faint outer ring frames a central brand mark, six satellite marks orbit it,
 * and dotted spokes bridge the gap between the centre and each satellite.
 * All marks are resolved from existing icons/logos via Icon + MarkEmblem.
 */
import Icon from '@components/ui/Icon.astro';
import LogoBadge from '@components/ui/LogoBadge.astro';
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import { logoSrc } from '@lib/content';
import { logoHasOwnRing } from '@lib/logo-display';
import type { VisionBoard } from '@schemas';
import type { VisionMark } from '@schemas';

function nodeRasterLogo(mark: VisionMark): string | undefined {
  if (mark.kind !== 'logo') return undefined;
  if (logoHasOwnRing(mark.asset)) return undefined;
  return logoSrc(mark.asset);
}

type VisionGroup = VisionBoard['groups'][number];

interface Props {
  group: VisionGroup;
}

const { group } = Astro.props;

const leadAsset = group.lead.kind === 'logo' ? group.lead.asset : undefined;
const leadLogo = leadAsset ? logoSrc(leadAsset) : undefined;
const leadUsesRasterLogo = Boolean(
  leadLogo && leadAsset && !logoHasOwnRing(leadAsset)
);

// Radial geometry — all lengths in cqi (1cqi = 1% of the square stage width).
const ORBIT = 36; // centre → satellite distance
const NODE = 18; // satellite diameter
const CENTER = 28; // centre-hub diameter
const count = group.marks.length;

// Pre-compute each satellite's offset + spoke angle so the CSS stays trig-free.
const nodes = group.marks.map((mark, i) => {
  const angle = (2 * Math.PI * i) / count - Math.PI / 2; // start at 12 o'clock
  return {
    mark,
    tx: +(Math.cos(angle) * ORBIT).toFixed(3),
    ty: +(Math.sin(angle) * ORBIT).toFixed(3),
    rot: +((360 * i) / count - 90).toFixed(3),
    rasterLogo: nodeRasterLogo(mark),
  };
});

// Spokes run only across the gap between the two rings.
const spokeStart = CENTER / 2;
const spokeLen = ORBIT - CENTER / 2 - NODE / 2;
---

<figure class="vision-hub">
  <div
    class="vision-hub__stage"
    style={`--orbit:${ORBIT}cqi;--node:${NODE}cqi;--center:${CENTER}cqi;--spoke-start:${spokeStart}cqi;--spoke-len:${spokeLen}cqi`}
  >
    <div class="vision-hub__ring" aria-hidden="true"></div>

    {
      nodes.map((n) => (
        <span
          class="vision-hub__spoke"
          style={`--rot:${n.rot}deg`}
          aria-hidden="true"
        />
      ))
    }

    <div class="vision-hub__center">
      {
        group.lead.kind === 'icon' ? (
          <Icon name={group.lead.name} size={44} />
        ) : leadUsesRasterLogo && leadLogo ? (
          <LogoBadge
            logoUrl={leadLogo}
            altText={group.lead.alt ?? group.label}
            useBadge={false}
            size="md"
            class="vision-hub__lead-logo"
          />
        ) : (
          <MarkEmblem mark={group.lead} class="vision-hub__lead" />
        )
      }
    </div>

    {
      nodes.map((n) => (
        <span
          class="vision-hub__node"
          style={`--tx:${n.tx}cqi;--ty:${n.ty}cqi`}
        >
          {n.rasterLogo ? (
            <img
              src={n.rasterLogo}
              alt={n.mark.kind === 'logo' ? (n.mark.alt ?? '') : ''}
              class="vision-hub__node-img"
              loading="lazy"
              aria-hidden="true"
            />
          ) : (
            <MarkEmblem mark={n.mark} />
          )}
        </span>
      ))
    }
  </div>

  <div class="vision-hub__below">
    <div class="vision-hub__rule" aria-hidden="true">
      <span class="vision-hub__rule-line"></span>
      <span class="vision-hub__rule-dot"></span>
      <span class="vision-hub__rule-line"></span>
    </div>

    <figcaption class="vision-hub__label">{group.label}</figcaption>
  </div>
</figure>

<style>
  .vision-hub {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    /* Reserve space for rule + label below the stage (out-of-flow footer). */
    margin-bottom: var(--vision-hub-footer-h);
  }

  .vision-hub__stage {
    container-type: inline-size;
    position: relative;
    width: 100%;
    max-width: var(--vision-hub-max);
    aspect-ratio: 1;
  }

  /* Outer circle — bright purple ring, echoing the reference (no glow). */
  .vision-hub__ring {
    position: absolute;
    inset: 4%;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent) 55%, transparent);
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--accent) 14%, transparent) 0%,
      transparent 64%
    );
    z-index: 1;
  }

  .vision-hub__center {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--center);
    height: var(--center);
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent-ll);
    z-index: 2;
  }
  .vision-hub__center :global(.icon) {
    width: 46%;
    height: 46%;
  }
  /* Contain-masked lead mark: wide wordmarks fit to width, square emblems to height. */
  .vision-hub__center :global(.vision-hub__lead) {
    width: 62%;
    height: 52%;
  }
  .vision-hub__center :global(.vision-hub__lead-logo) {
    width: 72%;
    max-height: 46%;
  }
  .vision-hub__center :global(.vision-hub__lead-logo img) {
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
  }

  .vision-hub__node {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--node);
    height: var(--node);
    transform: translate(-50%, -50%) translate(var(--tx), var(--ty));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid color-mix(in srgb, var(--accent) 42%, transparent);
    border-radius: 50%;
    background: color-mix(in srgb, var(--bg) 82%, var(--accent));
    color: var(--accent-ll);
    z-index: 2;
  }
  .vision-hub__node :global(.mark-emblem),
  .vision-hub__node :global(.icon) {
    width: 52%;
    height: 52%;
  }
  .vision-hub__node-img {
    width: 72%;
    height: 72%;
    object-fit: contain;
  }

  /* Dotted spoke bridging centre-ring edge → satellite-ring edge. */
  .vision-hub__spoke {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--spoke-len);
    height: 0;
    border-top: 2px dotted color-mix(in srgb, var(--accent) 45%, transparent);
    transform-origin: 0 0;
    transform: rotate(var(--rot)) translateX(var(--spoke-start));
    z-index: 1;
  }

  .vision-hub__below {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .vision-hub__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 62%;
    max-width: 220px;
  }

  .vision-hub__rule-line {
    flex: 1;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .vision-hub__rule-dot {
    width: calc(var(--space-1) + var(--space-0-5));
    height: calc(var(--space-1) + var(--space-0-5));
    border-radius: 50%;
    background: var(--accent-ll);
    flex-shrink: 0;
  }

  .vision-hub__label {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent-ll);
    margin: 0;
  }

  @media (max-width: 480px) {
    .vision-hub__stage {
      max-width: 300px;
    }
  }
</style>
