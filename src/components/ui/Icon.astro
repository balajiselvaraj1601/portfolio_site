---
import type { IconName } from '@lib/icons';
import {
  iconBody,
  iconPixelSize,
  isFilledIcon,
  isBrandMonoIcon,
} from '@lib/icon-render';
import type { IconSizeToken } from '@lib/icon-render';

// Inline SVG from src/lib/icon-paths.json — inherits currentColor for tinting.
// Decorative by default (aria-hidden); pass a `label` to expose an accessible name.
interface Props {
  name: IconName;
  label?: string;
  size?: number | IconSizeToken;
  class?: string;
}

const { name, label, size = 'md', class: cls } = Astro.props;
const px = iconPixelSize(size);
const filled = isFilledIcon(name);
const brandMono = isBrandMonoIcon(name);
const body = iconBody(name);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={px}
  height={px}
  viewBox="0 0 24 24"
  fill={filled ? 'currentColor' : 'none'}
  stroke={filled ? 'none' : 'currentColor'}
  stroke-width={filled ? undefined : '1.8'}
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['icon', brandMono && 'icon--brand', cls]}
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
  aria-label={label}
>
  <g set:html={body} />
</svg>

<style is:global>
  .icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
  /* Official monochrome brand marks render in neutral per-background ink,
     ignoring the surrounding context color. */
  .icon--brand {
    color: var(--brand-mark);
  }
</style>
