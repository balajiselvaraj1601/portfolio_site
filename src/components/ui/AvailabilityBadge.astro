---
import type { Profile } from '@schemas';

// Derive the status union from the schema (SSOT) rather than re-declaring it.
type Status = NonNullable<Profile['availability']>['status'];

interface Props {
  status: Status;
  label: string;
  class?: string;
}

const { status, label, class: cls } = Astro.props;
---

<span class:list={['avail', `avail--${status}`, cls]}>
  <span class="avail__dot" aria-hidden="true"></span>
  <span class="avail__label">{label}</span>
</span>

<style>
  .avail {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: var(--pill-padding-y) var(--pill-padding-x);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    background: var(--accent-soft);
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    color: var(--text);
    line-height: 1;
  }
  .avail__dot {
    width: var(--size-dot);
    height: var(--size-dot);
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--avail-dot, var(--status-available));
    box-shadow: 0 0 0 3px
      color-mix(
        in srgb,
        var(--avail-dot, var(--status-available)) 22%,
        transparent
      );
  }
  .avail--available {
    --avail-dot: var(--status-available);
  }
  .avail--limited {
    --avail-dot: var(--status-limited);
  }
  .avail--closed {
    --avail-dot: var(--status-closed);
  }
  @media (prefers-reduced-motion: no-preference) {
    .avail__dot {
      animation: avail-pulse 2.4s ease-in-out infinite;
    }
  }
  @keyframes avail-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px
        color-mix(in srgb, var(--avail-dot) 22%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--avail-dot) 8%, transparent);
    }
  }
</style>
