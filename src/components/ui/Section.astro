---
import Eyebrow from '@components/ui/Eyebrow.astro';

interface Props {
  id: string;
  title: string;
  hideTitle?: boolean;
  eyebrow?: string;
  eyebrowVariant?: 'default' | 'red';
  subtitle?: string;
  variant?: 'default' | 'alt' | 'full' | 'impact';
  /**
   * Explicit accessible name for the section, used only when `title` is empty
   * (e.g. sections that render their own heading). Ignored when a real `title`
   * is provided, since the emitted <h2> already labels the section.
   */
  ariaLabel?: string;
  /** Points aria-labelledby at a custom heading (e.g. SectionHeading) when hideTitle. */
  labelledBy?: string;
  class?: string;
}
const {
  id,
  title,
  hideTitle = false,
  eyebrow,
  eyebrowVariant = 'default',
  subtitle,
  variant = 'default',
  ariaLabel,
  labelledBy,
  class: cls,
} = Astro.props;
const headingId = `${id}-heading`;
// Only emit the labelling <h2> when there is real title text. Sections that
// pass title="" (and render their own heading) would otherwise get an empty
// accessible name via a dangling aria-labelledby pointing at an empty heading.
const hasTitle = title.trim().length > 0;
---

<section
  id={id}
  class:list={[
    'section',
    'reveal',
    {
      'section--alt': variant === 'alt',
      'section--full': variant === 'full',
      'section--impact': variant === 'impact',
    },
    cls,
  ]}
  aria-labelledby={labelledBy ?? (hasTitle ? headingId : undefined)}
  aria-label={!hasTitle && !labelledBy ? ariaLabel : undefined}
>
  <div class="container">
    {eyebrow && <Eyebrow text={eyebrow} variant={eyebrowVariant} />}
    {
      hasTitle && (
        <h2
          id={headingId}
          class:list={['section__title', { 'visually-hidden': hideTitle }]}
        >
          {title}
        </h2>
      )
    }
    {subtitle && <p class="section__subtitle">{subtitle}</p>}
    <slot />
  </div>
</section>
