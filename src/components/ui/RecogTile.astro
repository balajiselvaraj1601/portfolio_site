---
// Shared recognition summary stat tile (Awards, Kaggle). Spreads ...rest onto
// the root so the parent's scoped-style attribute (and any accent class passed
// via `class`) keeps matching.
import CardMark from '@components/ui/CardMark.astro';
import type { IconName } from '@lib/icons';
import type { HTMLAttributes } from 'astro/types';

interface Props {
  icon: IconName;
  /** logo_* slug for MarkEmblem rendering (e.g. 'logo_trophy_badge').
   *  Falls back to <Icon name={icon}> when the SVG asset is not yet available (BC5). */
  markSlug?: string;
  count: string | number;
  label: string;
  class?: string;
  role?: HTMLAttributes<'div'>['role'];
}

const { icon, markSlug, count, label, class: cls, ...rest } = Astro.props;
---

<div class:list={['theme-card', 'card', cls]} {...rest}>
  <CardMark
    icon={icon}
    mark={markSlug ? { kind: 'logo', asset: markSlug } : undefined}
    context="theme-card"
    emblemInCircle
  />
  <div class="recog-tile__count">{count}</div>
  <p class="recog-tile__label">{label}<slot name="label-extra" /></p>
</div>
