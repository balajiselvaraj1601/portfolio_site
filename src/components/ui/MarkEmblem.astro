---
import Icon from '@components/ui/Icon.astro';
import { logoSrc } from '@lib/content';
import type { VisionMark } from '@schemas';

interface Props {
  mark: VisionMark;
  /** Optional px override for Tier D infographics only; default uses --mark-glyph via CSS. */
  iconSize?: number;
  /** Mask sizing for logo branch; default scales glyph with SVG viewBox padding. */
  maskSize?: string;
  class?: string;
}

const { mark, iconSize, maskSize, class: cls } = Astro.props;
const fillMask = maskSize === '100% 100%';

// Resolve the logo URL only on the 'logo' branch; the emblem is painted via a
// CSS mask so it inherits the parent's currentColor in both themes.
const logo = mark.kind === 'logo' ? logoSrc(mark.asset) : undefined;
---

{
  mark.kind === 'icon' ? (
    <Icon name={mark.name} size={iconSize ?? 'md'} class={cls} />
  ) : logo ? (
    <span
      class:list={['mark-emblem', fillMask && 'mark-emblem--fill', cls]}
      style={`--emblem:url("${logo}")`}
      aria-hidden="true"
    />
  ) : null
}

<style>
  .mark-emblem {
    display: block;
    width: var(--mark-glyph, 100%);
    height: var(--mark-glyph, 100%);
    background: currentColor;
    -webkit-mask: var(--emblem) center / contain no-repeat;
    mask: var(--emblem) center / contain no-repeat;
  }
  .mark-emblem--fill {
    -webkit-mask: var(--emblem) center / 100% 100% no-repeat;
    mask: var(--emblem) center / 100% 100% no-repeat;
  }
</style>
