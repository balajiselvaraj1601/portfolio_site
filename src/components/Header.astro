---
import { site, navItems } from '@lib/content';
import Monogram from '@components/Monogram.astro';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (path: string) => (path.replace(/\/$/, '') || '/') === current;
const internalNavItems = navItems.filter((item) => !item.external);
const resumeItem = navItems.find((item) => item.id === 'resume');
const resumeLabel = resumeItem?.label ?? site.resume.label;
const resumePath = resumeItem?.path ?? site.resume.path;

const [firstName, ...rest] = site.name.split(' ');
const lastName = rest.join(' ');
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={site.name}>
      <span class="brand__wordmark" aria-hidden="true">
        {firstName}{' '}
        <span class="brand__accent">{lastName}</span>
      </span>
      <span class="brand__mark" aria-hidden="true">
        <Monogram size={36} />
      </span>
    </a>

    <nav class="nav" id="primary-nav" aria-label="Primary">
      <ul class="nav__list">
        {
          internalNavItems.map((item) => (
            <li>
              <a
                class="nav__link"
                href={item.path}
                aria-current={isActive(item.path) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="nav__mobile-actions" role="group" aria-label="Primary actions">
        <a
          class="btn btn-secondary nav-resume"
          href={resumePath}
          aria-label={site.resume.label}
        >
          {resumeLabel}
        </a>
        <a class="btn btn-primary nav-cta" href="/contact">Get in Touch</a>
      </div>
    </nav>

    <div class="site-header__actions">
      <a
        class="btn btn-secondary nav-resume"
        href={resumePath}
        aria-label={site.resume.label}
      >
        {resumeLabel}
      </a>
      <a class="btn btn-primary nav-cta" href="/contact">Get in Touch</a>
      <button
        type="button"
        class="save-btn"
        id="save-btn"
        aria-label="Save page as HTML"
        title="Save page as HTML"
      >
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M13 14H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h8l3 3v8a1 1 0 0 1-1 1Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
          <path d="M5 2v3h5V2M5 14v-5h6v5" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
        </svg>
        <span class="save-btn__spinner" aria-hidden="true"></span>
      </button>
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
      >
        <span class="theme-toggle__sun" aria-hidden="true">☀</span>
        <span class="theme-toggle__moon" aria-hidden="true">☾</span>
      </button>

      <button
        type="button"
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <span class="nav-toggle__open" aria-hidden="true">☰</span>
        <span class="nav-toggle__close" aria-hidden="true">✕</span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  @media (prefers-reduced-motion: no-preference) {
    .site-header {
      transition: background-color var(--dur) var(--ease),
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .site-header__inner {
      transition: min-height var(--dur) var(--ease);
    }
  }
  .site-header.is-scrolled {
    background: color-mix(in srgb, var(--bg) 95%, transparent);
    border-bottom-color: var(--border-strong);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }
  .site-header.is-scrolled .site-header__inner {
    min-height: 52px;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--header-h);
    gap: var(--space-3);
  }
  .brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--heading);
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .brand__wordmark {
    display: inline;
  }
  .brand__mark {
    display: none;
  }
  .brand__accent {
    color: var(--accent-light);
  }
  @media (max-width: 480px) {
    .brand__wordmark {
      display: none;
    }
    .brand__mark {
      display: inline-flex;
    }
  }
  .nav__list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__mobile-actions {
    display: none;
  }
  .nav__link {
    position: relative;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.4rem 0.85rem;
    border-radius: 4px;
    transition: color 0.2s, background-color 0.2s;
  }
  .nav__link:hover,
  .nav__link[aria-current='page'] {
    color: var(--heading);
    background: var(--accent-soft);
  }
  .nav__link[aria-current='page']::after {
    content: none;
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .nav-cta,
  .nav-resume {
    font-size: 0.75rem;
    padding: 0.45rem 1.1rem;
    white-space: nowrap;
  }
  .nav-resume {
    background: color-mix(in srgb, var(--bg-elev) 72%, transparent);
  }
  .save-btn,
  .theme-toggle,
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--text);
    font-size: 1rem;
  }
  .save-btn {
    position: relative;
  }
  .save-btn:hover,
  .theme-toggle:hover,
  .nav-toggle:hover {
    border-color: var(--accent);
  }
  .save-btn[aria-busy='true'] svg {
    opacity: 0;
  }
  .save-btn__spinner {
    display: none;
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent-light);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  .save-btn[aria-busy='true'] .save-btn__spinner {
    display: block;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  :global(html[data-theme='dark']) .theme-toggle__moon,
  :global(html:not([data-theme='dark'])) .theme-toggle__sun {
    display: none;
  }
  @media (max-width: 1024px) {
    .nav {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .site-header__actions .nav-cta,
    .site-header__actions .nav-resume {
      display: none;
    }
    .nav.is-open {
      display: block;
      position: fixed;
      inset: var(--header-h) 0 0 0;
      background: var(--bg);
      padding: var(--space-6);
      overflow-y: auto;
      border-top: 1px solid var(--border);
    }
    .nav.is-open .nav__list {
      flex-direction: column;
      gap: var(--space-1);
    }
    .nav.is-open .nav__link {
      display: block;
      padding: var(--space-3) var(--space-4);
      font-size: 1rem;
    }
    .nav.is-open .nav__link[aria-current='page']::after {
      content: none;
    }
    .nav.is-open .nav__mobile-actions {
      display: grid;
      gap: var(--space-3);
      margin-top: var(--space-6);
      padding-top: var(--space-6);
      border-top: 1px solid var(--border);
    }
    .nav.is-open .nav__mobile-actions .btn {
      justify-content: center;
      width: 100%;
    }
  }
  .nav-toggle__close {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__open {
    display: none;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__close {
    display: inline;
  }
</style>

<script>
  import { initSiteChrome } from '../scripts/site-chrome';
  import { savePage } from '../scripts/save-page';
  initSiteChrome();
  document.getElementById('save-btn')?.addEventListener('click', savePage);
</script>
