---
import '../styles/global.css';
import deferredFontsUrl from '../styles/fonts-deferred.css?url';
import BaseHead from '@components/chrome/BaseHead.astro';
import ThemeScript from '@components/chrome/ThemeScript.astro';
import Header from '@components/chrome/Header.astro';
import Footer from '@components/chrome/Footer.astro';
import DotNav from '@components/chrome/DotNav.astro';
import SiteChromeBoot from '@components/chrome/SiteChromeBoot.astro';
import HeroCanvas from '@components/cards/HeroCanvas.astro';
import {
  navViews,
  defaultTheme,
  homeViewAnchor,
  profile,
  sectionToDotNav,
  homeSections,
  type DotNavView,
} from '@lib/content';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  chrome?: boolean;
  dotNavViews?: DotNavView[];
  singlePageViews?: boolean;
}
const {
  title,
  description,
  path = '/',
  chrome = true,
  dotNavViews: dotNav = [],
  singlePageViews = false,
} = Astro.props;

const navViewsConfig = singlePageViews
  ? {
      views: navViews.map((v) => ({
        viewAnchor: v.viewAnchor,
        viewSections: v.viewSections,
      })),
      defaultView: homeViewAnchor,
    }
  : undefined;
const hashCollisionAnchors =
  navViewsConfig?.views
    .filter((v) => v.viewSections[0] && v.viewSections[0] !== v.viewAnchor)
    .map((v) => v.viewAnchor) ?? [];
const preloadPortrait =
  path === '/' && profile.portrait
    ? { webp: profile.portrait.webp, avif: profile.portrait.avif }
    : undefined;
const dotNavConfig =
  dotNav.length >= 2
    ? {
        orderedSections: homeSections,
        sectionToDot: sectionToDotNav,
      }
    : undefined;
---

<!doctype html>
<html lang="en" data-theme={defaultTheme}>
  <head>
    <ThemeScript />
    {
      hashCollisionAnchors.length > 0 && (
        <script
          is:inline
          set:html={`(function(){var a=${JSON.stringify(hashCollisionAnchors)};var h=location.hash.replace(/^#/,"");if(a.indexOf(h)>=0){if("scrollRestoration"in history)history.scrollRestoration="manual";scrollTo(0,0);}})();`}
        />
      )
    }
    <BaseHead
      title={title}
      description={description}
      path={path}
      preloadPortrait={preloadPortrait}
    />
    <link
      id="fonts-deferred"
      rel="stylesheet"
      href={deferredFontsUrl}
      media="print"
    />
    <script is:inline>
      (function () {
        const link = document.getElementById('fonts-deferred');
        if (!link) return;
        link.addEventListener('load', function () {
          link.media = 'all';
        });
        if (link.sheet) link.media = 'all';
      })();
    </script>
    <noscript>
      <link rel="stylesheet" href={deferredFontsUrl} />
    </noscript>
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <HeroCanvas />
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome && <Header singlePageViews={singlePageViews} />}
    {chrome && dotNav.length >= 2 && <DotNav views={dotNav} />}
    <main id="main">
      <slot />
    </main>
    {chrome && <Footer />}
    {
      chrome && navViewsConfig && (
        <script
          is:inline
          type="application/json"
          id="nav-views-config"
          set:html={JSON.stringify(navViewsConfig)}
        />
      )
    }
    {
      chrome && dotNavConfig && (
        <script
          is:inline
          type="application/json"
          id="dot-nav-config"
          set:html={JSON.stringify(dotNavConfig)}
        />
      )
    }
    {chrome && <SiteChromeBoot />}
    <script>
      import { initAssetGuard } from '../scripts/asset-guard';
      initAssetGuard();
    </script>


  </body>
</html>

<style is:global>
  body {
    padding-top: var(--header-h);
  }
</style>
