---
import '../styles/global.css';
import BaseHead from '@components/BaseHead.astro';
import ThemeScript from '@components/ThemeScript.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  /** Render the persistent header/footer chrome (off for 404 minimalism if needed). */
  chrome?: boolean;
}
const { title, description, path = '/', chrome = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeScript />
    <BaseHead title={title} description={description} path={path} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome && <Header />}
    <main id="main">
      <slot />
    </main>
    {chrome && <Footer />}
  </body>
</html>
