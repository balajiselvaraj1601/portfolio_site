---
import '../styles/global.css';
import BaseHead from '@components/BaseHead.astro';
import ThemeScript from '@components/ThemeScript.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import DotNav from '@components/DotNav.astro';
import HeroCanvas from '@components/HeroCanvas.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  chrome?: boolean;
  dotNavSections?: string[];
}
const {
  title,
  description,
  path = '/',
  chrome = true,
  dotNavSections = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeScript />
    <BaseHead title={title} description={description} path={path} />
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <HeroCanvas />
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome && <Header />}
    {chrome && dotNavSections.length >= 2 && (
      <DotNav sections={dotNavSections} />
    )}
    <main id="main">
      <slot />
    </main>
    {chrome && <Footer />}
  </body>
</html>

<style is:global>
  body {
    padding-top: var(--header-h);
  }
</style>
