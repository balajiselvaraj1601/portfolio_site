{
  "name": "portfolio-site",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:restart": "node scripts/dev-restart.mjs",
    "start": "astro dev",
    "build": "astro build",
    "optimize:images": "node scripts/optimize-images.mjs",
    "optimize:images:check": "node scripts/optimize-images.mjs --check",
    "perf:lighthouse": "node scripts/lighthouse-check.mjs",
    "preview": "astro preview",
    "preview:restart": "node scripts/preview-restart.mjs",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:tokens": "node scripts/check-icon-token-sync.mjs",
    "verify": "npm run check && npm run check:tokens && npm run lint && npm run format:check && npm run build",
    "release:bump": "node scripts/bump-version.mjs",
    "test:icons": "python3 tests/run-icon-tests.py",
    "screenshots:baseline": "node scripts/baseline-shots.mjs",
    "smoke:localhost": "node .cursor/scripts/smoke-localhost.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.6.0",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^4.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
